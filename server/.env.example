# 服务端口
PORT=3000

# JWT 密钥。正式环境必须改为强随机字符串。
JWT_SECRET=your-strong-random-secret-here

# 数据库配置
MYSQL_HOST=localhost
MYSQL_PORT=3306
MYSQL_USER=root
MYSQL_PASSWORD=123456
MYSQL_DATABASE=jingyi_reservation

# Redis 配置
REDIS_HOST=localhost
REDIS_PORT=6379
REDIS_PASSWORD=

# 微信小程序配置
WECHAT_APPID=wxa83f083ceb601977
WECHAT_APPSECRET=your-wechat-appsecret

# 管理后台地址。开发环境可用 http://localhost:5173。
ADMIN_ORIGIN=http://localhost:5173

# 允许访问接口的来源，多个地址用英文逗号分隔。
CORS_ORIGINS=http://localhost:5173,http://127.0.0.1:5173,https://servicewechat.com,https://mp.weixin.qq.com

# 服务端基础地址。正式上线后改为真实 HTTPS 域名。
BASE_URL=http://127.0.0.1:3000
