# 运行环境：development / test / production
NODE_ENV=development

# 服务端口
PORT=3000

# 仅非生产环境可启用模拟数据。production 会强制禁用模拟回退。
ALLOW_MOCK_DB=true
ALLOW_MOCK_REDIS=true

# JWT 密钥。正式环境必须改为强随机字符串。
JWT_SECRET=your-strong-random-secret-here

# 动态签到凭证签名密钥。正式环境必须使用独立强随机字符串。
CHECKIN_CREDENTIAL_SECRET=your-independent-checkin-secret-here
# 动态二维码有效期，服务端限制为30-90秒。
CHECKIN_CREDENTIAL_TTL_SECONDS=60
# 到期前多少秒自动刷新，服务端限制为10-30秒。
CHECKIN_CREDENTIAL_REFRESH_BEFORE_SECONDS=15

# 数据库配置。正式环境不得使用默认账号或弱密码。
MYSQL_HOST=localhost
MYSQL_PORT=3306
MYSQL_USER=jingyi_app
MYSQL_PASSWORD=replace-with-strong-database-password
MYSQL_DATABASE=jingyi_reservation

# Redis 配置
REDIS_HOST=localhost
REDIS_PORT=6379
REDIS_PASSWORD=replace-with-strong-redis-password
REDIS_DB=0

# 微信小程序配置
WECHAT_APPID=your-wechat-appid
WECHAT_APPSECRET=your-wechat-appsecret

# 管理后台地址。开发环境可用 http://localhost:5173。
ADMIN_ORIGIN=http://localhost:5173

# 允许访问接口的来源，多个地址用英文逗号分隔。
CORS_ORIGINS=http://localhost:5173,http://127.0.0.1:5173,https://servicewechat.com,https://mp.weixin.qq.com

# 服务端基础地址。正式上线后改为真实 HTTPS 域名。
BASE_URL=http://127.0.0.1:3000
