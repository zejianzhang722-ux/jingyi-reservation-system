.reservation-card {
  background-color: #FFFFFF;
  border-radius: 12rpx;
  padding: 24rpx;
  margin: 12rpx 24rpx;
  box-shadow: 0 2rpx 12rpx rgba(0, 0, 0, 0.08);
}

.reservation-card-header {
  display: flex;
  flex-direction: row;
  justify-content: space-between;
  align-items: center;
  margin-bottom: 16rpx;
}

.reservation-card-room {
  display: flex;
  flex-direction: row;
  align-items: center;
  gap: 12rpx;
}

.reservation-card-room-name {
  font-size: 30rpx;
  font-weight: bold;
  color: #333333;
}

.reservation-card-room-number {
  font-size: 24rpx;
  color: #999999;
}

.reservation-card-body {
  padding: 12rpx 0;
  border-top: 1rpx solid #F0F0F0;
  border-bottom: 1rpx solid #F0F0F0;
}

.reservation-card-info-row {
  display: flex;
  flex-direction: row;
  justify-content: space-between;
  align-items: center;
  padding: 8rpx 0;
}

.reservation-card-label {
  font-size: 26rpx;
  color: #999999;
}

.reservation-card-value {
  font-size: 26rpx;
  color: #333333;
}

.reservation-card-actions {
  display: flex;
  flex-direction: row;
  justify-content: flex-end;
  gap: 16rpx;
  padding-top: 16rpx;
}

.reservation-card-action {
  padding: 12rpx 24rpx;
  border-radius: 8rpx;
  font-size: 24rpx;
  text-align: center;
}

.btn-cancel {
  background-color: #FFF2F0;
  color: #FF4D4F;
  border: 1rpx solid #FF4D4F;
}

.btn-checkin {
  background-color: #0066CC;
  color: #FFFFFF;
}

.btn-qrcode {
  background-color: #F6FFED;
  color: #52C41A;
  border: 1rpx solid #52C41A;
}
