.date-picker {
  width: 100%;
  white-space: nowrap;
  padding: 18rpx 0 14rpx;
  background: rgba(248, 251, 255, 0.88);
  border-bottom: 1rpx solid rgba(255,255,255,0.75);
  box-shadow: 0 14rpx 32rpx rgba(99,117,150,0.08);
  backdrop-filter: blur(18px);
  -webkit-backdrop-filter: blur(18px);
}

.date-picker-inner {
  display: flex;
  flex-direction: row;
  padding: 0 24rpx;
  gap: 16rpx;
}

.date-item {
  position: relative;
  flex-shrink: 0;
  display: flex;
  flex-direction: column;
  align-items: center;
  justify-content: center;
  min-width: 128rpx;
  padding: 17rpx 26rpx;
  border-radius: 24rpx;
  background: linear-gradient(145deg, rgba(255,255,255,0.96), rgba(236,242,250,0.88));
  border: 1rpx solid rgba(255,255,255,0.88);
  box-shadow: 8rpx 10rpx 20rpx rgba(154,170,196,0.16), -6rpx -6rpx 16rpx rgba(255,255,255,0.84), inset 0 2rpx 0 rgba(255,255,255,0.84);
  box-sizing: border-box;
  transition: transform 160ms ease, box-shadow 160ms ease;
}

.date-item:active {
  transform: scale(0.965);
  box-shadow: inset 6rpx 6rpx 14rpx rgba(164,178,202,0.18), inset -6rpx -6rpx 14rpx rgba(255,255,255,0.82);
}

.date-item-active {
  background: linear-gradient(135deg, #2f80ff 0%, #39c6df 100%);
  box-shadow: 0 16rpx 30rpx rgba(47,128,255,0.24), inset 0 2rpx 0 rgba(255,255,255,0.32);
}

.date-item-active::after {
  content: '';
  position: absolute;
  left: 50%;
  bottom: 8rpx;
  width: 28rpx;
  height: 5rpx;
  margin-left: -14rpx;
  border-radius: 8rpx;
  background: rgba(255,255,255,0.82);
  box-shadow: 0 0 10rpx rgba(255,255,255,0.45);
}

.date-weekday {
  font-size: 22rpx;
  color: #8d9ab0;
  margin-bottom: 5rpx;
  font-weight: 650;
}

.date-display {
  font-size: 30rpx;
  line-height: 1.2;
  font-weight: 860;
  color: #1f2a3d;
}

.date-item-active .date-weekday,
.date-item-active .date-display {
  color: #ffffff;
}
