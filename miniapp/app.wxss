page {
  --primary: #0066CC;
  --primary-dark: #003D7A;
  --primary-light: #E6F0FF;
  --accent: #C4943A;
  --accent-light: rgba(196, 148, 58, 0.1);
  --success: #52C41A;
  --success-light: #F6FFED;
  --danger: #FF4D4F;
  --danger-light: #FFF2F0;
  --warning: #FA8C16;
  --warning-light: #FFF7E6;
  --disabled: #D9D9D9;
  --blue: #1890FF;
  --text-primary: #1A1A1A;
  --text-secondary: #666666;
  --text-hint: #999999;
  --bg-page: #F5F6FA;
  --bg-card: #FFFFFF;
  --border-color: #F0F0F0;
  --font-size-xs: 20rpx;
  --font-size-sm: 24rpx;
  --font-size-md: 28rpx;
  --font-size-lg: 32rpx;
  --font-size-xl: 36rpx;
  --radius-sm: 8rpx;
  --radius-md: 12rpx;
  --radius-lg: 16rpx;
  --radius-xl: 24rpx;
  --shadow: 0 2rpx 12rpx rgba(0, 0, 0, 0.06);
  --shadow-lg: 0 4rpx 24rpx rgba(0, 0, 0, 0.08);
  --shadow-accent: 0 2rpx 12rpx rgba(196, 148, 58, 0.15);
}

@keyframes fadeIn {
  from {
    opacity: 0;
    transform: translateY(12rpx);
  }
  to {
    opacity: 1;
    transform: translateY(0);
  }
}

@keyframes shimmer {
  0% {
    background-position: -200% 0;
  }
  100% {
    background-position: 200% 0;
  }
}

@keyframes spin {
  to {
    transform: rotate(360deg);
  }
}

@keyframes pulseGlow {
  0%, 100% {
    box-shadow: 0 0 0 0 rgba(196, 148, 58, 0.3);
  }
  50% {
    box-shadow: 0 0 16rpx 4rpx rgba(196, 148, 58, 0.15);
  }
}

.page-fade-in {
  animation: fadeIn 0.3s ease-out both;
}

.glass-effect {
  background: rgba(255, 255, 255, 0.72);
  backdrop-filter: blur(20px);
  -webkit-backdrop-filter: blur(20px);
}

.skeleton {
  background: linear-gradient(90deg, #F0F0F0 25%, #E8E8E8 37%, #F0F0F0 63%);
  background-size: 200% 100%;
  animation: shimmer 1.5s ease-in-out infinite;
  border-radius: var(--radius-sm);
}

.container {
  display: flex;
  flex-direction: column;
  min-height: 100vh;
  background-color: var(--bg-page);
  padding-bottom: calc(110rpx + env(safe-area-inset-bottom));
}

.card {
  background-color: var(--bg-card);
  border-radius: var(--radius-lg);
  padding: 24rpx;
  margin: 16rpx 24rpx;
  box-shadow: var(--shadow);
}

.btn-primary {
  background-color: var(--primary);
  color: #FFFFFF;
  border: none;
  border-radius: var(--radius-xl);
  padding: 20rpx 40rpx;
  font-size: var(--font-size-md);
  text-align: center;
  line-height: 1.5;
  transition: opacity 0.2s ease, transform 0.15s ease;
}

.btn-primary:active {
  opacity: 0.85;
  transform: scale(0.97);
}

.btn-danger {
  background-color: var(--danger);
  color: #FFFFFF;
  border: none;
  border-radius: var(--radius-xl);
  padding: 20rpx 40rpx;
  font-size: var(--font-size-md);
  text-align: center;
  line-height: 1.5;
  transition: opacity 0.2s ease, transform 0.15s ease;
}

.btn-danger:active {
  opacity: 0.85;
  transform: scale(0.97);
}

.btn-outline {
  background-color: transparent;
  color: var(--primary);
  border: 2rpx solid var(--primary);
  border-radius: var(--radius-xl);
  padding: 18rpx 38rpx;
  font-size: var(--font-size-md);
  text-align: center;
  line-height: 1.5;
  transition: background-color 0.2s ease;
}

.btn-outline:active {
  background-color: var(--primary-light);
}

.btn-disabled {
  background-color: var(--disabled);
  color: #FFFFFF;
  border: none;
  border-radius: var(--radius-xl);
  padding: 20rpx 40rpx;
  font-size: var(--font-size-md);
  text-align: center;
  line-height: 1.5;
}

.text-primary {
  color: var(--primary);
}

.text-success {
  color: var(--success);
}

.text-danger {
  color: var(--danger);
}

.text-warning {
  color: var(--warning);
}

.text-blue {
  color: var(--blue);
}

.text-accent {
  color: var(--accent);
}

.text-secondary {
  color: var(--text-secondary);
}

.text-hint {
  color: var(--text-hint);
}

.flex-row {
  display: flex;
  flex-direction: row;
  align-items: center;
}

.flex-column {
  display: flex;
  flex-direction: column;
}

.flex-between {
  display: flex;
  justify-content: space-between;
  align-items: center;
}

.flex-center {
  display: flex;
  justify-content: center;
  align-items: center;
}

.flex-1 {
  flex: 1;
}

.ellipsis {
  overflow: hidden;
  text-overflow: ellipsis;
  white-space: nowrap;
}

.section-title {
  font-size: var(--font-size-lg);
  font-weight: 700;
  color: var(--text-primary);
  padding: 24rpx 24rpx 12rpx;
  letter-spacing: 1rpx;
}

.divider {
  height: 1rpx;
  background-color: var(--border-color);
  margin: 16rpx 0;
}

.empty-state {
  display: flex;
  flex-direction: column;
  align-items: center;
  justify-content: center;
  padding: 120rpx 0;
  animation: fadeIn 0.3s ease-out both;
}

.empty-state .empty-icon-svg {
  width: 120rpx;
  height: 120rpx;
  background: var(--border-color);
  border-radius: 50%;
  margin-bottom: 24rpx;
}

.empty-state .empty-text {
  font-size: var(--font-size-md);
  color: var(--text-hint);
}

.loading-state {
  display: flex;
  flex-direction: column;
  align-items: center;
  justify-content: center;
  padding: 120rpx 0;
  animation: fadeIn 0.3s ease-out both;
}

.loading-spinner {
  width: 48rpx;
  height: 48rpx;
  border: 4rpx solid #E8E8E8;
  border-top-color: var(--primary);
  border-radius: 50%;
  animation: spin 0.8s linear infinite;
  margin-bottom: 16rpx;
}

.loading-text {
  font-size: 26rpx;
  color: var(--text-hint);
}

.error-state {
  display: flex;
  flex-direction: column;
  align-items: center;
  justify-content: center;
  padding: 120rpx 0;
  animation: fadeIn 0.3s ease-out both;
}

.error-state .error-icon-svg {
  width: 120rpx;
  height: 120rpx;
  background: var(--danger-light);
  border-radius: 50%;
  margin-bottom: 24rpx;
}

.error-state .error-text {
  font-size: var(--font-size-md);
  color: var(--text-secondary);
  margin-bottom: 24rpx;
}

.error-state .error-retry-btn {
  font-size: var(--font-size-sm);
  color: var(--primary);
  padding: 12rpx 32rpx;
  border: 2rpx solid var(--primary);
  border-radius: var(--radius-xl);
}

.status-tag {
  display: inline-block;
  padding: 4rpx 16rpx;
  border-radius: 20rpx;
  font-size: var(--font-size-xs);
  line-height: 1.6;
}

.status-pending {
  background-color: var(--warning-light);
  color: var(--warning);
}

.status-approved {
  background-color: var(--primary-light);
  color: var(--primary);
}

.status-using {
  background-color: var(--success-light);
  color: var(--success);
}

.status-completed {
  background-color: #F5F5F5;
  color: var(--text-hint);
}

.status-cancelled {
  background-color: #F5F5F5;
  color: #BBBBBB;
}

.status-noshow {
  background-color: var(--danger-light);
  color: var(--danger);
}

.credit-green {
  color: var(--success);
}

.credit-yellow {
  color: var(--warning);
}

.credit-red {
  color: var(--danger);
}

.timeline-container {
  position: relative;
  overflow: hidden;
}

.timeline-header {
  display: flex;
  flex-direction: row;
  position: sticky;
  top: 0;
  z-index: 10;
  background-color: #FFFFFF;
}

.timeline-hour {
  flex-shrink: 0;
  text-align: center;
  font-size: var(--font-size-xs);
  color: var(--text-hint);
  border-right: 1rpx solid var(--border-color);
}

.timeline-row {
  display: flex;
  flex-direction: row;
  align-items: center;
  border-bottom: 1rpx solid var(--border-color);
}

.timeline-seat-label {
  flex-shrink: 0;
  width: 120rpx;
  padding: 12rpx 8rpx;
  font-size: var(--font-size-xs);
  color: var(--text-secondary);
  text-align: center;
  background-color: #FAFAFA;
  border-right: 1rpx solid var(--border-color);
}

.timeline-blocks {
  display: flex;
  flex-direction: row;
  position: relative;
  height: 64rpx;
}

.timeline-block {
  position: absolute;
  top: 8rpx;
  height: 48rpx;
  border-radius: 6rpx;
}

.timeline-block-free {
  background-color: var(--success-light);
  border: 1rpx solid var(--success);
}

.timeline-block-occupied {
  background-color: var(--danger-light);
  border: 1rpx solid var(--danger);
}

.timeline-block-mine {
  background-color: var(--primary-light);
  border: 1rpx solid var(--primary);
}

.timeline-block-unavailable {
  background-color: #F5F5F5;
  border: 1rpx solid var(--disabled);
}

.timeline-block-selected {
  background-color: rgba(0, 102, 204, 0.3);
  border: 2rpx solid var(--primary);
}

.loading-mask {
  position: fixed;
  top: 0;
  left: 0;
  right: 0;
  bottom: 0;
  background-color: rgba(255, 255, 255, 0.6);
  display: flex;
  justify-content: center;
  align-items: center;
  z-index: 9999;
}
