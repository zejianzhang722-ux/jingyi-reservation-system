page {
  --primary: #0066CC;
  --primary-dark: #003D7A;
  --primary-light: #E6F0FF;
  --accent: #C4943A;
  --accent-light: rgba(196, 148, 58, 0.1);
  --success: #52C41A;
  --success-light: #F6FFED;
  --danger: #FF4D4F;
  --danger-light: #FFF2F0;
  --warning: #FA8C16;
  --warning-light: #FFF7E6;
  --disabled: #D9D9D9;
  --blue: #1890FF;
  --text-primary: #1A1A1A;
  --text-secondary: #666666;
  --text-hint: #999999;
  --bg-page: #F5F6FA;
  --bg-card: #FFFFFF;
  --border-color: #F0F0F0;
  --font-size-xs: 20rpx;
  --font-size-sm: 24rpx;
  --font-size-md: 28rpx;
  --font-size-lg: 32rpx;
  --font-size-xl: 36rpx;
  --radius-sm: 8rpx;
  --radius-md: 12rpx;
  --radius-lg: 16rpx;
  --radius-xl: 24rpx;
  --shadow: 0 2rpx 12rpx rgba(0, 0, 0, 0.06);
  --shadow-lg: 0 4rpx 24rpx rgba(0, 0, 0, 0.08);
  --shadow-accent: 0 2rpx 12rpx rgba(196, 148, 58, 0.15);
}

@keyframes fadeIn {
  from { opacity: 0; transform: translateY(12rpx); }
  to { opacity: 1; transform: translateY(0); }
}

@keyframes shimmer {
  0% { background-position: -200% 0; }
  100% { background-position: 200% 0; }
}

@keyframes spin { to { transform: rotate(360deg); } }

@keyframes pulseGlow {
  0%, 100% { box-shadow: 0 0 0 0 rgba(196, 148, 58, 0.3); }
  50% { box-shadow: 0 0 16rpx 4rpx rgba(196, 148, 58, 0.15); }
}

.page-fade-in { animation: fadeIn 0.3s ease-out both; }
.glass-effect { background: rgba(255, 255, 255, 0.72); backdrop-filter: blur(20px); -webkit-backdrop-filter: blur(20px); }
.skeleton { background: linear-gradient(90deg, #F0F0F0 25%, #E8E8E8 37%, #F0F0F0 63%); background-size: 200% 100%; animation: shimmer 1.5s ease-in-out infinite; border-radius: var(--radius-sm); }
.container { display: flex; flex-direction: column; min-height: 100vh; background-color: var(--bg-page); padding-bottom: calc(110rpx + env(safe-area-inset-bottom)); }
.card { background-color: var(--bg-card); border-radius: var(--radius-lg); padding: 24rpx; margin: 16rpx 24rpx; box-shadow: var(--shadow); }
.btn-primary { background-color: var(--primary); color: #FFFFFF; border: none; border-radius: var(--radius-xl); padding: 20rpx 40rpx; font-size: var(--font-size-md); text-align: center; line-height: 1.5; transition: opacity 0.2s ease, transform 0.15s ease; }
.btn-primary:active { opacity: 0.85; transform: scale(0.97); }
.btn-danger { background-color: var(--danger); color: #FFFFFF; border: none; border-radius: var(--radius-xl); padding: 20rpx 40rpx; font-size: var(--font-size-md); text-align: center; line-height: 1.5; transition: opacity 0.2s ease, transform 0.15s ease; }
.btn-danger:active { opacity: 0.85; transform: scale(0.97); }
.btn-outline { background-color: transparent; color: var(--primary); border: 2rpx solid var(--primary); border-radius: var(--radius-xl); padding: 18rpx 38rpx; font-size: var(--font-size-md); text-align: center; line-height: 1.5; transition: background-color 0.2s ease; }
.btn-outline:active { background-color: var(--primary-light); }
.btn-disabled { background-color: var(--disabled); color: #FFFFFF; border: none; border-radius: var(--radius-xl); padding: 20rpx 40rpx; font-size: var(--font-size-md); text-align: center; line-height: 1.5; }
.text-primary { color: var(--primary); }
.text-success { color: var(--success); }
.text-danger { color: var(--danger); }
.text-warning { color: var(--warning); }
.text-blue { color: var(--blue); }
.text-accent { color: var(--accent); }
.text-secondary { color: var(--text-secondary); }
.text-hint { color: var(--text-hint); }
.flex-row { display: flex; flex-direction: row; align-items: center; }
.flex-column { display: flex; flex-direction: column; }
.flex-between { display: flex; justify-content: space-between; align-items: center; }
.flex-center { display: flex; justify-content: center; align-items: center; }
.flex-1 { flex: 1; }

/* 首页新增组团入口后的全局兜底样式，避免旧三宫格布局被四个快捷入口撑乱。 */
.quick-panel { grid-template-columns: repeat(4, 1fr); gap: 12rpx; }
.quick-item { min-height: 172rpx; }
.quick-icon-group { background: linear-gradient(145deg, #f2ebff, #d5c2ff); }
.quick-icon-group-shape { position: relative; width: 36rpx; height: 34rpx; }
.quick-icon-group-shape:before { content: ''; position: absolute; left: 11rpx; top: 1rpx; width: 14rpx; height: 14rpx; border-radius: 50%; background: #7654d6; box-shadow: -11rpx 8rpx 0 -2rpx #7654d6, 11rpx 8rpx 0 -2rpx #7654d6; }
.quick-icon-group-shape:after { content: ''; position: absolute; left: 2rpx; bottom: 0; width: 32rpx; height: 14rpx; border-radius: 18rpx 18rpx 8rpx 8rpx; background: #7654d6; }
