.tab-bar {
  display: flex;
  flex-direction: row;
  position: fixed;
  bottom: 0;
  left: 0;
  right: 0;
  height: 110rpx;
  background: rgba(255, 255, 255, 0.78);
  backdrop-filter: blur(20px);
  -webkit-backdrop-filter: blur(20px);
  border-top: 1rpx solid rgba(240, 240, 240, 0.6);
  padding-bottom: env(safe-area-inset-bottom);
  z-index: 999;
  box-shadow: 0 -2rpx 16rpx rgba(0, 0, 0, 0.04);
}

.tab-bar-item {
  flex: 1;
  display: flex;
  flex-direction: column;
  align-items: center;
  justify-content: center;
  padding: 8rpx 0 4rpx;
  position: relative;
}

.tab-bar-item-active::after {
  content: '';
  position: absolute;
  bottom: 8rpx;
  left: 50%;
  transform: translateX(-50%);
  width: 32rpx;
  height: 4rpx;
  background: var(--accent);
  border-radius: 2rpx;
}

.tab-bar-icon-wrap {
  position: relative;
  width: 48rpx;
  height: 48rpx;
  margin-bottom: 4rpx;
}

.tab-bar-badge {
  position: absolute;
  top: -8rpx;
  right: -16rpx;
  background-color: #FF4D4F;
  border-radius: 20rpx;
  min-width: 28rpx;
  height: 28rpx;
  display: flex;
  align-items: center;
  justify-content: center;
  padding: 0 6rpx;
}

.tab-bar-badge-text {
  font-size: 18rpx;
  color: #FFFFFF;
}

.tab-bar-text {
  font-size: 20rpx;
  color: #999999;
  line-height: 1.2;
  transition: color 0.2s ease;
}

.tab-bar-item-active .tab-bar-text {
  color: var(--primary);
  font-weight: 600;
}

.tab-bar-icon-img {
  width: 44rpx;
  height: 44rpx;
  display: block;
}

.tab-bar-icon-symbol {
  width: 44rpx;
  height: 44rpx;
  border-radius: 16rpx;
  position: relative;
  background: linear-gradient(145deg, #eef4ff, #dbeaff);
  box-shadow: inset 0 2rpx 6rpx rgba(255, 255, 255, 0.72), 0 4rpx 12rpx rgba(0, 102, 204, 0.12);
  opacity: 0.7;
}

.symbol-active {
  opacity: 1;
  background: linear-gradient(145deg, #e9f2ff, #b9d8ff);
}

.tab-bar-icon-approve::before,
.tab-bar-icon-approve::after {
  content: '';
  position: absolute;
  background: var(--primary);
  border-radius: 6rpx;
}

.tab-bar-icon-approve::before {
  width: 22rpx;
  height: 8rpx;
  left: 10rpx;
  top: 22rpx;
  transform: rotate(42deg);
}

.tab-bar-icon-approve::after {
  width: 30rpx;
  height: 8rpx;
  left: 18rpx;
  top: 18rpx;
  transform: rotate(-48deg);
}

.tab-bar-icon-manage::before {
  content: '';
  position: absolute;
  left: 11rpx;
  top: 11rpx;
  width: 22rpx;
  height: 22rpx;
  border: 6rpx solid var(--primary);
  border-radius: 50%;
}

.tab-bar-icon-manage::after {
  content: '';
  position: absolute;
  left: 19rpx;
  top: 4rpx;
  width: 6rpx;
  height: 36rpx;
  background: var(--primary);
  border-radius: 4rpx;
  box-shadow: 14rpx 7rpx 0 -1rpx var(--primary), -14rpx 7rpx 0 -1rpx var(--primary);
}

.tab-bar-icon-user::before {
  content: '';
  position: absolute;
  left: 15rpx;
  top: 8rpx;
  width: 14rpx;
  height: 14rpx;
  background: var(--primary);
  border-radius: 50%;
}

.tab-bar-icon-user::after {
  content: '';
  position: absolute;
  left: 10rpx;
  top: 25rpx;
  width: 24rpx;
  height: 12rpx;
  background: var(--primary);
  border-radius: 14rpx 14rpx 6rpx 6rpx;
}
