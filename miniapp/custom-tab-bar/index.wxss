@import "../styles/theme-3d.wxss";

.tab-bar {
  position: fixed;
  left: 22rpx;
  right: 22rpx;
  bottom: calc(18rpx + env(safe-area-inset-bottom));
  z-index: 999;
  height: 104rpx;
  padding: 7rpx 12rpx;
  display: flex;
  border-radius: 34rpx;
  background: rgba(249, 251, 254, 0.9);
  border: 1rpx solid rgba(255, 255, 255, 0.94);
  box-shadow: 0 22rpx 42rpx rgba(78, 95, 128, 0.20), -8rpx -8rpx 22rpx rgba(255, 255, 255, 0.9), inset 0 2rpx 0 rgba(255, 255, 255, 0.92);
  backdrop-filter: blur(26px);
  -webkit-backdrop-filter: blur(26px);
}

.tab-bar-item {
  position: relative;
  flex: 1;
  display: flex;
  flex-direction: column;
  align-items: center;
  justify-content: center;
  padding: 3rpx 0;
  border-radius: 25rpx;
  transition: transform 180ms ease, background 180ms ease;
}

.tab-bar-item:active {
  transform: scale(0.94);
}

.tab-bar-item-active {
  background: linear-gradient(145deg, rgba(255,255,255,0.94), rgba(228,239,252,0.9));
  box-shadow: inset 0 2rpx 0 rgba(255,255,255,0.92), 7rpx 9rpx 17rpx rgba(137,156,185,0.18), -6rpx -6rpx 14rpx rgba(255,255,255,0.84);
}

.tab-bar-item-active::after {
  content: '';
  position: absolute;
  bottom: -2rpx;
  left: 50%;
  width: 24rpx;
  height: 5rpx;
  margin-left: -12rpx;
  border-radius: 5rpx;
  background: linear-gradient(90deg, var(--primary), var(--cyan));
  box-shadow: 0 5rpx 10rpx rgba(47,128,255,0.28);
}

.tab-bar-icon-wrap {
  position: relative;
  width: 52rpx;
  height: 52rpx;
  margin-bottom: 4rpx;
  display: flex;
  align-items: center;
  justify-content: center;
  border-radius: 18rpx;
  transition: transform 190ms ease, box-shadow 190ms ease;
}

.tab-bar-item-active .tab-bar-icon-wrap {
  transform: translateY(-3rpx);
  background: linear-gradient(145deg, #fdfefe, #dcecff);
  box-shadow: 5rpx 7rpx 13rpx rgba(126,148,180,0.20), -4rpx -4rpx 11rpx rgba(255,255,255,0.94), inset 0 3rpx 5rpx rgba(255,255,255,0.8);
}

.tab-bar-icon-img {
  width: 39rpx;
  height: 39rpx;
  display: block;
  opacity: 0.64;
  transition: opacity 180ms ease, transform 180ms ease, filter 180ms ease;
}

.tab-bar-item-active .tab-bar-icon-img {
  opacity: 1;
  transform: scale(1.08);
  filter: drop-shadow(0 5rpx 5rpx rgba(47,128,255,0.17));
}

.tab-bar-icon-symbol {
  position: relative;
  width: 42rpx;
  height: 42rpx;
  border-radius: 15rpx;
  background: linear-gradient(145deg, #f5f8fc, #dfe8f4);
  box-shadow: inset 0 2rpx 5rpx rgba(255,255,255,0.82), 4rpx 6rpx 10rpx rgba(142,157,181,0.16);
  opacity: 0.66;
}

.symbol-active {
  opacity: 1;
  background: linear-gradient(145deg, #eef7ff, #bcdcff);
}

.tab-bar-text {
  font-size: 20rpx;
  line-height: 1.2;
  color: var(--ink-muted);
  transition: color 180ms ease, font-weight 180ms ease;
}

.tab-bar-item-active .tab-bar-text {
  color: var(--primary);
  font-weight: 720;
}

.tab-bar-badge {
  position: absolute;
  top: -8rpx;
  right: -15rpx;
  min-width: 27rpx;
  height: 27rpx;
  padding: 0 5rpx;
  display: flex;
  align-items: center;
  justify-content: center;
  border-radius: 18rpx;
  background: linear-gradient(145deg, #ff7b83, #ef4650);
  border: 3rpx solid #fff;
  box-shadow: 0 5rpx 10rpx rgba(239,70,80,0.28);
}

.tab-bar-badge-text {
  font-size: 17rpx;
  font-weight: 700;
  color: #fff;
}
