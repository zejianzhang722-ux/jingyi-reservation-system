<view class="container">
  <view class="create-form" wx:if="{{mode === 'create'}}">
    <view class="form-card">
      <view class="form-section-title">发起团队预约</view>
      <view class="room-tip" wx:if="{{room}}">{{room.name}} · 该页面仅用于指定成员团队确认，不再作为首页独立入口</view>
      <view class="form-item"><text class="form-label">标题</text><input class="form-input" placeholder="请输入团队预约标题" value="{{form.title}}" bindinput="onTitleInput" maxlength="80" /></view>
      <view class="form-item"><text class="form-label">日期</text><picker mode="date" start="{{today}}" value="{{form.date}}" bindchange="onDateChange"><text class="form-value {{form.date ? '' : 'placeholder'}}">{{form.date || '请选择'}}</text></picker></view>
      <view class="form-item"><text class="form-label">开始时间</text><picker mode="time" value="{{form.startHour}}" bindchange="onStartHourChange"><text class="form-value {{form.startHour ? '' : 'placeholder'}}">{{form.startHour || '请选择'}}</text></picker></view>
      <view class="form-item"><text class="form-label">结束时间</text><picker mode="time" value="{{form.endHour}}" bindchange="onEndHourChange"><text class="form-value {{form.endHour ? '' : 'placeholder'}}">{{form.endHour || '请选择'}}</text></picker></view>
      <view class="form-item"><text class="form-label">团队人数</text><input class="form-input" placeholder="至少2人，不能超过容量" type="number" value="{{form.maxMembers}}" bindinput="onMaxMembersChange" /></view>
      <view class="form-item-vertical"><text class="form-label">用途说明</text><textarea class="form-textarea" placeholder="请说明团队用途、成员要求或注意事项" value="{{form.description}}" bindinput="onDescriptionInput" maxlength="200" /></view>
    </view>
    <view class="submit-btn {{submitting ? 'btn-disabled' : ''}}" bindtap="onCreateGroup">{{submitting ? '创建中...' : '创建团队预约'}}</view>
  </view>

  <view class="group-detail" wx:if="{{mode === 'detail' || mode === 'join'}}">
    <view class="group-card" wx:if="{{group}}">
      <view class="group-header">
        <view class="group-title-wrap"><text class="group-title">{{group.title}}</text><text class="group-room">{{group.roomName || room.name || '功能房'}}</text></view>
        <text class="group-status status-{{group.status}}">{{statusMap[group.status] || group.status}}</text>
      </view>
      <view class="group-info">
        <view class="group-info-row"><text class="info-label">日期</text><text class="info-value">{{group.date}}</text></view>
        <view class="group-info-row"><text class="info-label">时间</text><text class="info-value">{{group.startHour || group.start_time}} - {{group.endHour || group.end_time}}</text></view>
        <view class="group-info-row"><text class="info-label">人数</text><text class="info-value">{{members.length}}/{{group.maxMembers || group.max_members}}</text></view>
        <view class="group-info-row"><text class="info-label">待确认</text><text class="info-value">{{group.pendingCount || 0}}人</text></view>
        <view class="group-info-row"><text class="info-label">发起人</text><text class="info-value">{{group.creatorName || '宿生'}}</text></view>
        <view class="group-info-row" wx:if="{{group.reservationId || group.reservation_id}}"><text class="info-label">预约单</text><text class="info-value">已生成</text></view>
        <view class="group-info-row" wx:if="{{group.description}}"><text class="info-label">说明</text><text class="info-value">{{group.description}}</text></view>
      </view>
      <view class="members-section"><text class="members-title">成员确认状态</text><view class="member-item" wx:for="{{members}}" wx:key="id"><image class="member-avatar" src="{{item.avatarUrl || item.avatar_url || '/images/default-avatar.png'}}" mode="aspectFill"></image><text class="member-name">{{item.name || item.nickname || '成员'}}</text><text class="member-tag" wx:if="{{item.isCreator || item.is_creator}}">发起人</text><text class="member-status status-member-{{item.status}}">{{memberStatusMap[item.status] || item.statusText || '已确认'}}</text></view></view>
    </view>

    <view class="group-actions">
      <view class="action-btn btn-primary {{submitting ? 'btn-disabled' : ''}}" wx:if="{{group && group.canConfirm}}" bindtap="onConfirmJoin">{{submitting ? '确认中...' : '确认参与'}}</view>
      <view class="action-btn btn-primary {{submitting ? 'btn-disabled' : ''}}" wx:if="{{mode === 'join' && group && group.status === 'open' && !group.isJoined}}" bindtap="onJoinGroup">{{submitting ? '加入中...' : '加入组团'}}</view>
      <button class="action-btn btn-outline share-btn" wx:if="{{mode === 'detail' && group && group.status === 'open' && !(group.reservationId || group.reservation_id)}}" open-type="share">邀请成员</button>
      <view class="action-btn btn-primary {{submitting ? 'btn-disabled' : ''}}" wx:if="{{group && group.canSubmitReservation}}" bindtap="onSubmitReservation">{{submitting ? '提交中...' : '提交正式预约'}}</view>
      <view class="action-btn btn-outline" wx:if="{{group && (group.reservationId || group.reservation_id)}}" bindtap="onViewReservation">查看预约单</view>
      <view class="action-btn btn-danger {{submitting ? 'btn-disabled' : ''}}" wx:if="{{group && group.isJoined && group.status !== 'cancelled' && !(group.reservationId || group.reservation_id)}}" bindtap="onLeaveGroup">{{group.isCreator ? '取消团队预约' : '退出团队预约'}}</view>
    </view>
  </view>

  <view class="loading-state" wx:if="{{loading}}"><text class="loading-text">加载中...</text></view>
</view>