.container {
  min-height: 100vh;
  padding-bottom: calc(48rpx + env(safe-area-inset-bottom));
  background:
    radial-gradient(circle at 90% 4%, rgba(79,213,232,0.16), transparent 30%),
    radial-gradient(circle at 2% 24%, rgba(47,128,255,0.10), transparent 28%),
    linear-gradient(180deg, #f8fbff 0%, #f0f3f8 48%, #edf1f7 100%);
}

.form-card,
.group-card {
  position: relative;
  margin: 24rpx;
  padding: 28rpx;
  overflow: hidden;
  border-radius: 34rpx;
  background:
    radial-gradient(circle at 92% 0%, rgba(79,213,232,0.10), transparent 32%),
    linear-gradient(145deg, rgba(255,255,255,0.99), rgba(242,246,252,0.95));
  border: 1rpx solid rgba(255,255,255,0.94);
  box-shadow: 16rpx 18rpx 38rpx rgba(154,170,196,0.22), -10rpx -10rpx 24rpx rgba(255,255,255,0.86), inset 0 2rpx 0 rgba(255,255,255,0.92);
  box-sizing: border-box;
}

.group-card {
  padding: 0;
}

.form-section-title {
  display: block;
  margin-bottom: 18rpx;
  font-size: 31rpx;
  line-height: 1.3;
  font-weight: 850;
  color: #1f2a3d;
}

.form-item {
  display: flex;
  flex-direction: row;
  justify-content: space-between;
  align-items: center;
  min-height: 88rpx;
  padding: 16rpx 0;
  border-bottom: 1rpx solid rgba(139,154,178,0.10);
}

.form-label {
  flex-shrink: 0;
  width: 160rpx;
  font-size: 27rpx;
  color: #61708a;
  font-weight: 660;
}

.form-input {
  flex: 1;
  min-height: 62rpx;
  padding: 10rpx 18rpx;
  border-radius: 18rpx;
  text-align: right;
  font-size: 27rpx;
  color: #1f2a3d;
  background: linear-gradient(145deg, rgba(255,255,255,0.92), rgba(239,244,251,0.86));
  box-shadow: inset 5rpx 5rpx 12rpx rgba(164,178,202,0.16), inset -5rpx -5rpx 12rpx rgba(255,255,255,0.86);
  box-sizing: border-box;
}

.form-value {
  font-size: 27rpx;
  color: #1f2a3d;
  font-weight: 720;
}

.placeholder {
  color: #9aa6b8;
}

.form-item-vertical {
  padding: 18rpx 0 4rpx;
}

.form-textarea {
  width: 100%;
  height: 176rpx;
  margin-top: 14rpx;
  padding: 18rpx;
  border-radius: 22rpx;
  font-size: 27rpx;
  color: #1f2a3d;
  line-height: 1.55;
  background: linear-gradient(145deg, rgba(255,255,255,0.92), rgba(239,244,251,0.86));
  box-shadow: inset 6rpx 6rpx 14rpx rgba(164,178,202,0.16), inset -6rpx -6rpx 14rpx rgba(255,255,255,0.86);
  box-sizing: border-box;
}

.submit-btn {
  margin: 32rpx 24rpx;
  padding: 25rpx 28rpx;
  text-align: center;
  border-radius: 999rpx;
  font-size: 32rpx;
  font-weight: 850;
  color: #ffffff;
  background: linear-gradient(135deg, #2f80ff 0%, #39c6df 100%);
  box-shadow: 0 16rpx 32rpx rgba(47,128,255,0.30), inset 0 2rpx 0 rgba(255,255,255,0.36);
}

.group-header {
  display: flex;
  flex-direction: row;
  justify-content: space-between;
  align-items: center;
  gap: 18rpx;
  padding: 28rpx;
  border-bottom: 1rpx solid rgba(139,154,178,0.10);
  background: linear-gradient(145deg, rgba(255,255,255,0.58), rgba(232,242,253,0.58));
}

.group-title {
  flex: 1;
  font-size: 32rpx;
  font-weight: 860;
  color: #1f2a3d;
}

.group-status {
  flex-shrink: 0;
  font-size: 24rpx;
  color: #22a86e;
  background: #e9fbf3;
  padding: 7rpx 16rpx;
  border-radius: 999rpx;
  font-weight: 760;
}

.group-info {
  padding: 18rpx 28rpx;
}

.group-info-row {
  display: flex;
  flex-direction: row;
  justify-content: space-between;
  gap: 20rpx;
  padding: 12rpx 0;
}

.info-label {
  font-size: 26rpx;
  color: #8d9ab0;
}

.info-value {
  flex: 1;
  text-align: right;
  font-size: 26rpx;
  color: #1f2a3d;
  font-weight: 720;
}

.members-section {
  padding: 20rpx 28rpx 28rpx;
  border-top: 1rpx solid rgba(139,154,178,0.10);
}

.members-title {
  display: block;
  margin-bottom: 14rpx;
  font-size: 29rpx;
  font-weight: 850;
  color: #1f2a3d;
}

.member-item {
  display: flex;
  flex-direction: row;
  align-items: center;
  padding: 14rpx 0;
  gap: 14rpx;
}

.member-avatar {
  width: 58rpx;
  height: 58rpx;
  border-radius: 20rpx;
  box-shadow: 0 8rpx 16rpx rgba(47,128,255,0.12);
}

.member-name {
  flex: 1;
  font-size: 28rpx;
  color: #1f2a3d;
  font-weight: 700;
}

.member-tag {
  font-size: 22rpx;
  color: #2f80ff;
  background: #eaf3ff;
  padding: 6rpx 14rpx;
  border-radius: 999rpx;
  font-weight: 760;
}

.group-actions {
  display: flex;
  flex-direction: column;
  gap: 16rpx;
  padding: 0 24rpx 40rpx;
}

.action-btn,
.share-btn {
  text-align: center;
  padding: 24rpx;
  border-radius: 999rpx;
  font-size: 30rpx;
  font-weight: 800;
}

.share-btn {
  background: linear-gradient(145deg, #ffffff, #edf4fc);
  color: #2f80ff;
  line-height: normal;
  box-shadow: 10rpx 12rpx 24rpx rgba(164,178,202,0.18), -8rpx -8rpx 18rpx rgba(255,255,255,0.88), inset 0 2rpx 0 rgba(255,255,255,0.86);
}

.loading-state {
  display: flex;
  justify-content: center;
  padding: 150rpx 0;
}

.loading-text {
  font-size: 28rpx;
  color: #8d9ab0;
}
