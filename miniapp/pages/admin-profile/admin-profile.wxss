.container { padding: 0 0 150rpx; background: #f5f6fa; min-height: 100vh; box-sizing: border-box; }
.profile-header { background: linear-gradient(135deg, #0066cc, #004c99); padding: 48rpx 32rpx; display: flex; align-items: center; border-radius: 0 0 30rpx 30rpx; }
.avatar-wrap { margin-right: 24rpx; }
.avatar-icon { width: 104rpx; height: 104rpx; border-radius: 50%; background: rgba(255,255,255,0.2); color: #fff; display: flex; align-items: center; justify-content: center; font-size: 42rpx; font-weight: 800; border: 3rpx solid rgba(255,255,255,0.42); }
.profile-info { flex: 1; min-width: 0; }
.profile-name { display: block; font-size: 38rpx; font-weight: bold; color: #fff; margin-bottom: 10rpx; }
.profile-role { display: inline-block; font-size: 24rpx; color: rgba(255,255,255,0.9); background: rgba(255,255,255,0.16); padding: 6rpx 16rpx; border-radius: 14rpx; }
.notice-card { margin: -20rpx 24rpx 22rpx; background: #fff; border-radius: 16rpx; padding: 24rpx; box-shadow: 0 6rpx 18rpx rgba(12, 32, 64, 0.08); position: relative; z-index: 1; }
.notice-title { display: block; font-size: 28rpx; color: #172033; font-weight: 700; }
.notice-desc { display: block; margin-top: 8rpx; color: #7b8794; font-size: 24rpx; line-height: 1.5; }
.menu-list { margin: 0 24rpx; background: #fff; border-radius: 16rpx; overflow: hidden; box-shadow: 0 2rpx 8rpx rgba(0,0,0,0.04); }
.menu-item { display: flex; align-items: center; padding: 26rpx 28rpx; border-bottom: 1rpx solid #f0f2f5; }
.menu-item:last-child { border-bottom: none; }
.menu-item:active { background: #edf5ff; }
.menu-icon { width: 58rpx; height: 58rpx; border-radius: 16rpx; display: flex; align-items: center; justify-content: center; font-size: 24rpx; font-weight: 800; margin-right: 20rpx; flex-shrink: 0; }
.menu-icon-blue { color: #0066cc; background: #e6f1ff; }
.menu-icon-purple { color: #6648c4; background: #f0ebff; }
.menu-icon-gold { color: #9a6a00; background: #fff3cf; }
.menu-icon-cyan { color: #157b83; background: #e4f8f8; }
.menu-icon-red { color: #c33d36; background: #ffeceb; }
.admin-profile-symbol { width: 30rpx; height: 30rpx; position: relative; }
.admin-profile-symbol::before, .admin-profile-symbol::after { content: ''; position: absolute; box-sizing: border-box; }
.admin-profile-symbol-account::before { width: 12rpx; height: 12rpx; left: 9rpx; top: 1rpx; background: #0066cc; border-radius: 50%; }
.admin-profile-symbol-account::after { width: 26rpx; height: 13rpx; left: 2rpx; bottom: 2rpx; background: #0066cc; border-radius: 16rpx 16rpx 8rpx 8rpx; }
.admin-profile-symbol-network::before { width: 8rpx; height: 8rpx; left: 11rpx; top: 11rpx; background: #6648c4; border-radius: 50%; box-shadow: -10rpx -8rpx 0 #6648c4, 10rpx -8rpx 0 #6648c4, -10rpx 8rpx 0 #6648c4, 10rpx 8rpx 0 #6648c4; }
.admin-profile-symbol-network::after { width: 28rpx; height: 28rpx; left: 1rpx; top: 1rpx; border: 3rpx solid #6648c4; border-radius: 50%; opacity: 0.35; }
.admin-profile-symbol-security::before { width: 24rpx; height: 28rpx; left: 3rpx; top: 1rpx; background: #9a6a00; border-radius: 14rpx 14rpx 8rpx 8rpx; }
.admin-profile-symbol-security::after { width: 12rpx; height: 8rpx; left: 9rpx; top: 11rpx; border-left: 4rpx solid #fff; border-bottom: 4rpx solid #fff; transform: rotate(-45deg); }
.admin-profile-symbol-info::before { width: 26rpx; height: 26rpx; left: 2rpx; top: 2rpx; border: 4rpx solid #157b83; border-radius: 50%; }
.admin-profile-symbol-info::after { width: 5rpx; height: 13rpx; left: 13rpx; top: 12rpx; background: #157b83; border-radius: 4rpx; box-shadow: 0 -7rpx 0 #157b83; }
.admin-profile-symbol-logout::before { width: 20rpx; height: 20rpx; left: 2rpx; top: 5rpx; border-left: 4rpx solid #c33d36; border-top: 4rpx solid #c33d36; border-bottom: 4rpx solid #c33d36; border-radius: 6rpx 0 0 6rpx; }
.admin-profile-symbol-logout::after { width: 18rpx; height: 4rpx; right: 0; top: 13rpx; background: #c33d36; border-radius: 4rpx; }
.menu-info { flex: 1; min-width: 0; }
.menu-name { display: block; font-size: 29rpx; color: #172033; font-weight: 700; }
.menu-desc { display: block; margin-top: 6rpx; font-size: 23rpx; color: #8a94a6; }
.menu-arrow { width: 16rpx; height: 16rpx; border-top: 3rpx solid #c9d0dc; border-right: 3rpx solid #c9d0dc; transform: rotate(45deg); margin-left: 18rpx; }
