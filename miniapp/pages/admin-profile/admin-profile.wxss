@import "../../styles/theme-3d.wxss";

.container {
  min-height: 100vh;
  box-sizing: border-box;
  padding: 24rpx 24rpx 150rpx;
  background:
    radial-gradient(circle at 88% 7%, rgba(79,213,232,.14), transparent 30%),
    linear-gradient(180deg, #f8fafd 0%, var(--canvas) 100%);
}

.profile-header {
  position: relative;
  overflow: hidden;
  display: flex;
  align-items: center;
  padding: 32rpx 28rpx;
  border-radius: 40rpx;
  background:
    radial-gradient(circle at 92% 8%, rgba(79,213,232,.28), transparent 34%),
    linear-gradient(145deg, rgba(255,255,255,.98), rgba(231,240,250,.94));
  border: 1rpx solid rgba(255,255,255,.92);
  box-shadow: 18rpx 20rpx 42rpx rgba(151,165,189,.28), -12rpx -12rpx 28rpx rgba(255,255,255,.92), inset 0 2rpx 0 rgba(255,255,255,.92);
}

.avatar-wrap { margin-right: 24rpx; }

.avatar-icon {
  width: 112rpx;
  height: 112rpx;
  border-radius: 50%;
  display: flex;
  align-items: center;
  justify-content: center;
  color: #fff;
  font-size: 42rpx;
  font-weight: 850;
  background: linear-gradient(145deg, #4da5ff, #1767e8);
  border: 5rpx solid rgba(255,255,255,.65);
  box-shadow: 9rpx 11rpx 22rpx rgba(123,145,178,.22), inset 0 4rpx 8rpx rgba(255,255,255,.28);
}

.profile-info {
  flex: 1;
  min-width: 0;
}

.profile-name {
  display: block;
  margin-bottom: 10rpx;
  font-size: 38rpx;
  font-weight: 850;
  color: var(--ink);
}

.profile-role {
  display: inline-block;
  padding: 7rpx 17rpx;
  border-radius: 999rpx;
  font-size: 24rpx;
  color: var(--primary-deep);
  background: rgba(255,255,255,.72);
  border: 1rpx solid rgba(255,255,255,.86);
  box-shadow: 6rpx 8rpx 15rpx rgba(151,168,193,.18), inset 0 2rpx 0 rgba(255,255,255,.84);
}

.notice-card,
.menu-list {
  border-radius: 30rpx;
  background: linear-gradient(145deg, rgba(255,255,255,.98), rgba(246,248,252,.95));
  border: 1rpx solid rgba(255,255,255,.90);
  box-shadow: var(--shadow-soft);
}

.notice-card {
  position: relative;
  z-index: 1;
  margin: 22rpx 0;
  padding: 24rpx 26rpx;
}

.notice-title {
  display: block;
  font-size: 29rpx;
  font-weight: 800;
  color: var(--ink);
}

.notice-desc {
  display: block;
  margin-top: 8rpx;
  color: var(--ink-secondary);
  font-size: 24rpx;
  line-height: 1.5;
}

.menu-list {
  margin: 0;
  overflow: hidden;
}

.menu-item {
  display: flex;
  align-items: center;
  padding: 26rpx 28rpx;
  border-bottom: 1rpx solid rgba(139,154,178,.10);
  transition: transform 180ms ease, background 180ms ease;
}

.menu-item:last-child { border-bottom: none; }

.menu-item:active {
  transform: scale(.985);
  background: rgba(47,128,255,.05);
}

.menu-icon {
  flex-shrink: 0;
  width: 60rpx;
  height: 60rpx;
  margin-right: 20rpx;
  display: flex;
  align-items: center;
  justify-content: center;
  border-radius: 21rpx;
  font-size: 24rpx;
  font-weight: 800;
  box-shadow: inset 0 3rpx 6rpx rgba(255,255,255,.78), 6rpx 8rpx 15rpx rgba(126,144,174,.16);
}

.menu-icon-blue { color: #1767e8; background: linear-gradient(145deg, #e8f5ff, #b9dcff); }
.menu-icon-purple { color: #7654d6; background: linear-gradient(145deg, #f2ebff, #d5c2ff); }
.menu-icon-gold { color: #a86e00; background: linear-gradient(145deg, #fff4df, #ffdba0); }
.menu-icon-cyan { color: #157b83; background: linear-gradient(145deg, #e1fbfb, #a9ecec); }
.menu-icon-red { color: #d64545; background: linear-gradient(145deg, #ffe7eb, #ffb8c4); }

.admin-profile-symbol {
  width: 30rpx;
  height: 30rpx;
  position: relative;
  filter: drop-shadow(0 5rpx 5rpx rgba(45,70,110,.14));
}

.admin-profile-symbol::before,
.admin-profile-symbol::after {
  content: '';
  position: absolute;
  box-sizing: border-box;
}

.admin-profile-symbol-account::before { width: 12rpx; height: 12rpx; left: 9rpx; top: 1rpx; background: #1767e8; border-radius: 50%; }
.admin-profile-symbol-account::after { width: 26rpx; height: 13rpx; left: 2rpx; bottom: 2rpx; background: #1767e8; border-radius: 16rpx 16rpx 8rpx 8rpx; }
.admin-profile-symbol-network::before { width: 8rpx; height: 8rpx; left: 11rpx; top: 11rpx; background: #7654d6; border-radius: 50%; box-shadow: -10rpx -8rpx 0 #7654d6, 10rpx -8rpx 0 #7654d6, -10rpx 8rpx 0 #7654d6, 10rpx 8rpx 0 #7654d6; }
.admin-profile-symbol-network::after { width: 28rpx; height: 28rpx; left: 1rpx; top: 1rpx; border: 3rpx solid #7654d6; border-radius: 50%; opacity: .35; }
.admin-profile-symbol-security::before { width: 24rpx; height: 28rpx; left: 3rpx; top: 1rpx; background: #a86e00; border-radius: 14rpx 14rpx 8rpx 8rpx; }
.admin-profile-symbol-security::after { width: 12rpx; height: 8rpx; left: 9rpx; top: 11rpx; border-left: 4rpx solid #fff; border-bottom: 4rpx solid #fff; transform: rotate(-45deg); }
.admin-profile-symbol-info::before { width: 26rpx; height: 26rpx; left: 2rpx; top: 2rpx; border: 4rpx solid #157b83; border-radius: 50%; }
.admin-profile-symbol-info::after { width: 5rpx; height: 13rpx; left: 13rpx; top: 12rpx; background: #157b83; border-radius: 4rpx; box-shadow: 0 -7rpx 0 #157b83; }
.admin-profile-symbol-logout::before { width: 20rpx; height: 20rpx; left: 2rpx; top: 5rpx; border-left: 4rpx solid #d64545; border-top: 4rpx solid #d64545; border-bottom: 4rpx solid #d64545; border-radius: 6rpx 0 0 6rpx; }
.admin-profile-symbol-logout::after { width: 18rpx; height: 4rpx; right: 0; top: 13rpx; background: #d64545; border-radius: 4rpx; }

.menu-info {
  flex: 1;
  min-width: 0;
}

.menu-name {
  display: block;
  font-size: 29rpx;
  font-weight: 750;
  color: var(--ink);
}

.menu-desc {
  display: block;
  margin-top: 6rpx;
  font-size: 23rpx;
  color: var(--ink-muted);
}

.menu-arrow {
  width: 15rpx;
  height: 15rpx;
  margin-left: 18rpx;
  border-top: 3rpx solid #c3ccd8;
  border-right: 3rpx solid #c3ccd8;
  transform: rotate(45deg);
}
