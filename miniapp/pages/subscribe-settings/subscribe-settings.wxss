.container {
  min-height: 100vh;
  padding-bottom: calc(48rpx + env(safe-area-inset-bottom));
  background:
    radial-gradient(circle at 90% 4%, rgba(79,213,232,0.16), transparent 30%),
    radial-gradient(circle at 2% 24%, rgba(47,128,255,0.10), transparent 28%),
    linear-gradient(180deg, #f8fbff 0%, #f0f3f8 48%, #edf1f7 100%);
}

.subscribe-header {
  padding: 34rpx 32rpx 24rpx;
}

.subscribe-title {
  display: block;
  font-size: 40rpx;
  line-height: 1.22;
  font-weight: 880;
  color: #1f2a3d;
  letter-spacing: 0.6rpx;
}

.subscribe-desc {
  display: block;
  margin-top: 10rpx;
  font-size: 25rpx;
  line-height: 1.6;
  color: #61708a;
}

.status-card,
.template-list {
  margin: 0 24rpx 24rpx;
  padding: 28rpx;
  border-radius: 34rpx;
  background:
    radial-gradient(circle at 92% 0%, rgba(79,213,232,0.10), transparent 32%),
    linear-gradient(145deg, rgba(255,255,255,0.99), rgba(242,246,252,0.95));
  border: 1rpx solid rgba(255,255,255,0.94);
  box-shadow: 16rpx 18rpx 38rpx rgba(154,170,196,0.22), -10rpx -10rpx 24rpx rgba(255,255,255,0.86), inset 0 2rpx 0 rgba(255,255,255,0.92);
  box-sizing: border-box;
}

.status-row {
  display: flex;
  justify-content: space-between;
  align-items: center;
  gap: 20rpx;
}

.status-label {
  font-size: 31rpx;
  font-weight: 850;
  color: #1f2a3d;
}

.status-value {
  flex-shrink: 0;
  padding: 8rpx 18rpx;
  border-radius: 999rpx;
  font-size: 25rpx;
  font-weight: 800;
  box-shadow: inset 0 2rpx 0 rgba(255,255,255,0.72), 0 8rpx 16rpx rgba(117,132,161,0.10);
}

.status-ok {
  color: #22a86e;
  background: #e9fbf3;
}

.status-warn {
  color: #f59b28;
  background: #fff6e8;
}

.status-note {
  display: block;
  margin-top: 18rpx;
  padding: 20rpx 22rpx;
  border-radius: 24rpx;
  font-size: 25rpx;
  line-height: 1.6;
  color: #61708a;
  background: rgba(255,255,255,0.52);
  box-shadow: inset 5rpx 5rpx 12rpx rgba(164,178,202,0.10), inset -5rpx -5rpx 12rpx rgba(255,255,255,0.82);
}

.template-list {
  padding: 0;
  overflow: hidden;
}

.template-item {
  display: flex;
  justify-content: space-between;
  align-items: center;
  gap: 22rpx;
  padding: 27rpx 28rpx;
  border-bottom: 1rpx solid rgba(139,154,178,0.10);
}

.template-item:last-child {
  border-bottom: none;
}

.template-main {
  flex: 1;
  min-width: 0;
  padding-right: 0;
}

.template-name {
  display: block;
  font-size: 29rpx;
  line-height: 1.35;
  font-weight: 820;
  color: #1f2a3d;
  overflow: hidden;
  text-overflow: ellipsis;
  white-space: nowrap;
}

.template-desc {
  display: block;
  margin-top: 7rpx;
  font-size: 24rpx;
  line-height: 1.5;
  color: #61708a;
}

.template-badge {
  flex-shrink: 0;
  padding: 8rpx 16rpx;
  border-radius: 999rpx;
  font-size: 23rpx;
  font-weight: 800;
  box-shadow: inset 0 2rpx 0 rgba(255,255,255,0.72), 0 8rpx 16rpx rgba(117,132,161,0.10);
}

.badge-ok {
  color: #22a86e;
  background: #e9fbf3;
}

.badge-warn {
  color: #f59b28;
  background: #fff6e8;
}

.subscribe-actions {
  padding: 8rpx 24rpx 48rpx;
}

.action-btn {
  margin-top: 18rpx;
  padding: 25rpx 28rpx;
  border-radius: 999rpx;
  text-align: center;
  font-size: 30rpx;
  font-weight: 850;
  color: #ffffff;
  background: linear-gradient(135deg, #2f80ff 0%, #39c6df 100%);
  border: 1rpx solid rgba(255,255,255,0.45);
  box-shadow: 0 16rpx 32rpx rgba(47,128,255,0.30), inset 0 2rpx 0 rgba(255,255,255,0.36);
  transition: transform 160ms ease, opacity 160ms ease;
}

.action-btn:active {
  transform: translateY(3rpx) scale(0.98);
  opacity: 0.92;
}
