.profile-header {
  display: flex;
  flex-direction: row;
  align-items: center;
  background: linear-gradient(135deg, var(--primary) 0%, var(--primary-dark) 100%);
  padding: 48rpx 32rpx;
  border-radius: 0 0 32rpx 32rpx;
  position: relative;
  overflow: hidden;
}

.profile-header::after {
  content: '';
  position: absolute;
  bottom: 0;
  left: 0;
  right: 0;
  height: 4rpx;
  background: linear-gradient(90deg, transparent, var(--accent), transparent);
  opacity: 0.6;
}

.profile-avatar-wrap {
  width: 120rpx;
  height: 120rpx;
  border-radius: 50%;
  background: rgba(255, 255, 255, 0.2);
  border: 4rpx solid rgba(255, 255, 255, 0.5);
  flex-shrink: 0;
  display: flex;
  align-items: center;
  justify-content: center;
  overflow: hidden;
  position: relative;
}

.avatar-choose-button {
  padding: 0;
  margin: 0;
  line-height: 1;
}

.avatar-choose-button::after {
  border: 0;
}

.profile-avatar-icon {
  width: 64rpx;
  height: 64rpx;
  background: #FFFFFF;
  border-radius: 50%;
}

.profile-avatar-fallback {
  width: 120rpx;
  height: 120rpx;
  border-radius: 50%;
  display: flex;
  align-items: center;
  justify-content: center;
  background: linear-gradient(145deg, #E8F4FF, #B9DAFF);
  color: #0052A3;
  font-size: 46rpx;
  font-weight: 800;
}

.profile-avatar-img {
  width: 120rpx;
  height: 120rpx;
  border-radius: 50%;
}

.profile-avatar-edit {
  position: absolute;
  bottom: 0;
  right: 0;
  width: 36rpx;
  height: 36rpx;
  background: rgba(0, 0, 0, 0.5);
  border-radius: 50%;
  display: flex;
  align-items: center;
  justify-content: center;
  font-size: 18rpx;
}

.profile-avatar-edit::before,
.profile-avatar-edit::after {
  content: '';
  position: absolute;
  background: #ffffff;
  border-radius: 4rpx;
}

.profile-avatar-edit::before {
  width: 18rpx;
  height: 6rpx;
  transform: rotate(-38deg);
}

.profile-avatar-edit::after {
  width: 6rpx;
  height: 6rpx;
  right: 8rpx;
  top: 10rpx;
}

.profile-info {
  flex: 1;
  margin-left: 24rpx;
}

.profile-name {
  font-size: 36rpx;
  font-weight: 700;
  color: #FFFFFF;
  display: block;
  letter-spacing: 1rpx;
}

.profile-student-id {
  font-size: 26rpx;
  color: rgba(255, 255, 255, 0.75);
  margin-top: 8rpx;
  display: block;
}

.profile-credit {
  display: flex;
  flex-direction: column;
  align-items: center;
  background-color: rgba(255, 255, 255, 0.2);
  border-radius: 16rpx;
  padding: 16rpx 28rpx;
  position: relative;
  animation: pulseGlow 3s ease-in-out infinite;
}

.credit-score {
  font-size: 44rpx;
  font-weight: 700;
}

.credit-label {
  font-size: 22rpx;
  color: rgba(255, 255, 255, 0.8);
  margin-top: 4rpx;
}

.profile-credit-bar {
  background-color: var(--bg-card);
  padding: 24rpx 32rpx;
  margin: 16rpx 0;
  border-radius: 16rpx;
  margin-left: 24rpx;
  margin-right: 24rpx;
  box-shadow: var(--shadow);
}

.credit-bar-bg {
  height: 16rpx;
  background-color: #F0F0F0;
  border-radius: 8rpx;
  overflow: hidden;
}

.credit-bar-fill {
  height: 100%;
  border-radius: 8rpx;
  transition: width 0.3s ease;
}

.credit-bar-labels {
  display: flex;
  flex-direction: row;
  justify-content: space-between;
  margin-top: 8rpx;
}

.credit-bar-label {
  font-size: 20rpx;
}

.menu-list {
  background-color: var(--bg-card);
  margin: 0 24rpx 120rpx;
  border-radius: 16rpx;
  box-shadow: var(--shadow);
  overflow: hidden;
}

.menu-item {
  display: flex;
  flex-direction: row;
  justify-content: space-between;
  align-items: center;
  padding: 28rpx 32rpx;
  border-bottom: 1rpx solid #F5F5F5;
  transition: background-color 0.2s ease;
}

.menu-item:active {
  background-color: var(--accent-light);
}

.menu-item:last-child {
  border-bottom: none;
}

.menu-item-left {
  display: flex;
  flex-direction: row;
  align-items: center;
  gap: 20rpx;
}

.menu-icon-wrap {
  width: 54rpx;
  height: 54rpx;
  border-radius: 16rpx;
  display: flex;
  align-items: center;
  justify-content: center;
  box-shadow: inset 0 2rpx 6rpx rgba(255,255,255,0.65), 0 6rpx 14rpx rgba(0,0,0,0.06);
}

.menu-icon-blue { background: linear-gradient(145deg, #E8F4FF, #CDE7FF); }
.menu-icon-gold { background: linear-gradient(145deg, #FFF6D9, #FFE4A6); }
.menu-icon-green { background: linear-gradient(145deg, #EAF9E8, #CEF1C8); }
.menu-icon-cyan { background: linear-gradient(145deg, #E0FAFA, #BDF0F0); }
.menu-icon-purple { background: linear-gradient(145deg, #F1EAFF, #DDD0FF); }
.menu-icon-gray { background: linear-gradient(145deg, #F4F6F8, #E4E8EE); }
.menu-icon-red { background: linear-gradient(145deg, #FFE7E7, #FFC9C9); }

.menu-symbol {
  width: 30rpx;
  height: 30rpx;
  position: relative;
}

.menu-symbol::before,
.menu-symbol::after {
  content: '';
  position: absolute;
  box-sizing: border-box;
}

.menu-symbol-profile::before { width: 14rpx; height: 14rpx; left: 8rpx; top: 0; border-radius: 50%; background: #4d5a7a; }
.menu-symbol-profile::after { width: 28rpx; height: 14rpx; left: 1rpx; bottom: 0; border-radius: 16rpx 16rpx 6rpx 6rpx; background: #4d5a7a; }
.menu-symbol-star::before { width: 28rpx; height: 28rpx; left: 1rpx; top: 1rpx; background: #d79a00; clip-path: polygon(50% 0, 62% 34%, 98% 36%, 69% 56%, 79% 92%, 50% 72%, 21% 92%, 31% 56%, 2% 36%, 38% 34%); }
.menu-symbol-chart::before { width: 6rpx; height: 22rpx; left: 4rpx; bottom: 2rpx; background: #11a66a; border-radius: 4rpx; box-shadow: 10rpx -8rpx 0 #11a66a, 20rpx -14rpx 0 #11a66a; }
.menu-symbol-document::before { width: 24rpx; height: 28rpx; left: 3rpx; top: 1rpx; border: 4rpx solid #2c73d2; border-radius: 6rpx; }
.menu-symbol-document::after { width: 14rpx; height: 4rpx; left: 8rpx; top: 12rpx; background: #2c73d2; box-shadow: 0 8rpx 0 #2c73d2; }
.menu-symbol-chat::before { width: 28rpx; height: 22rpx; left: 1rpx; top: 2rpx; border: 4rpx solid #16a3a3; border-radius: 14rpx; }
.menu-symbol-chat::after { width: 8rpx; height: 8rpx; left: 7rpx; bottom: 1rpx; background: #16a3a3; transform: rotate(45deg); }
.menu-symbol-network::before { width: 8rpx; height: 8rpx; left: 11rpx; top: 11rpx; background: #7654d6; border-radius: 50%; box-shadow: -10rpx -8rpx 0 #7654d6, 10rpx -8rpx 0 #7654d6, -10rpx 8rpx 0 #7654d6, 10rpx 8rpx 0 #7654d6; }
.menu-symbol-network::after { width: 28rpx; height: 28rpx; left: 1rpx; top: 1rpx; border: 3rpx solid #7654d6; border-radius: 50%; opacity: 0.35; }
.menu-symbol-bell::before { width: 22rpx; height: 22rpx; left: 4rpx; top: 2rpx; border: 4rpx solid #d79a00; border-radius: 16rpx 16rpx 8rpx 8rpx; }
.menu-symbol-bell::after { width: 10rpx; height: 6rpx; left: 10rpx; bottom: 1rpx; background: #d79a00; border-radius: 0 0 8rpx 8rpx; }
.menu-symbol-info::before { width: 24rpx; height: 24rpx; left: 3rpx; top: 3rpx; border: 4rpx solid #697386; border-radius: 50%; }
.menu-symbol-info::after { width: 5rpx; height: 14rpx; left: 13rpx; top: 11rpx; background: #697386; border-radius: 4rpx; box-shadow: 0 -7rpx 0 #697386; }
.menu-symbol-logout::before { width: 20rpx; height: 20rpx; left: 3rpx; top: 5rpx; border-left: 4rpx solid #d64545; border-top: 4rpx solid #d64545; border-bottom: 4rpx solid #d64545; border-radius: 6rpx 0 0 6rpx; }
.menu-symbol-logout::after { width: 18rpx; height: 4rpx; right: 1rpx; top: 13rpx; background: #d64545; border-radius: 4rpx; box-shadow: 8rpx 0 0 -2rpx #d64545; }

.menu-name {
  font-size: 30rpx;
  color: #333333;
}

.menu-arrow {
  width: 16rpx;
  height: 16rpx;
  border-top: 3rpx solid #D9D9D9;
  border-right: 3rpx solid #D9D9D9;
  transform: rotate(45deg);
}
