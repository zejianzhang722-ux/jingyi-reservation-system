@import "../../styles/theme-3d.wxss";

.container {
  background:
    radial-gradient(circle at 85% 8%, rgba(79,213,232,.14), transparent 30%),
    linear-gradient(180deg, #f8fafd 0%, var(--canvas) 100%);
  padding-bottom: calc(132rpx + env(safe-area-inset-bottom));
}

.profile-header {
  position: relative;
  overflow: hidden;
  display: flex;
  align-items: center;
  margin: 22rpx 22rpx 0;
  padding: 32rpx 28rpx;
  border-radius: 40rpx;
  background:
    radial-gradient(circle at 90% 10%, rgba(79,213,232,.28), transparent 34%),
    linear-gradient(145deg, rgba(255,255,255,.98), rgba(231,240,250,.94));
  border: 1rpx solid rgba(255,255,255,.92);
  box-shadow: 18rpx 20rpx 42rpx rgba(151,165,189,.28), -12rpx -12rpx 28rpx rgba(255,255,255,.92), inset 0 2rpx 0 rgba(255,255,255,.92);
}

.profile-header::after {
  content: '';
  position: absolute;
  width: 210rpx;
  height: 210rpx;
  right: -94rpx;
  bottom: -100rpx;
  border-radius: 50%;
  background: radial-gradient(circle, rgba(47,128,255,.12), rgba(47,128,255,0));
}

.profile-avatar-wrap {
  position: relative;
  z-index: 2;
  flex-shrink: 0;
  width: 124rpx;
  height: 124rpx;
  display: flex;
  align-items: center;
  justify-content: center;
  overflow: hidden;
  border-radius: 50%;
  background: linear-gradient(145deg, #fdfefe, #d6e8f9);
  border: 5rpx solid rgba(255,255,255,.74);
  box-shadow: 9rpx 11rpx 22rpx rgba(123,145,178,.22), inset 0 4rpx 8rpx rgba(255,255,255,.80);
}

.avatar-choose-button {
  padding: 0;
  margin: 0;
  line-height: 1;
}

.avatar-choose-button::after { border: 0; }

.profile-avatar-img,
.profile-avatar-fallback {
  width: 124rpx;
  height: 124rpx;
  border-radius: 50%;
}

.profile-avatar-fallback {
  display: flex;
  align-items: center;
  justify-content: center;
  background: linear-gradient(145deg, #e8f5ff, #b9dcff);
  color: var(--primary-deep);
  font-size: 44rpx;
  font-weight: 800;
}

.profile-avatar-edit {
  position: absolute;
  right: 1rpx;
  bottom: 1rpx;
  width: 38rpx;
  height: 38rpx;
  border-radius: 50%;
  background: linear-gradient(145deg, #4da5ff, #1767e8);
  border: 3rpx solid #fff;
  box-shadow: 0 7rpx 12rpx rgba(47,128,255,.22);
}

.profile-avatar-edit::before,
.profile-avatar-edit::after {
  content: '';
  position: absolute;
  background: #fff;
  border-radius: 4rpx;
}

.profile-avatar-edit::before {
  width: 17rpx;
  height: 5rpx;
  left: 10rpx;
  top: 17rpx;
  transform: rotate(-38deg);
}

.profile-avatar-edit::after {
  width: 5rpx;
  height: 5rpx;
  right: 8rpx;
  top: 10rpx;
}

.profile-info {
  position: relative;
  z-index: 2;
  flex: 1;
  min-width: 0;
  margin-left: 24rpx;
}

.profile-name {
  display: block;
  max-width: 310rpx;
  overflow: hidden;
  text-overflow: ellipsis;
  white-space: nowrap;
  font-size: 38rpx;
  font-weight: 800;
  color: var(--ink);
  letter-spacing: .5rpx;
}

.profile-student-id {
  display: block;
  margin-top: 8rpx;
  font-size: 25rpx;
  color: var(--ink-secondary);
}

.profile-credit {
  position: relative;
  z-index: 2;
  display: flex;
  flex-direction: column;
  align-items: center;
  min-width: 96rpx;
  padding: 14rpx 18rpx;
  border-radius: 25rpx;
  background: rgba(255,255,255,.72);
  border: 1rpx solid rgba(255,255,255,.9);
  box-shadow: 8rpx 10rpx 18rpx rgba(151,168,193,.22), -6rpx -6rpx 14rpx rgba(255,255,255,.9), inset 0 2rpx 0 rgba(255,255,255,.86);
}

.credit-score {
  font-size: 43rpx;
  line-height: 1.08;
  font-weight: 850;
}

.credit-label {
  margin-top: 4rpx;
  font-size: 20rpx;
  color: var(--ink-muted);
}

.profile-credit-bar {
  margin: 22rpx 24rpx 0;
  padding: 24rpx 26rpx;
  border-radius: 30rpx;
  background: linear-gradient(145deg, rgba(255,255,255,.98), rgba(246,248,252,.95));
  border: 1rpx solid rgba(255,255,255,.9);
  box-shadow: var(--shadow-soft);
}

.credit-bar-title {
  display: flex;
  align-items: center;
  justify-content: space-between;
  margin-bottom: 14rpx;
  font-size: 26rpx;
  font-weight: 700;
  color: var(--ink);
}

.credit-bar-bg {
  height: 17rpx;
  overflow: hidden;
  border-radius: 999rpx;
  background: #e9eef5;
  box-shadow: inset 6rpx 6rpx 14rpx rgba(174,186,205,.22), inset -6rpx -6rpx 14rpx rgba(255,255,255,.86);
}

.credit-bar-fill {
  height: 100%;
  border-radius: 999rpx;
  transition: width 320ms ease;
  box-shadow: 0 0 14rpx rgba(57,191,120,.22);
}

.credit-bar-labels {
  display: flex;
  justify-content: space-between;
  margin-top: 10rpx;
}

.credit-bar-label {
  font-size: 20rpx;
  color: var(--ink-muted);
}

.menu-list {
  margin: 22rpx 24rpx 120rpx;
  overflow: hidden;
  border-radius: 30rpx;
  background: linear-gradient(145deg, rgba(255,255,255,.98), rgba(246,248,252,.95));
  border: 1rpx solid rgba(255,255,255,.9);
  box-shadow: var(--shadow-soft);
}

.menu-item {
  display: flex;
  justify-content: space-between;
  align-items: center;
  padding: 26rpx 28rpx;
  border-bottom: 1rpx solid rgba(139,154,178,.10);
  transition: transform 180ms ease, background 180ms ease;
}

.menu-item:active {
  transform: scale(.985);
  background: rgba(47,128,255,.05);
}

.menu-item:last-child { border-bottom: none; }

.menu-item-left {
  display: flex;
  align-items: center;
  gap: 20rpx;
}

.menu-icon-wrap {
  width: 58rpx;
  height: 58rpx;
  border-radius: 20rpx;
  display: flex;
  align-items: center;
  justify-content: center;
  box-shadow: inset 0 3rpx 6rpx rgba(255,255,255,.75), 6rpx 8rpx 15rpx rgba(126,144,174,.16);
}

.menu-icon-blue { background: linear-gradient(145deg, #e8f5ff, #b9dcff); }
.menu-icon-gold { background: linear-gradient(145deg, #fff4df, #ffdba0); }
.menu-icon-green { background: linear-gradient(145deg, #e5fff5, #bcefd9); }
.menu-icon-cyan { background: linear-gradient(145deg, #e1fbfb, #a9ecec); }
.menu-icon-purple { background: linear-gradient(145deg, #f2ebff, #d5c2ff); }
.menu-icon-gray { background: linear-gradient(145deg, #f5f8fc, #dfe8f4); }
.menu-icon-red { background: linear-gradient(145deg, #ffe7eb, #ffb8c4); }

.menu-symbol {
  width: 30rpx;
  height: 30rpx;
  position: relative;
  filter: drop-shadow(0 5rpx 5rpx rgba(45,70,110,.14));
}

.menu-symbol::before,
.menu-symbol::after {
  content: '';
  position: absolute;
  box-sizing: border-box;
}

.menu-symbol-profile::before { width: 14rpx; height: 14rpx; left: 8rpx; top: 0; border-radius: 50%; background: #4d5a7a; }
.menu-symbol-profile::after { width: 28rpx; height: 14rpx; left: 1rpx; bottom: 0; border-radius: 16rpx 16rpx 6rpx 6rpx; background: #4d5a7a; }
.menu-symbol-star::before { width: 28rpx; height: 28rpx; left: 1rpx; top: 1rpx; background: #d79a00; clip-path: polygon(50% 0, 62% 34%, 98% 36%, 69% 56%, 79% 92%, 50% 72%, 21% 92%, 31% 56%, 2% 36%, 38% 34%); }
.menu-symbol-chart::before { width: 6rpx; height: 22rpx; left: 4rpx; bottom: 2rpx; background: #11a66a; border-radius: 4rpx; box-shadow: 10rpx -8rpx 0 #11a66a, 20rpx -14rpx 0 #11a66a; }
.menu-symbol-document::before { width: 24rpx; height: 28rpx; left: 3rpx; top: 1rpx; border: 4rpx solid #2c73d2; border-radius: 6rpx; }
.menu-symbol-document::after { width: 14rpx; height: 4rpx; left: 8rpx; top: 12rpx; background: #2c73d2; box-shadow: 0 8rpx 0 #2c73d2; }
.menu-symbol-chat::before { width: 28rpx; height: 22rpx; left: 1rpx; top: 2rpx; border: 4rpx solid #16a3a3; border-radius: 14rpx; }
.menu-symbol-chat::after { width: 8rpx; height: 8rpx; left: 7rpx; bottom: 1rpx; background: #16a3a3; transform: rotate(45deg); }
.menu-symbol-network::before { width: 8rpx; height: 8rpx; left: 11rpx; top: 11rpx; background: #7654d6; border-radius: 50%; box-shadow: -10rpx -8rpx 0 #7654d6, 10rpx -8rpx 0 #7654d6, -10rpx 8rpx 0 #7654d6, 10rpx 8rpx 0 #7654d6; }
.menu-symbol-network::after { width: 28rpx; height: 28rpx; left: 1rpx; top: 1rpx; border: 3rpx solid #7654d6; border-radius: 50%; opacity: .35; }
.menu-symbol-bell::before { width: 22rpx; height: 22rpx; left: 4rpx; top: 2rpx; border: 4rpx solid #d79a00; border-radius: 16rpx 16rpx 8rpx 8rpx; }
.menu-symbol-bell::after { width: 10rpx; height: 6rpx; left: 10rpx; bottom: 1rpx; background: #d79a00; border-radius: 0 0 8rpx 8rpx; }
.menu-symbol-info::before { width: 24rpx; height: 24rpx; left: 3rpx; top: 3rpx; border: 4rpx solid #697386; border-radius: 50%; }
.menu-symbol-info::after { width: 5rpx; height: 14rpx; left: 13rpx; top: 11rpx; background: #697386; border-radius: 4rpx; box-shadow: 0 -7rpx 0 #697386; }
.menu-symbol-logout::before { width: 20rpx; height: 20rpx; left: 3rpx; top: 5rpx; border-left: 4rpx solid #d64545; border-top: 4rpx solid #d64545; border-bottom: 4rpx solid #d64545; border-radius: 6rpx 0 0 6rpx; }
.menu-symbol-logout::after { width: 18rpx; height: 4rpx; right: 1rpx; top: 13rpx; background: #d64545; border-radius: 4rpx; box-shadow: 8rpx 0 0 -2rpx #d64545; }

.menu-name {
  font-size: 29rpx;
  font-weight: 650;
  color: var(--ink);
}

.menu-arrow {
  width: 15rpx;
  height: 15rpx;
  border-top: 3rpx solid #c3ccd8;
  border-right: 3rpx solid #c3ccd8;
  transform: rotate(45deg);
}
