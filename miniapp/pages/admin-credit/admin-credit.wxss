.container {
  min-height: 100vh;
  padding: 24rpx 24rpx calc(120rpx + env(safe-area-inset-bottom));
  box-sizing: border-box;
  background:
    radial-gradient(circle at 90% 4%, rgba(79,213,232,0.16), transparent 30%),
    radial-gradient(circle at 2% 24%, rgba(47,128,255,0.10), transparent 28%),
    linear-gradient(180deg, #f8fbff 0%, #f0f3f8 48%, #edf1f7 100%);
}

.page-header {
  padding: 10rpx 4rpx 24rpx;
}

.title {
  display: block;
  font-size: 40rpx;
  line-height: 1.22;
  font-weight: 880;
  color: #1f2a3d;
  letter-spacing: 0.6rpx;
}

.subtitle {
  display: block;
  margin-top: 9rpx;
  font-size: 24rpx;
  line-height: 1.5;
  color: #61708a;
}

.tabs {
  display: flex;
  gap: 14rpx;
  margin-bottom: 18rpx;
}

.tab {
  flex: 1;
  text-align: center;
  color: #8d9ab0;
  border-radius: 999rpx;
  padding: 18rpx 0;
  font-size: 25rpx;
  font-weight: 760;
  background: linear-gradient(145deg, rgba(255,255,255,0.96), rgba(236,242,250,0.88));
  border: 1rpx solid rgba(255,255,255,0.88);
  box-shadow: 8rpx 10rpx 20rpx rgba(154,170,196,0.16), -6rpx -6rpx 16rpx rgba(255,255,255,0.84);
  transition: transform 160ms ease, box-shadow 160ms ease;
}

.tab:active {
  transform: scale(0.96);
  box-shadow: inset 5rpx 5rpx 12rpx rgba(164,178,202,0.18), inset -5rpx -5rpx 12rpx rgba(255,255,255,0.82);
}

.tab.active {
  color: #ffffff;
  background: linear-gradient(135deg, #2f80ff, #39c6df);
  box-shadow: 0 14rpx 26rpx rgba(47,128,255,0.23), inset 0 2rpx 0 rgba(255,255,255,0.34);
}

.action-strip {
  display: flex;
  justify-content: space-between;
  gap: 20rpx;
  align-items: center;
  margin-bottom: 20rpx;
  padding: 22rpx 24rpx;
  color: #61708a;
  border-radius: 28rpx;
  font-size: 24rpx;
  line-height: 1.5;
  background:
    radial-gradient(circle at 92% 0%, rgba(79,213,232,0.12), transparent 32%),
    linear-gradient(145deg, rgba(255,255,255,0.98), rgba(236,244,253,0.92));
  border: 1rpx solid rgba(255,255,255,0.92);
  box-shadow: 12rpx 14rpx 28rpx rgba(154,170,196,0.18), -8rpx -8rpx 18rpx rgba(255,255,255,0.84), inset 0 2rpx 0 rgba(255,255,255,0.88);
}

.link {
  flex-shrink: 0;
  padding: 9rpx 18rpx;
  border-radius: 999rpx;
  color: #2f80ff;
  font-weight: 800;
  background: #eaf3ff;
}

.list-card {
  overflow: hidden;
  border-radius: 32rpx;
  background:
    radial-gradient(circle at 92% 0%, rgba(79,213,232,0.10), transparent 32%),
    linear-gradient(145deg, rgba(255,255,255,0.99), rgba(242,246,252,0.95));
  border: 1rpx solid rgba(255,255,255,0.94);
  box-shadow: 14rpx 16rpx 34rpx rgba(154,170,196,0.22), -10rpx -10rpx 24rpx rgba(255,255,255,0.86), inset 0 2rpx 0 rgba(255,255,255,0.92);
}

.list-item,
.config-row {
  display: flex;
  justify-content: space-between;
  align-items: center;
  gap: 22rpx;
  padding: 25rpx 28rpx;
  border-bottom: 1rpx solid rgba(139,154,178,0.10);
}

.list-item:last-child,
.config-row:last-child {
  border-bottom: 0;
}

.item-main {
  flex: 1;
  min-width: 0;
}

.item-title {
  display: block;
  font-size: 30rpx;
  line-height: 1.35;
  font-weight: 820;
  color: #1f2a3d;
  overflow: hidden;
  text-overflow: ellipsis;
  white-space: nowrap;
}

.item-desc {
  display: block;
  margin-top: 8rpx;
  font-size: 24rpx;
  color: #61708a;
  line-height: 1.5;
}

.item-time {
  display: block;
  margin-top: 6rpx;
  font-size: 22rpx;
  color: #9aa6b8;
}

.score {
  flex-shrink: 0;
  min-width: 74rpx;
  padding: 9rpx 16rpx;
  border-radius: 999rpx;
  font-size: 31rpx;
  font-weight: 880;
  text-align: center;
  background: #eaf3ff;
  color: #2f80ff;
  box-shadow: inset 0 2rpx 0 rgba(255,255,255,0.72), 0 8rpx 16rpx rgba(117,132,161,0.10);
}

.danger {
  color: #ec4e58;
  background: #fff0f1;
}

.small-btn {
  flex-shrink: 0;
  padding: 11rpx 20rpx;
  border-radius: 999rpx;
  background: #e9fbf3;
  color: #22a86e;
  font-size: 24rpx;
  font-weight: 760;
  box-shadow: inset 0 2rpx 0 rgba(255,255,255,0.72), 0 8rpx 16rpx rgba(34,168,110,0.08);
}

.config-key {
  flex: 0 0 260rpx;
  font-size: 24rpx;
  color: #61708a;
  line-height: 1.5;
}

.config-value {
  flex: 1;
  text-align: right;
  font-size: 25rpx;
  font-weight: 720;
  color: #1f2a3d;
  word-break: break-all;
  line-height: 1.5;
}

.empty {
  margin-top: 70rpx;
  padding: 105rpx 0;
  text-align: center;
  color: #8d9ab0;
  font-size: 28rpx;
  border-radius: 32rpx;
  background: linear-gradient(145deg, rgba(255,255,255,0.96), rgba(242,246,252,0.90));
  border: 1rpx solid rgba(255,255,255,0.88);
  box-shadow: 12rpx 14rpx 28rpx rgba(164,178,202,0.18), -8rpx -8rpx 18rpx rgba(255,255,255,0.80);
}
