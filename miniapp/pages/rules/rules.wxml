<view class="container">
  <view class="rules-card" wx:if="{{!loading}}">
    <view class="rules-header" wx:if="{{typeName}}">
      <view class="rules-type-icon rules-type-icon-{{type || 'reading'}}"></view>
      <text class="rules-type-name">{{typeName}}管理制度</text>
    </view>
    <view class="rules-content">
      <text class="rules-text">{{rules}}</text>
    </view>
  </view>

  <view class="loading-state" wx:if="{{loading}}">
    <text class="loading-text">加载中...</text>
  </view>
</view>
