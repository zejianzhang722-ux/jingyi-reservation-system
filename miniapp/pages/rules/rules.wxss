.container {
  min-height: 100vh;
  padding: 24rpx 0 calc(48rpx + env(safe-area-inset-bottom));
  background:
    radial-gradient(circle at 90% 4%, rgba(79,213,232,0.16), transparent 30%),
    radial-gradient(circle at 2% 24%, rgba(47,128,255,0.10), transparent 28%),
    linear-gradient(180deg, #f8fbff 0%, #f0f3f8 48%, #edf1f7 100%);
}

.rules-card {
  position: relative;
  margin: 0 24rpx 24rpx;
  overflow: hidden;
  border-radius: 36rpx;
  background:
    radial-gradient(circle at 90% 0%, rgba(79,213,232,0.12), transparent 32%),
    linear-gradient(145deg, rgba(255,255,255,0.99), rgba(242,246,252,0.95));
  border: 1rpx solid rgba(255,255,255,0.94);
  box-shadow: 18rpx 20rpx 42rpx rgba(154,170,196,0.24), -10rpx -10rpx 24rpx rgba(255,255,255,0.88), inset 0 2rpx 0 rgba(255,255,255,0.92);
  animation: rulesRise 380ms cubic-bezier(.22,.74,.25,1) both;
}

.rules-card::before {
  content: '';
  position: absolute;
  right: -70rpx;
  top: -78rpx;
  width: 220rpx;
  height: 220rpx;
  border-radius: 50%;
  background: radial-gradient(circle, rgba(79,213,232,0.24), rgba(79,213,232,0));
}

.rules-header {
  position: relative;
  z-index: 1;
  display: flex;
  flex-direction: row;
  align-items: center;
  gap: 18rpx;
  padding: 30rpx 30rpx 26rpx;
  background: linear-gradient(145deg, rgba(255,255,255,0.58), rgba(232,242,253,0.58));
  border-bottom: 1rpx solid rgba(139,154,178,0.10);
}

.rules-type-icon {
  position: relative;
  flex-shrink: 0;
  width: 62rpx;
  height: 62rpx;
  border: none;
  border-radius: 22rpx;
  background: linear-gradient(145deg, #e8f5ff, #b9dcff);
  box-shadow: 9rpx 10rpx 20rpx rgba(164,178,202,0.18), -6rpx -6rpx 14rpx rgba(255,255,255,0.82), inset 0 3rpx 6rpx rgba(255,255,255,0.72);
}

.rules-type-icon::before {
  content: '';
  position: absolute;
  left: 18rpx;
  top: 15rpx;
  width: 26rpx;
  height: 32rpx;
  border: 5rpx solid #2f80ff;
  border-radius: 6rpx;
  box-sizing: border-box;
}

.rules-type-icon::after {
  content: '';
  position: absolute;
  left: 24rpx;
  top: 27rpx;
  width: 15rpx;
  height: 4rpx;
  border-radius: 4rpx;
  background: #2f80ff;
  box-shadow: 0 8rpx 0 #2f80ff;
}

.rules-type-name {
  flex: 1;
  font-size: 32rpx;
  line-height: 1.35;
  font-weight: 860;
  color: #1f2a3d;
  letter-spacing: 0.6rpx;
}

.rules-content {
  position: relative;
  z-index: 1;
  padding: 34rpx 30rpx 38rpx;
}

.rules-text {
  display: block;
  padding: 26rpx;
  border-radius: 28rpx;
  font-size: 28rpx;
  color: #61708a;
  line-height: 2;
  white-space: pre-wrap;
  background: rgba(255,255,255,0.52);
  box-shadow: inset 5rpx 5rpx 12rpx rgba(164,178,202,0.10), inset -5rpx -5rpx 12rpx rgba(255,255,255,0.82);
}

.loading-state {
  display: flex;
  justify-content: center;
  padding: 150rpx 0;
  animation: rulesRise 360ms cubic-bezier(.22,.74,.25,1) both;
}

.loading-text {
  font-size: 28rpx;
  color: #8d9ab0;
}

@keyframes rulesRise {
  from { opacity: 0; transform: translateY(24rpx) scale(0.985); }
  to { opacity: 1; transform: translateY(0) scale(1); }
}
