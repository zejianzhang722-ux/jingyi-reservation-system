.offline-tip {
  display: flex;
  flex-direction: row;
  align-items: center;
  margin: 16rpx 24rpx 0;
  padding: 16rpx 24rpx;
  background-color: var(--warning-light);
  border-radius: 12rpx;
  border: 1rpx solid #FFE58F;
  gap: 12rpx;
}

.offline-dot {
  width: 16rpx;
  height: 16rpx;
  border-radius: 50%;
  background-color: var(--warning);
  flex-shrink: 0;
}

.offline-text {
  font-size: 24rpx;
  color: #D48806;
  line-height: 1.4;
}

.room-list {
  padding: 8rpx 0;
}

.room-item {
  display: flex;
  flex-direction: row;
  background-color: var(--bg-card);
  border-radius: 16rpx;
  overflow: hidden;
  margin: 12rpx 24rpx;
  box-shadow: var(--shadow);
  transition: transform 0.2s ease, box-shadow 0.2s ease;
}

.room-item:active {
  transform: scale(0.98);
}

.room-item-status-bar {
  width: 8rpx;
  flex-shrink: 0;
  background: linear-gradient(180deg, var(--accent), var(--primary));
}

.room-item-content {
  flex: 1;
  padding: 24rpx;
}

.room-item-header {
  display: flex;
  flex-direction: row;
  align-items: center;
  margin-bottom: 16rpx;
}

.room-type-dot {
  width: 16rpx;
  height: 16rpx;
  border-radius: 50%;
  margin-right: 12rpx;
  flex-shrink: 0;
}

.room-item-info {
  flex: 1;
  display: flex;
  flex-direction: column;
}

.room-item-name {
  font-size: 30rpx;
  font-weight: 700;
  color: var(--text-primary);
  line-height: 1.3;
}

.room-item-location {
  font-size: 24rpx;
  color: var(--text-hint);
  margin-top: 4rpx;
}

.room-item-status-tag {
  font-size: 22rpx;
  padding: 4rpx 16rpx;
  border-radius: 20rpx;
  flex-shrink: 0;
  transition: transform 0.15s ease;
}

.room-item:active .room-item-status-tag {
  transform: scale(1.05);
}

.status-open {
  background-color: var(--success-light);
  color: var(--success);
}

.status-closed {
  background-color: var(--danger-light);
  color: var(--danger);
}

.room-item-details {
  display: flex;
  flex-direction: row;
  gap: 32rpx;
  margin-bottom: 12rpx;
}

.room-item-detail {
  display: flex;
  flex-direction: row;
  align-items: center;
  gap: 6rpx;
}

.detail-label {
  font-size: 22rpx;
  color: var(--text-hint);
}

.detail-value {
  font-size: 24rpx;
  font-weight: 600;
  color: #333333;
}

.room-item-facilities {
  display: flex;
  flex-direction: row;
  flex-wrap: wrap;
  gap: 8rpx;
}

.facility-tag {
  font-size: 20rpx;
  color: var(--accent);
  background-color: var(--accent-light);
  padding: 4rpx 12rpx;
  border-radius: 6rpx;
  border: 1rpx solid rgba(196, 148, 58, 0.25);
}

.room-item-audit {
  margin-top: 8rpx;
}

.audit-tag {
  font-size: 20rpx;
  color: var(--warning);
  background-color: var(--warning-light);
  padding: 4rpx 12rpx;
  border-radius: 6rpx;
  border: 1rpx solid #FFE58F;
}

.empty-state {
  display: flex;
  flex-direction: column;
  align-items: center;
  justify-content: center;
  padding: 120rpx 0;
  animation: fadeIn 0.3s ease-out both;
}

.empty-icon-svg {
  width: 120rpx;
  height: 120rpx;
  background: var(--border-color);
  border-radius: 50%;
  margin-bottom: 24rpx;
}

.empty-text {
  font-size: 28rpx;
  color: var(--text-hint);
  margin-bottom: 8rpx;
}

.empty-hint {
  font-size: 24rpx;
  color: #CCCCCC;
}

.loading-state {
  display: flex;
  flex-direction: column;
  align-items: center;
  justify-content: center;
  padding: 120rpx 0;
  animation: fadeIn 0.3s ease-out both;
}

.loading-spinner {
  width: 48rpx;
  height: 48rpx;
  border: 4rpx solid #E8E8E8;
  border-top-color: var(--primary);
  border-radius: 50%;
  animation: spin 0.8s linear infinite;
  margin-bottom: 16rpx;
}

.loading-text {
  font-size: 26rpx;
  color: var(--text-hint);
}
