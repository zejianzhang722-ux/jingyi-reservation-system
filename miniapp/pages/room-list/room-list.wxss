@import "../../styles/theme-3d.wxss";

.container {
  background:
    radial-gradient(circle at 90% 6%, rgba(79,213,232,.14), transparent 32%),
    linear-gradient(180deg, #f8fafd 0%, var(--canvas) 100%);
}

.offline-tip {
  display: flex;
  align-items: center;
  margin: 18rpx 24rpx 0;
  padding: 18rpx 24rpx;
  gap: 12rpx;
  border-radius: 26rpx;
  background: linear-gradient(145deg, #fff9ea, #fff1ce);
  border: 1rpx solid rgba(255, 216, 142, .62);
  box-shadow: var(--shadow-soft);
}

.offline-dot {
  flex-shrink: 0;
  width: 14rpx;
  height: 14rpx;
  border-radius: 50%;
  background-color: var(--warning);
  box-shadow: 0 0 0 8rpx rgba(248, 166, 60, .14);
}

.offline-text {
  font-size: 24rpx;
  color: #9b6a13;
  line-height: 1.48;
}

.room-list {
  padding: 16rpx 0 28rpx;
}

.room-item {
  position: relative;
  display: flex;
  margin: 16rpx 24rpx;
  overflow: hidden;
  border-radius: 30rpx;
  background: linear-gradient(145deg, rgba(255,255,255,.98), rgba(245,248,252,.95));
  border: 1rpx solid rgba(255,255,255,.90);
  box-shadow: 13rpx 15rpx 28rpx rgba(154,168,192,.25), -10rpx -10rpx 24rpx rgba(255,255,255,.88), inset 0 2rpx 0 rgba(255,255,255,.90);
  transition: transform 180ms ease, box-shadow 180ms ease;
}

.room-item:active {
  transform: translateY(3rpx) scale(.985);
  box-shadow: var(--shadow-pressed);
}

.room-item::after {
  content: '';
  position: absolute;
  width: 190rpx;
  height: 190rpx;
  right: -90rpx;
  top: -110rpx;
  border-radius: 50%;
  background: radial-gradient(circle, rgba(79,213,232,.18), rgba(79,213,232,0));
}

.room-item-status-bar {
  position: relative;
  z-index: 2;
  width: 9rpx;
  flex-shrink: 0;
  border-radius: 9rpx;
  margin: 0 0 0 0;
  background: linear-gradient(180deg, var(--gold), var(--primary));
  box-shadow: 5rpx 0 14rpx rgba(47,128,255,.18);
}

.room-item-content {
  position: relative;
  z-index: 2;
  flex: 1;
  padding: 26rpx 26rpx 24rpx 24rpx;
}

.room-item-header {
  display: flex;
  align-items: flex-start;
  margin-bottom: 18rpx;
}

.room-type-dot {
  flex-shrink: 0;
  width: 16rpx;
  height: 16rpx;
  margin: 14rpx 14rpx 0 0;
  border-radius: 50%;
  box-shadow: 0 0 0 8rpx rgba(47,128,255,.12), 0 5rpx 10rpx rgba(47,128,255,.28);
}

.room-item-info {
  flex: 1;
  display: flex;
  flex-direction: column;
  min-width: 0;
}

.room-item-name {
  font-size: 34rpx;
  line-height: 1.25;
  font-weight: 800;
  color: var(--ink);
  letter-spacing: .4rpx;
}

.room-item-location {
  margin-top: 4rpx;
  font-size: 24rpx;
  color: var(--ink-muted);
}

.room-item-status-tag {
  flex-shrink: 0;
  padding: 7rpx 18rpx;
  border-radius: 999rpx;
  font-size: 22rpx;
  font-weight: 700;
}

.status-open {
  color: #24a75f;
  background: linear-gradient(145deg, #f3fff7, #e1ffe9);
  box-shadow: inset 0 2rpx 0 rgba(255,255,255,.85), 0 8rpx 16rpx rgba(57,191,120,.12);
}

.status-closed {
  color: #e14a55;
  background: linear-gradient(145deg, #fff5f5, #ffe2e4);
}

.room-item-details {
  display: flex;
  flex-wrap: wrap;
  gap: 16rpx 28rpx;
  margin-bottom: 15rpx;
}

.room-item-detail {
  display: flex;
  align-items: baseline;
  gap: 7rpx;
}

.detail-label {
  font-size: 23rpx;
  color: var(--ink-muted);
}

.detail-value {
  font-size: 24rpx;
  font-weight: 760;
  color: var(--ink);
}

.room-item-facilities {
  display: flex;
  flex-wrap: wrap;
  gap: 9rpx;
}

.facility-tag,
.audit-tag {
  padding: 5rpx 14rpx;
  border-radius: 10rpx;
  font-size: 20rpx;
  font-weight: 650;
}

.facility-tag {
  color: #b77716;
  background: linear-gradient(145deg, #fff8e8, #ffedc8);
  border: 1rpx solid rgba(245,184,75,.26);
}

.room-item-audit {
  margin-top: 10rpx;
}

.audit-tag {
  color: #9b6a13;
  background: linear-gradient(145deg, #fff9ea, #fff0cf);
  border: 1rpx solid rgba(248,166,60,.28);
}

.empty-state,
.loading-state {
  padding: 120rpx 0;
}

.empty-icon-svg {
  width: 118rpx;
  height: 92rpx;
  margin-bottom: 24rpx;
  border-radius: 28rpx;
  background: linear-gradient(145deg, #fdfefe, #dce7f5);
  box-shadow: var(--shadow-soft);
}

.empty-text {
  font-size: 28rpx;
  color: var(--ink-muted);
  margin-bottom: 8rpx;
}

.empty-hint {
  font-size: 24rpx;
  color: var(--ink-muted);
}

.loading-spinner {
  border-top-color: var(--primary);
}
