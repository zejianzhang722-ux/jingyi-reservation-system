@import "../../styles/theme-3d.wxss";

.container {
  min-height: 100vh;
  padding-bottom: calc(46rpx + env(safe-area-inset-bottom));
  background:
    radial-gradient(circle at 90% 4%, rgba(79,213,232,0.16), transparent 30%),
    radial-gradient(circle at 2% 24%, rgba(47,128,255,0.10), transparent 28%),
    linear-gradient(180deg, #f8fbff 0%, #f0f3f8 48%, #edf1f7 100%);
}

.room-header {
  position: relative;
  margin: 22rpx 24rpx 0;
  padding: 28rpx 30rpx;
  overflow: hidden;
  border-radius: 34rpx;
  background:
    radial-gradient(circle at 90% 0%, rgba(79,213,232,0.14), transparent 34%),
    linear-gradient(145deg, rgba(255,255,255,0.99), rgba(242,246,252,0.95));
  border: 1rpx solid rgba(255,255,255,0.94);
  box-shadow: 16rpx 18rpx 38rpx rgba(154,170,196,0.22), -10rpx -10rpx 24rpx rgba(255,255,255,0.86), inset 0 2rpx 0 rgba(255,255,255,0.92);
}

.room-header::before {
  content: '';
  position: absolute;
  right: -68rpx;
  top: -74rpx;
  width: 220rpx;
  height: 220rpx;
  border-radius: 50%;
  background: radial-gradient(circle, rgba(79,213,232,0.24), rgba(79,213,232,0));
}

.room-header-info {
  position: relative;
  z-index: 1;
  display: flex;
  flex-direction: column;
}

.room-header-name {
  font-size: 38rpx;
  line-height: 1.25;
  font-weight: 880;
  color: #1f2a3d;
  letter-spacing: 0.6rpx;
}

.room-header-stats {
  display: flex;
  flex-direction: row;
  align-items: center;
  flex-wrap: wrap;
  gap: 12rpx;
  margin-top: 14rpx;
}

.stat-item {
  padding: 8rpx 16rpx;
  border-radius: 999rpx;
  font-size: 24rpx;
  color: #61708a;
  font-weight: 700;
  background: rgba(255,255,255,0.58);
  box-shadow: inset 0 2rpx 0 rgba(255,255,255,0.72), 0 8rpx 16rpx rgba(117,132,161,0.08);
}

.stat-free {
  color: #22a86e;
  background: #e9fbf3;
}

.stat-divider {
  display: none;
}

.timeline-section {
  padding: 20rpx 16rpx 28rpx;
}

.time-picker-mask {
  position: fixed;
  inset: 0;
  background: rgba(31,42,61,0.42);
  z-index: 100;
  backdrop-filter: blur(6px);
  -webkit-backdrop-filter: blur(6px);
}

.time-picker {
  position: fixed;
  left: 20rpx;
  right: 20rpx;
  bottom: calc(20rpx + env(safe-area-inset-bottom));
  z-index: 101;
  transform: translateY(calc(100% + 80rpx));
  transition: transform 0.28s cubic-bezier(.22,.74,.25,1);
  overflow: hidden;
  border-radius: 34rpx;
  background: linear-gradient(145deg, rgba(255,255,255,0.98), rgba(239,245,252,0.96));
  border: 1rpx solid rgba(255,255,255,0.92);
  box-shadow: 0 30rpx 70rpx rgba(31,42,61,0.30), inset 0 2rpx 0 rgba(255,255,255,0.92);
}

.time-picker-show {
  transform: translateY(0);
}

.time-picker-header {
  display: flex;
  flex-direction: row;
  justify-content: space-between;
  align-items: center;
  padding: 28rpx 32rpx 22rpx;
  border-bottom: 1rpx solid rgba(139,154,178,0.10);
}

.time-picker-title {
  font-size: 32rpx;
  font-weight: 860;
  color: #1f2a3d;
}

.time-picker-close {
  width: 48rpx;
  height: 48rpx;
  display: flex;
  align-items: center;
  justify-content: center;
  border-radius: 16rpx;
  font-size: 30rpx;
  color: #8d9ab0;
  background: linear-gradient(145deg, #ffffff, #edf4fc);
  box-shadow: 6rpx 8rpx 16rpx rgba(164,178,202,0.14), inset 0 2rpx 0 rgba(255,255,255,0.84);
}

.time-picker-body {
  padding: 20rpx 32rpx;
}

.time-picker-row {
  display: flex;
  flex-direction: row;
  justify-content: space-between;
  align-items: center;
  min-height: 86rpx;
  border-bottom: 1rpx solid rgba(139,154,178,0.10);
}

.time-picker-label {
  font-size: 28rpx;
  color: #61708a;
  font-weight: 700;
}

.time-picker-value {
  padding: 10rpx 18rpx;
  border-radius: 999rpx;
  font-size: 30rpx;
  color: #2f80ff;
  font-weight: 850;
  background: #eaf3ff;
  box-shadow: inset 0 2rpx 0 rgba(255,255,255,0.72), 0 8rpx 16rpx rgba(47,128,255,0.08);
}

.time-picker-duration {
  padding: 22rpx 0 6rpx;
  text-align: center;
}

.duration-text {
  display: inline-block;
  padding: 10rpx 18rpx;
  border-radius: 999rpx;
  font-size: 26rpx;
  color: #f59b28;
  font-weight: 800;
  background: #fff6e8;
}

.time-picker-footer {
  display: flex;
  flex-direction: row;
  padding: 22rpx 32rpx 30rpx;
  gap: 16rpx;
}

.time-picker-btn {
  flex: 1;
  text-align: center;
  padding: 22rpx;
  border-radius: 999rpx;
  font-size: 30rpx;
  font-weight: 800;
}

.btn-cancel {
  background: linear-gradient(145deg, #ffffff, #edf4fc);
  color: #61708a;
  box-shadow: 8rpx 10rpx 20rpx rgba(164,178,202,0.16), inset 0 2rpx 0 rgba(255,255,255,0.84);
}

.btn-confirm {
  background: linear-gradient(135deg, #2f80ff 0%, #39c6df 100%);
  color: #ffffff;
  box-shadow: 0 14rpx 28rpx rgba(47,128,255,0.24), inset 0 2rpx 0 rgba(255,255,255,0.34);
}

.loading-state {
  display: flex;
  justify-content: center;
  padding: 120rpx 0;
}

.loading-text {
  font-size: 28rpx;
  color: #8d9ab0;
}

.rules-modal {
  position: fixed;
  inset: 0;
  z-index: 1000;
  display: flex;
  align-items: center;
  justify-content: center;
}

.rules-modal-mask {
  position: absolute;
  inset: 0;
  background: rgba(31,42,61,0.48);
  backdrop-filter: blur(6px);
  -webkit-backdrop-filter: blur(6px);
}

.rules-modal-content {
  position: relative;
  width: 86%;
  max-height: 80vh;
  display: flex;
  flex-direction: column;
  overflow: hidden;
  border-radius: 32rpx;
  background: linear-gradient(145deg, #ffffff, #f2f6fb);
  border: 1rpx solid rgba(255,255,255,0.94);
  box-shadow: 0 34rpx 70rpx rgba(31,42,61,0.30), inset 0 2rpx 0 rgba(255,255,255,0.90);
}

.rules-modal-header {
  padding: 30rpx;
  text-align: center;
  border-bottom: 1rpx solid rgba(139,154,178,0.12);
}

.rules-modal-title {
  font-size: 34rpx;
  font-weight: 830;
  color: #1f2a3d;
}

.rules-modal-body {
  flex: 1;
  max-height: 50vh;
  padding: 30rpx;
}

.rules-text {
  display: block;
  padding: 22rpx;
  border-radius: 24rpx;
  font-size: 27rpx;
  line-height: 1.85;
  color: #61708a;
  white-space: pre-wrap;
  background: rgba(255,255,255,0.54);
  box-shadow: inset 5rpx 5rpx 12rpx rgba(164,178,202,0.10), inset -5rpx -5rpx 12rpx rgba(255,255,255,0.82);
}

.rules-modal-footer {
  padding: 20rpx 30rpx 30rpx;
  border-top: 1rpx solid rgba(139,154,178,0.12);
}

.rules-agree-row {
  display: flex;
  align-items: center;
  padding: 16rpx 0;
}

.rules-checkbox {
  flex-shrink: 0;
  width: 38rpx;
  height: 38rpx;
  margin-right: 16rpx;
  border: 2rpx solid #d8e0ec;
  border-radius: 12rpx;
  background: #ffffff;
  box-shadow: inset 0 2rpx 0 rgba(255,255,255,0.86), 5rpx 6rpx 12rpx rgba(164,178,202,0.14);
}

.rules-checkbox-checked {
  background: linear-gradient(135deg, #2f80ff, #39c6df);
  border-color: transparent;
}

.rules-checkbox-checked::after {
  content: '✓';
  color: #fff;
  font-size: 24rpx;
  display: flex;
  align-items: center;
  justify-content: center;
  height: 100%;
}

.rules-agree-text {
  font-size: 26rpx;
  color: #61708a;
}

.rules-btn-row {
  display: flex;
  gap: 20rpx;
  margin-top: 16rpx;
}

.rules-btn {
  flex: 1;
  text-align: center;
  padding: 20rpx 0;
  border-radius: 999rpx;
  font-size: 30rpx;
  font-weight: 800;
}

.rules-btn-cancel {
  background: linear-gradient(145deg, #ffffff, #edf4fc);
  color: #61708a;
}

.rules-btn-confirm {
  background: linear-gradient(135deg, #2f80ff, #39c6df);
  color: #fff;
  box-shadow: 0 12rpx 24rpx rgba(47,128,255,0.22), inset 0 2rpx 0 rgba(255,255,255,0.34);
}

.rules-btn-disabled {
  background: linear-gradient(135deg, #afc2da, #bfd0df);
  color: #fff;
  box-shadow: none;
}
