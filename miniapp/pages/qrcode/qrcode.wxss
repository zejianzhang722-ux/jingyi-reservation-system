.qrcode-page {
  display: flex;
  flex-direction: column;
  align-items: center;
  padding: 40rpx 24rpx;
}

.qrcode-card {
  width: 100%;
  background-color: #FFFFFF;
  border-radius: 16rpx;
  overflow: hidden;
  box-shadow: 0 4rpx 24rpx rgba(0, 0, 0, 0.12);
}

.qrcode-expired {
  opacity: 0.6;
}

.qrcode-header {
  display: flex;
  flex-direction: column;
  align-items: center;
  padding: 32rpx;
  background: linear-gradient(135deg, #0066CC, #1890FF);
  color: #FFFFFF;
}

.qrcode-room {
  font-size: 36rpx;
  font-weight: bold;
}

.qrcode-room-number {
  font-size: 26rpx;
  color: rgba(255, 255, 255, 0.8);
  margin-top: 4rpx;
}

.qrcode-area {
  position: relative;
  display: flex;
  justify-content: center;
  align-items: center;
  padding: 40rpx;
  min-height: 400rpx;
}

.qrcode-image {
  width: 320rpx;
  height: 320rpx;
}

.qrcode-placeholder {
  display: flex;
  flex-direction: column;
  align-items: center;
  justify-content: center;
  width: 320rpx;
  height: 320rpx;
  border: 4rpx dashed #D9D9D9;
  border-radius: 12rpx;
}

.qrcode-placeholder-icon {
  width: 72rpx;
  height: 88rpx;
  margin-bottom: 12rpx;
  border-radius: 16rpx;
  background: linear-gradient(145deg, #5441a6, #8072d6);
  position: relative;
  box-shadow: inset 0 4rpx 8rpx rgba(255,255,255,0.25), 0 8rpx 18rpx rgba(0,0,0,0.12);
}

.qrcode-placeholder-icon::before {
  content: '';
  position: absolute;
  left: 18rpx;
  top: 20rpx;
  width: 10rpx;
  height: 10rpx;
  background: #ffce4a;
  border-radius: 3rpx;
  box-shadow: 18rpx 0 0 #20c4ff, 36rpx 0 0 #ff7a59, 0 18rpx 0 #20c4ff, 18rpx 18rpx 0 #ff7a59, 36rpx 18rpx 0 #7ee27e, 0 36rpx 0 #ff7a59, 18rpx 36rpx 0 #7ee27e, 36rpx 36rpx 0 #ffce4a;
}

.qrcode-placeholder-icon::after {
  content: '';
  position: absolute;
  left: 28rpx;
  bottom: 8rpx;
  width: 16rpx;
  height: 4rpx;
  border-radius: 4rpx;
  background: rgba(255,255,255,0.8);
}

.qrcode-placeholder-text {
  font-size: 26rpx;
  color: #999999;
}

.qrcode-placeholder-id {
  font-size: 32rpx;
  font-weight: bold;
  color: #0066CC;
  margin-top: 8rpx;
  letter-spacing: 4rpx;
}

.expired-mask {
  position: absolute;
  top: 0;
  left: 0;
  right: 0;
  bottom: 0;
  background-color: rgba(255, 255, 255, 0.8);
  display: flex;
  justify-content: center;
  align-items: center;
}

.expired-text {
  font-size: 48rpx;
  font-weight: bold;
  color: #FF4D4F;
  transform: rotate(-15deg);
}

.qrcode-info {
  padding: 24rpx 32rpx;
  border-top: 1rpx solid #F0F0F0;
}

.qrcode-info-row {
  display: flex;
  flex-direction: row;
  justify-content: space-between;
  padding: 8rpx 0;
}

.info-label {
  font-size: 26rpx;
  color: #999999;
}

.info-value {
  font-size: 26rpx;
  color: #333333;
}

.qrcode-tips {
  margin-top: 32rpx;
  display: flex;
  flex-direction: column;
  align-items: center;
  gap: 8rpx;
}

.tip-text {
  font-size: 24rpx;
  color: #999999;
}

.refresh-btn {
  margin-top: 24rpx;
  padding: 16rpx 40rpx;
  background-color: #E6F0FF;
  border-radius: 40rpx;
}

.refresh-text {
  font-size: 26rpx;
  color: #0066CC;
}

.loading-state {
  display: flex;
  justify-content: center;
  padding: 120rpx 0;
}

.loading-text {
  font-size: 28rpx;
  color: #999999;
}
