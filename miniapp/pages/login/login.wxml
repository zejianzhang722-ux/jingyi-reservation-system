<view class="login-container">
  <view class="bg-animation">
    <view class="particle p1"></view>
    <view class="particle p2"></view>
    <view class="particle p3"></view>
    <view class="particle p4"></view>
    <view class="particle p5"></view>
    <view class="particle p6"></view>
  </view>

  <view class="login-content">
    <view class="brand-section">
      <view class="brand-icon">
        <text class="brand-icon-text">敬</text>
      </view>
      <text class="brand-title">敬一书院</text>
      <text class="brand-subtitle">功能房预约平台</text>
      <view class="brand-line"></view>
      <text class="brand-desc">智慧空间 · 便捷预约 · 高效管理</text>
    </view>

    <view class="login-card">
      <view class="tab-bar">
        <view class="tab-item {{loginMode === 'student' ? 'tab-active' : ''}}" bindtap="switchMode" data-mode="student">
          <text>学生登录</text>
        </view>
        <view class="tab-item {{loginMode === 'admin' ? 'tab-active' : ''}}" bindtap="switchMode" data-mode="admin">
          <text>管理员登录</text>
        </view>
        <view class="tab-indicator" style="transform: translateX({{loginMode === 'admin' ? '100%' : '0'}})"></view>
      </view>
      
      <view class="form-section" wx:if="{{loginMode === 'student'}}">
        <view class="input-group">
          <view class="input-icon input-icon-user"></view>
          <input class="form-input" type="text" placeholder="请输入学号" value="{{studentId}}" bindinput="onStudentIdInput" placeholder-style="color:#5a6a8a" />
        </view>
        <view class="input-group">
          <view class="input-icon input-icon-key"></view>
          <input class="form-input" type="text" placeholder="请输入一卡通卡号" value="{{cardNo}}" bindinput="onCardNoInput" placeholder-style="color:#5a6a8a" />
        </view>
      </view>

      <view class="form-section" wx:if="{{loginMode === 'admin'}}">
        <view class="input-group">
          <view class="input-icon input-icon-user"></view>
          <input class="form-input" type="text" placeholder="请输入管理员账号" value="{{username}}" bindinput="onUsernameInput" placeholder-style="color:#5a6a8a" />
        </view>
        <view class="input-group">
          <view class="input-icon input-icon-lock"></view>
          <input class="form-input" type="password" placeholder="请输入密码" value="{{password}}" bindinput="onPasswordInput" placeholder-style="color:#5a6a8a" />
        </view>
      </view>

      <view class="action-section">
        <button class="login-btn" bindtap="onLogin" loading="{{submitting}}" disabled="{{submitting}}">
          <text wx:if="{{!submitting}}">{{loginMode === 'student' ? '立即登录' : '管理员登录'}}</text>
          <text wx:else>验证中...</text>
        </button>
      </view>
    </view>

    <view class="footer-text">
      <text>首次使用？请前往书院前台绑定一卡通</text>
    </view>
  </view>
</view>
