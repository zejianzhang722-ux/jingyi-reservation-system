.login-container {
  min-height: 100vh;
  background: linear-gradient(135deg, #070b24 0%, #0d1538 30%, #12204e 60%, #0a1030 100%);
  position: relative;
  overflow: hidden;
}

.bg-animation {
  position: fixed;
  top: 0;
  left: 0;
  width: 100%;
  height: 100%;
  pointer-events: none;
  z-index: 0;
}

.particle {
  position: absolute;
  border-radius: 50%;
  background: rgba(0, 212, 255, 0.15);
}

.p1 {
  width: 200rpx;
  height: 200rpx;
  top: -60rpx;
  right: -40rpx;
  animation: float1 8s ease-in-out infinite;
}

.p2 {
  width: 160rpx;
  height: 160rpx;
  top: 300rpx;
  left: -50rpx;
  background: rgba(120, 80, 255, 0.12);
  animation: float2 10s ease-in-out infinite;
}

.p3 {
  width: 120rpx;
  height: 120rpx;
  bottom: 200rpx;
  right: -30rpx;
  background: rgba(0, 180, 255, 0.1);
  animation: float3 7s ease-in-out infinite;
}

.p4 {
  width: 80rpx;
  height: 80rpx;
  top: 500rpx;
  right: 80rpx;
  background: rgba(100, 200, 255, 0.08);
  animation: float1 9s ease-in-out infinite;
  animation-delay: 2s;
}

.p5 {
  width: 140rpx;
  height: 140rpx;
  top: 100rpx;
  left: 40rpx;
  background: rgba(72, 100, 255, 0.1);
  animation: float2 11s ease-in-out infinite;
  animation-delay: 3s;
}

.p6 {
  width: 60rpx;
  height: 60rpx;
  bottom: 400rpx;
  left: 100rpx;
  background: rgba(0, 212, 255, 0.12);
  animation: float3 6s ease-in-out infinite;
  animation-delay: 1s;
}

@keyframes float1 {
  0%, 100% { transform: translateY(0) translateX(0) scale(1); }
  33% { transform: translateY(-30rpx) translateX(20rpx) scale(1.05); }
  66% { transform: translateY(20rpx) translateX(-15rpx) scale(0.95); }
}

@keyframes float2 {
  0%, 100% { transform: translateY(0) translateX(0) scale(1); }
  33% { transform: translateY(25rpx) translateX(-20rpx) scale(1.08); }
  66% { transform: translateY(-15rpx) translateX(10rpx) scale(0.93); }
}

@keyframes float3 {
  0%, 100% { transform: translateY(0) translateX(0) scale(1); }
  50% { transform: translateY(-20rpx) translateX(-25rpx) scale(1.1); }
}

.login-content {
  position: relative;
  z-index: 1;
  display: flex;
  flex-direction: column;
  align-items: center;
  padding: 80rpx 40rpx 60rpx;
}

.brand-section {
  display: flex;
  flex-direction: column;
  align-items: center;
  margin-bottom: 48rpx;
}

.brand-icon {
  width: 100rpx;
  height: 100rpx;
  border-radius: 24rpx;
  background: linear-gradient(135deg, #00d4ff 0%, #0077ff 100%);
  display: flex;
  align-items: center;
  justify-content: center;
  margin-bottom: 24rpx;
  box-shadow: 0 8rpx 32rpx rgba(0, 119, 255, 0.35);
}

.brand-icon-text {
  font-size: 48rpx;
  font-weight: 700;
  color: #ffffff;
}

.brand-title {
  font-size: 44rpx;
  font-weight: 700;
  color: #ffffff;
  letter-spacing: 6rpx;
  margin-bottom: 8rpx;
}

.brand-subtitle {
  font-size: 28rpx;
  color: rgba(255, 255, 255, 0.7);
  letter-spacing: 4rpx;
  margin-bottom: 20rpx;
}

.brand-line {
  width: 80rpx;
  height: 4rpx;
  border-radius: 2rpx;
  background: linear-gradient(90deg, transparent, #00d4ff, transparent);
  margin-bottom: 20rpx;
}

.brand-desc {
  font-size: 22rpx;
  color: rgba(255, 255, 255, 0.45);
  letter-spacing: 3rpx;
}

.login-card {
  width: 100%;
  max-width: 630rpx;
  background: rgba(255, 255, 255, 0.06);
  backdrop-filter: blur(20px);
  -webkit-backdrop-filter: blur(20px);
  border-radius: 24rpx;
  border: 1rpx solid rgba(255, 255, 255, 0.12);
  padding: 40rpx 36rpx 36rpx;
  box-shadow: 0 16rpx 48rpx rgba(0, 0, 0, 0.3);
}

.tab-bar {
  display: flex;
  position: relative;
  margin-bottom: 36rpx;
  background: rgba(255, 255, 255, 0.05);
  border-radius: 12rpx;
  padding: 6rpx;
}

.tab-item {
  flex: 1;
  text-align: center;
  padding: 16rpx 0;
  font-size: 28rpx;
  color: rgba(255, 255, 255, 0.5);
  border-radius: 10rpx;
  transition: all 0.3s ease;
  position: relative;
  z-index: 1;
}

.tab-active {
  color: #ffffff;
  font-weight: 600;
}

.tab-indicator {
  position: absolute;
  top: 6rpx;
  left: 6rpx;
  width: calc(50% - 6rpx);
  height: calc(100% - 12rpx);
  background: linear-gradient(135deg, #0077ff 0%, #00d4ff 100%);
  border-radius: 10rpx;
  transition: transform 0.3s cubic-bezier(0.4, 0, 0.2, 1);
  z-index: 0;
}

.form-section {
  animation: fadeInUp 0.4s ease-out;
}

@keyframes fadeInUp {
  from { opacity: 0; transform: translateY(16rpx); }
  to { opacity: 1; transform: translateY(0); }
}

.input-group {
  display: flex;
  align-items: center;
  background: rgba(255, 255, 255, 0.08);
  border-radius: 14rpx;
  margin-bottom: 20rpx;
  padding: 6rpx 20rpx;
  border: 1rpx solid rgba(255, 255, 255, 0.08);
  transition: border-color 0.3s;
}

.input-group:focus-within {
  border-color: rgba(0, 212, 255, 0.5);
}

.input-icon {
  width: 34rpx;
  height: 34rpx;
  margin-right: 16rpx;
  flex-shrink: 0;
  position: relative;
}

.input-icon::before,
.input-icon::after {
  content: '';
  position: absolute;
  box-sizing: border-box;
}

.input-icon-user::before {
  width: 14rpx;
  height: 14rpx;
  left: 10rpx;
  top: 2rpx;
  background: rgba(0, 212, 255, 0.78);
  border-radius: 50%;
}

.input-icon-user::after {
  width: 28rpx;
  height: 15rpx;
  left: 3rpx;
  bottom: 2rpx;
  background: rgba(0, 212, 255, 0.78);
  border-radius: 16rpx 16rpx 8rpx 8rpx;
}

.input-icon-key::before {
  width: 16rpx;
  height: 16rpx;
  left: 1rpx;
  top: 5rpx;
  border: 5rpx solid rgba(0, 212, 255, 0.78);
  border-radius: 50%;
}

.input-icon-key::after {
  width: 20rpx;
  height: 5rpx;
  right: 0;
  top: 16rpx;
  background: rgba(0, 212, 255, 0.78);
  border-radius: 5rpx;
  box-shadow: 8rpx 6rpx 0 -2rpx rgba(0, 212, 255, 0.78);
}

.input-icon-lock::before {
  width: 22rpx;
  height: 18rpx;
  left: 6rpx;
  bottom: 2rpx;
  background: rgba(0, 212, 255, 0.78);
  border-radius: 6rpx;
}

.input-icon-lock::after {
  width: 18rpx;
  height: 16rpx;
  left: 8rpx;
  top: 2rpx;
  border: 4rpx solid rgba(0, 212, 255, 0.78);
  border-bottom: 0;
  border-radius: 12rpx 12rpx 0 0;
}

.form-input {
  flex: 1;
  height: 80rpx;
  font-size: 28rpx;
  color: #ffffff;
}

.action-section {
  margin-top: 12rpx;
}

.login-btn {
  width: 100%;
  height: 88rpx;
  line-height: 88rpx;
  background: linear-gradient(135deg, #0077ff 0%, #00d4ff 100%);
  border-radius: 44rpx;
  font-size: 32rpx;
  font-weight: 600;
  color: #ffffff;
  border: none;
  box-shadow: 0 8rpx 24rpx rgba(0, 119, 255, 0.4);
  transition: all 0.3s;
}

.login-btn:active {
  transform: scale(0.97);
  box-shadow: 0 4rpx 12rpx rgba(0, 119, 255, 0.3);
}

.login-btn[disabled] {
  opacity: 0.7;
  background: linear-gradient(135deg, #3a5a8a 0%, #4a7aaa 100%);
}

.test-hint {
  width: 100%;
  max-width: 630rpx;
  margin-top: 24rpx;
  padding: 20rpx 28rpx;
  background: rgba(255, 255, 255, 0.06);
  border-radius: 14rpx;
  border: 1rpx solid rgba(255, 200, 100, 0.2);
}

.hint-label {
  font-size: 22rpx;
  color: rgba(255, 200, 100, 0.8);
  font-weight: 600;
  display: block;
  margin-bottom: 6rpx;
}

.hint-text {
  font-size: 22rpx;
  color: rgba(255, 255, 255, 0.45);
  line-height: 1.6;
}

.footer-text {
  margin-top: 40rpx;
  font-size: 22rpx;
  color: rgba(255, 255, 255, 0.3);
}

.config-toggle {
  display: flex;
  align-items: center;
  justify-content: center;
  padding: 16rpx 20rpx;
  background: rgba(0, 212, 255, 0.08);
  border-radius: 12rpx;
  margin-bottom: 24rpx;
  border: 1rpx solid rgba(0, 212, 255, 0.15);
}

.toggle-icon {
  font-size: 28rpx;
  margin-right: 12rpx;
}

.config-toggle text:last-child {
  font-size: 22rpx;
  color: rgba(0, 212, 255, 0.7);
  word-break: break-all;
}

.server-config {
  background: rgba(0, 0, 0, 0.25);
  border-radius: 16rpx;
  padding: 24rpx;
  margin-bottom: 24rpx;
  border: 1rpx solid rgba(0, 212, 255, 0.15);
}

.config-title {
  display: flex;
  align-items: center;
  margin-bottom: 20rpx;
}

.config-icon {
  font-size: 32rpx;
  margin-right: 12rpx;
}

.config-title text:last-child {
  font-size: 26rpx;
  font-weight: 600;
  color: #ffffff;
}

.server-options {
  margin-bottom: 20rpx;
}

.server-option {
  display: flex;
  align-items: center;
  justify-content: space-between;
  padding: 16rpx 20rpx;
  background: rgba(255, 255, 255, 0.05);
  border-radius: 10rpx;
  margin-bottom: 12rpx;
  border: 1rpx solid transparent;
  transition: all 0.2s;
}

.server-option.active {
  background: rgba(0, 212, 255, 0.12);
  border-color: rgba(0, 212, 255, 0.4);
}

.server-text {
  flex: 1;
  font-size: 22rpx;
  color: rgba(255, 255, 255, 0.7);
  word-break: break-all;
}

.server-option.active .server-text {
  color: #00d4ff;
  font-weight: 500;
}

.server-check {
  font-size: 28rpx;
  color: #00d4ff;
  flex-shrink: 0;
  margin-left: 12rpx;
}

.custom-server {
  display: flex;
  align-items: center;
  gap: 12rpx;
  margin-bottom: 20rpx;
}

.custom-input {
  flex: 1;
  height: 72rpx;
  padding: 0 20rpx;
  background: rgba(255, 255, 255, 0.08);
  border-radius: 10rpx;
  font-size: 24rpx;
  color: #ffffff;
  border: 1rpx solid rgba(255, 255, 255, 0.1);
}

.custom-btn {
  flex-shrink: 0;
  background: linear-gradient(135deg, #0077ff 0%, #00d4ff 100%);
  color: #ffffff;
  border: none;
  font-size: 24rpx;
  border-radius: 10rpx;
}

.close-config {
  width: 100%;
  height: 64rpx;
  line-height: 64rpx;
  background: rgba(255, 255, 255, 0.08);
  color: rgba(255, 255, 255, 0.6);
  border: 1rpx solid rgba(255, 255, 255, 0.1);
  border-radius: 12rpx;
  font-size: 26rpx;
}
