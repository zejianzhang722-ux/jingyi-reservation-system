@import "../../styles/theme-3d.wxss";

.login-container {
  min-height: 100vh;
  position: relative;
  overflow: hidden;
  background:
    radial-gradient(circle at 78% 7%, rgba(79,213,232,.24), transparent 28%),
    radial-gradient(circle at 7% 34%, rgba(47,128,255,.13), transparent 31%),
    linear-gradient(180deg, #f9fbfe 0%, #eef2f7 100%);
}

.bg-animation {
  position: fixed;
  inset: 0;
  pointer-events: none;
  z-index: 0;
}

.particle {
  position: absolute;
  border-radius: 50%;
  filter: blur(2rpx);
  opacity: .8;
}

.p1 {
  width: 260rpx;
  height: 260rpx;
  top: -100rpx;
  right: -90rpx;
  background: radial-gradient(circle, rgba(79,213,232,.22), rgba(79,213,232,0));
  animation: floatOne 8s ease-in-out infinite;
}

.p2 {
  width: 200rpx;
  height: 200rpx;
  top: 360rpx;
  left: -95rpx;
  background: radial-gradient(circle, rgba(47,128,255,.17), rgba(47,128,255,0));
  animation: floatTwo 10s ease-in-out infinite;
}

.p3 {
  width: 160rpx;
  height: 160rpx;
  bottom: 160rpx;
  right: -55rpx;
  background: radial-gradient(circle, rgba(111,192,255,.17), rgba(111,192,255,0));
  animation: floatThree 7s ease-in-out infinite;
}

.p4,
.p5,
.p6 {
  width: 18rpx;
  height: 18rpx;
  background: linear-gradient(145deg, rgba(255,255,255,.95), rgba(79,213,232,.65));
  box-shadow: 0 0 22rpx rgba(79,213,232,.32);
  animation: sparkle 3.6s ease-in-out infinite;
}

.p4 { top: 265rpx; right: 90rpx; }
.p5 { top: 470rpx; left: 84rpx; animation-delay: 1.1s; }
.p6 { bottom: 310rpx; right: 128rpx; animation-delay: 2s; }

@keyframes floatOne {
  0%, 100% { transform: translate3d(0,0,0) scale(1); }
  50% { transform: translate3d(-22rpx,28rpx,0) scale(1.06); }
}

@keyframes floatTwo {
  0%, 100% { transform: translate3d(0,0,0); }
  50% { transform: translate3d(26rpx,-20rpx,0); }
}

@keyframes floatThree {
  0%, 100% { transform: translate3d(0,0,0); }
  50% { transform: translate3d(-18rpx,-30rpx,0); }
}

@keyframes sparkle {
  0%, 100% { opacity: .30; transform: scale(.7); }
  50% { opacity: 1; transform: scale(1.25); }
}

.login-content {
  position: relative;
  z-index: 1;
  display: flex;
  flex-direction: column;
  align-items: center;
  padding: 72rpx 38rpx calc(50rpx + env(safe-area-inset-bottom));
}

.brand-section {
  display: flex;
  flex-direction: column;
  align-items: center;
  margin-bottom: 38rpx;
  animation: uiRise 420ms cubic-bezier(.22,.74,.25,1) both;
}

.brand-icon {
  position: relative;
  width: 118rpx;
  height: 118rpx;
  margin-bottom: 24rpx;
  display: flex;
  align-items: center;
  justify-content: center;
  border-radius: 38rpx;
  background: linear-gradient(145deg, #fdfefe 0%, #cce6ff 56%, #8eddf1 100%);
  border: 1rpx solid rgba(255,255,255,.92);
  box-shadow: 18rpx 20rpx 35rpx rgba(99,128,170,.25), -14rpx -14rpx 30rpx rgba(255,255,255,.94), inset 0 5rpx 9rpx rgba(255,255,255,.78);
  animation: uiFloat 4.8s ease-in-out infinite;
}

.brand-icon::before {
  content: '';
  position: absolute;
  width: 68rpx;
  height: 15rpx;
  left: 16rpx;
  top: 13rpx;
  border-radius: 50%;
  transform: rotate(-20deg);
  background: rgba(255,255,255,.55);
}

.brand-icon::after {
  content: '';
  position: absolute;
  width: 78rpx;
  height: 26rpx;
  left: 20rpx;
  bottom: -16rpx;
  border-radius: 50%;
  background: rgba(47,128,255,.18);
  filter: blur(10rpx);
}

.brand-icon-text {
  position: relative;
  z-index: 2;
  font-size: 54rpx;
  font-weight: 800;
  color: #fff;
  text-shadow: 0 7rpx 12rpx rgba(28,92,178,.30);
}

.brand-title {
  font-size: 46rpx;
  line-height: 1.2;
  font-weight: 800;
  letter-spacing: 6rpx;
  color: var(--ink);
}

.brand-subtitle {
  margin-top: 8rpx;
  font-size: 27rpx;
  font-weight: 650;
  letter-spacing: 3rpx;
  color: var(--ink-secondary);
}

.brand-line {
  width: 86rpx;
  height: 5rpx;
  margin: 18rpx 0 15rpx;
  border-radius: 5rpx;
  background: linear-gradient(90deg, transparent, var(--cyan), var(--primary), transparent);
  box-shadow: 0 5rpx 12rpx rgba(47,128,255,.20);
}

.brand-desc {
  font-size: 21rpx;
  letter-spacing: 2rpx;
  color: var(--ink-muted);
}

.login-card {
  width: 100%;
  max-width: 640rpx;
  box-sizing: border-box;
  padding: 24rpx 28rpx 30rpx;
  border-radius: 38rpx;
  background: linear-gradient(145deg, rgba(255,255,255,.96), rgba(240,245,251,.93));
  border: 1rpx solid rgba(255,255,255,.92);
  box-shadow: 18rpx 22rpx 42rpx rgba(154,168,192,.28), -14rpx -14rpx 30rpx rgba(255,255,255,.92), inset 0 2rpx 0 rgba(255,255,255,.92);
  animation: uiRise 480ms 80ms cubic-bezier(.22,.74,.25,1) both;
}

.tab-bar {
  position: relative;
  display: flex;
  margin-bottom: 28rpx;
  padding: 6rpx;
  overflow: hidden;
  border-radius: 24rpx;
  background: #e9eef5;
  box-shadow: inset 7rpx 7rpx 15rpx rgba(171,183,202,.23), inset -7rpx -7rpx 15rpx rgba(255,255,255,.86);
}

.tab-item {
  position: relative;
  z-index: 2;
  flex: 1;
  padding: 16rpx 0;
  text-align: center;
  font-size: 27rpx;
  font-weight: 620;
  color: var(--ink-muted);
  transition: color 220ms ease;
}

.tab-active {
  color: #fff;
  text-shadow: 0 3rpx 7rpx rgba(28,92,178,.20);
}

.tab-indicator {
  position: absolute;
  z-index: 1;
  left: 6rpx;
  top: 6rpx;
  width: calc(50% - 6rpx);
  height: calc(100% - 12rpx);
  border-radius: 19rpx;
  background: linear-gradient(135deg, #2478ff, #44cce4);
  border: 1rpx solid rgba(255,255,255,.36);
  box-shadow: 0 10rpx 20rpx rgba(47,128,255,.24), inset 0 2rpx 0 rgba(255,255,255,.40);
  transition: transform 280ms cubic-bezier(.22,.74,.25,1);
}

.form-section {
  animation: formRise 320ms ease-out both;
}

@keyframes formRise {
  from { opacity: 0; transform: translateY(12rpx); }
  to { opacity: 1; transform: translateY(0); }
}

.input-group {
  display: flex;
  align-items: center;
  min-height: 88rpx;
  margin-bottom: 18rpx;
  padding: 0 20rpx;
  border-radius: 24rpx;
  background: #edf1f6;
  border: 1rpx solid rgba(255,255,255,.78);
  box-shadow: inset 7rpx 7rpx 16rpx rgba(174,186,205,.22), inset -7rpx -7rpx 16rpx rgba(255,255,255,.90);
  transition: box-shadow 180ms ease, border-color 180ms ease;
}

.input-group:focus-within {
  border-color: rgba(47,128,255,.30);
  box-shadow: inset 6rpx 6rpx 14rpx rgba(174,186,205,.19), inset -6rpx -6rpx 14rpx rgba(255,255,255,.92), 0 0 0 7rpx rgba(47,128,255,.07);
}

.input-icon {
  position: relative;
  flex-shrink: 0;
  width: 52rpx;
  height: 52rpx;
  margin-right: 14rpx;
  border-radius: 18rpx;
  background: linear-gradient(145deg, #faffff, #d8e9f8);
  box-shadow: 5rpx 6rpx 12rpx rgba(157,174,198,.22), -4rpx -4rpx 10rpx rgba(255,255,255,.88), inset 0 3rpx 5rpx rgba(255,255,255,.78);
}

.input-icon::before,
.input-icon::after {
  content: '';
  position: absolute;
  box-sizing: border-box;
}

.input-icon-user::before {
  width: 15rpx;
  height: 15rpx;
  left: 19rpx;
  top: 10rpx;
  border-radius: 50%;
  background: linear-gradient(145deg, #50cde2, #2478ff);
}

.input-icon-user::after {
  width: 28rpx;
  height: 14rpx;
  left: 12rpx;
  bottom: 9rpx;
  border-radius: 16rpx 16rpx 7rpx 7rpx;
  background: linear-gradient(145deg, #50cde2, #2478ff);
}

.input-icon-key::before {
  width: 17rpx;
  height: 17rpx;
  left: 8rpx;
  top: 12rpx;
  border: 5rpx solid #2f80ff;
  border-radius: 50%;
}

.input-icon-key::after {
  width: 23rpx;
  height: 5rpx;
  right: 7rpx;
  top: 24rpx;
  border-radius: 5rpx;
  background: #2f80ff;
  box-shadow: 8rpx 7rpx 0 -2rpx #2f80ff;
}

.input-icon-lock::before {
  width: 26rpx;
  height: 21rpx;
  left: 13rpx;
  bottom: 8rpx;
  border-radius: 7rpx;
  background: linear-gradient(145deg, #50cde2, #2478ff);
}

.input-icon-lock::after {
  width: 20rpx;
  height: 18rpx;
  left: 16rpx;
  top: 8rpx;
  border: 4rpx solid #2f80ff;
  border-bottom: 0;
  border-radius: 13rpx 13rpx 0 0;
}

.form-input {
  flex: 1;
  height: 82rpx;
  font-size: 27rpx;
  color: var(--ink);
}

.action-section {
  margin-top: 12rpx;
}

.login-btn {
  width: 100%;
  height: 92rpx;
  line-height: 92rpx;
  border: 1rpx solid rgba(255,255,255,.34);
  border-radius: 999rpx;
  color: #fff;
  font-size: 31rpx;
  font-weight: 700;
  letter-spacing: 1rpx;
  background: linear-gradient(135deg, #2478ff 0%, #38c4e2 100%);
  box-shadow: 0 18rpx 30rpx rgba(47,128,255,.27), inset 0 3rpx 0 rgba(255,255,255,.34);
  transition: transform 180ms ease, box-shadow 180ms ease, filter 180ms ease;
}

.login-btn:active {
  transform: translateY(3rpx) scale(.975);
  filter: brightness(.96);
  box-shadow: 0 8rpx 18rpx rgba(47,128,255,.20), inset 0 4rpx 9rpx rgba(18,80,164,.18);
}

.login-btn[disabled] {
  opacity: .64;
  background: linear-gradient(135deg, #8ba5c5, #9bbfca);
  box-shadow: 0 10rpx 20rpx rgba(86,107,139,.16);
}

.footer-text {
  margin-top: 34rpx;
  padding: 13rpx 20rpx;
  border-radius: 999rpx;
  font-size: 21rpx;
  color: var(--ink-muted);
  background: rgba(255,255,255,.42);
  border: 1rpx solid rgba(255,255,255,.66);
}

.test-hint,
.config-toggle,
.config-panel {
  display: none !important;
}
