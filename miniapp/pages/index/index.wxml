<view class="container page-fade-in">
  <view class="header">
    <view class="header-top">
      <view class="header-brand">
        <text class="header-logo">敬一书院</text>
        <text class="header-title">功能房预约</text>
      </view>
      <view class="header-user" bindtap="onAvatarTap">
        <view class="header-avatar-wrap">
          <view class="header-avatar-icon"></view>
        </view>
        <view class="header-user-info">
          <text class="header-name">{{userInfo.name || userInfo.real_name || '未登录'}}</text>
          <text class="header-credit" style="color:{{creditColorValue}}">信用分 {{creditScore}}</text>
        </view>
      </view>
    </view>

    <view class="search-bar glass-effect" bindtap="onSearchTap">
      <view class="search-icon-wrap">
        <view class="search-icon-svg"></view>
      </view>
      <text class="search-placeholder" wx:if="{{!searchKeyword}}">搜索房号或功能房名称</text>
      <text class="search-keyword" wx:else>{{searchKeyword}}</text>
    </view>
  </view>

  <view class="offline-tip" wx:if="{{isOffline}}">
    <view class="offline-dot"></view>
    <text class="offline-text">当前显示本地数据，连接服务器后会自动刷新。</text>
  </view>

  <view class="announcement-bar" wx:if="{{announcementText}}">
    <text class="announcement-icon">告</text>
    <view class="announcement-scroll">
      <text class="announcement-text">{{announcementText}}</text>
    </view>
  </view>

  <view class="quick-panel">
    <view class="quick-item" bindtap="onSearchTap">
      <text class="quick-num">{{categories.length}}</text>
      <text class="quick-label">空间分类</text>
    </view>
    <view class="quick-item">
      <text class="quick-num">{{creditScore}}</text>
      <text class="quick-label">当前信用</text>
    </view>
    <view class="quick-item" bindtap="onAvatarTap">
      <text class="quick-num">我的</text>
      <text class="quick-label">预约与设置</text>
    </view>
  </view>

  <view class="section-title">可预约空间</view>

  <view class="category-grid" wx:if="{{!loading}}">
    <view class="category-item {{currentCategory === item.key ? 'category-item-active' : ''}}"
          wx:for="{{categories}}" wx:key="key"
          data-key="{{item.key}}" bindtap="onCategoryTap">
      <view class="category-icon-wrap category-icon-{{item.key}}">
        <view class="category-symbol category-symbol-{{item.iconKey || item.key}}"></view>
        <view class="category-badge" wx:if="{{item.freeCount > 0}}">
          <text class="category-badge-text">{{item.freeCount}}</text>
        </view>
      </view>
      <text class="category-name">{{item.name}}</text>
      <text class="category-count">{{item.count}} 间</text>
    </view>
  </view>

  <view class="empty-category" wx:if="{{!loading && categories.length === 0}}">
    <view class="empty-icon-svg"></view>
    <text class="empty-text">暂无功能房分类</text>
    <text class="empty-hint">请检查网络连接后下拉重试</text>
  </view>

  <view class="loading-state" wx:if="{{loading}}">
    <view class="loading-spinner"></view>
    <text class="loading-text">正在加载...</text>
  </view>
</view>
