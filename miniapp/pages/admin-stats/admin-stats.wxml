<view class="container">
  <view class="page-header">
    <view>
      <text class="title">数据统计</text>
      <text class="subtitle">预约、使用、爽约和信用状态概览</text>
    </view>
    <view class="export-btn {{exporting ? 'exporting' : ''}}" bindtap="onExport">{{exporting ? '导出中' : '按筛选导出'}}</view>
  </view>

  <view class="filter-card">
    <view class="filter-row">
      <picker mode="date" value="{{filters.startDate}}" end="{{filters.endDate}}" bindchange="onStartDateChange"><view class="filter-pill"><text class="filter-label">开始</text><text>{{filters.startDate}}</text></view></picker>
      <picker mode="date" value="{{filters.endDate}}" start="{{filters.startDate}}" bindchange="onEndDateChange"><view class="filter-pill"><text class="filter-label">结束</text><text>{{filters.endDate}}</text></view></picker>
    </view>
    <view class="filter-row">
      <picker mode="selector" range="{{exportTypeOptions}}" range-key="label" value="{{exportTypeIndex}}" bindchange="onExportTypeChange"><view class="filter-pill"><text class="filter-label">导出</text><text>{{exportTypeOptions[exportTypeIndex].label}}</text></view></picker>
      <picker mode="selector" range="{{statusOptions}}" range-key="label" value="{{statusIndex}}" bindchange="onStatusChange" wx:if="{{filters.exportType === 'reservations'}}"><view class="filter-pill"><text class="filter-label">状态</text><text>{{statusOptions[statusIndex].label}}</text></view></picker>
      <view class="filter-reset" bindtap="onResetFilters">重置</view>
    </view>
  </view>

  <view class="stats-grid">
    <view class="stat-card"><text class="stat-value">{{dashboard.todayReservations}}</text><text class="stat-label">今日预约</text></view>
    <view class="stat-card"><text class="stat-value">{{dashboard.pendingCount}}</text><text class="stat-label">待审核</text></view>
    <view class="stat-card"><text class="stat-value">{{dashboard.usingCount}}</text><text class="stat-label">使用中</text></view>
    <view class="stat-card warning"><text class="stat-value">{{dashboard.noshowCount}}</text><text class="stat-label">今日爽约</text></view>
  </view>

  <view class="section">
    <view class="section-head"><text class="section-title">筛选期内使用排行</text><text class="refresh" bindtap="onRefresh">刷新</text></view>
    <view wx:if="{{usageRows.length > 0}}">
      <view class="rank-row" wx:for="{{usageRows}}" wx:key="room_name"><view class="rank-info"><text class="rank-name">{{item.room_name}}</text><text class="rank-meta">{{item.reservation_count}} 次预约 · {{item.used_days}} 天使用</text></view><text class="rank-rate">{{item.displayRate}}</text></view>
    </view>
    <view class="empty" wx:else>暂无使用排行</view>
  </view>

  <view class="section">
    <text class="section-title">爽约概览</text>
    <view class="summary-line"><text>筛选期内爽约总数</text><text class="summary-value danger">{{noshow.totalNoshow}}</text></view>
    <view class="simple-row" wx:for="{{noshow.topNoshowUsers}}" wx:key="id"><text>{{item.real_name || item.nickname || item.student_id}}</text><text>{{item.noshow_count}} 次</text></view>
    <view class="empty" wx:if="{{noshow.topNoshowUsers.length === 0}}">暂无爽约数据</view>
  </view>

  <view class="section">
    <text class="section-title">信用分布</text>
    <view class="simple-row" wx:for="{{creditDistribution}}" wx:key="level"><text>{{item.level === 'good' ? '良好' : item.level === 'warning' ? '需注意' : item.level === 'restricted' ? '受限' : '封禁'}}</text><text>{{item.count}} 人</text></view>
    <view class="empty" wx:if="{{creditDistribution.length === 0}}">暂无信用分布数据</view>
  </view>
</view>