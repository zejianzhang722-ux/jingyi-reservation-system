.container {
  min-height: 100vh;
  padding: 24rpx 24rpx calc(120rpx + env(safe-area-inset-bottom));
  box-sizing: border-box;
  background:
    radial-gradient(circle at 90% 4%, rgba(79,213,232,0.16), transparent 30%),
    radial-gradient(circle at 2% 24%, rgba(47,128,255,0.10), transparent 28%),
    linear-gradient(180deg, #f8fbff 0%, #f0f3f8 48%, #edf1f7 100%);
}

.page-header {
  position: relative;
  padding: 14rpx 4rpx 28rpx;
}

.title {
  display: block;
  font-size: 40rpx;
  line-height: 1.22;
  font-weight: 880;
  color: #1f2a3d;
  letter-spacing: 0.6rpx;
}

.subtitle {
  display: block;
  margin-top: 9rpx;
  font-size: 24rpx;
  line-height: 1.5;
  color: #61708a;
}

.stats-grid {
  display: grid;
  grid-template-columns: 1fr 1fr;
  gap: 18rpx;
  margin-bottom: 26rpx;
}

.stat-card {
  position: relative;
  min-height: 154rpx;
  padding: 28rpx;
  overflow: hidden;
  border-radius: 30rpx;
  background:
    radial-gradient(circle at 90% 0%, rgba(79,213,232,0.13), transparent 34%),
    linear-gradient(145deg, rgba(255,255,255,0.99), rgba(242,246,252,0.95));
  border: 1rpx solid rgba(255,255,255,0.94);
  box-shadow: 13rpx 15rpx 30rpx rgba(154,170,196,0.20), -9rpx -9rpx 22rpx rgba(255,255,255,0.86), inset 0 2rpx 0 rgba(255,255,255,0.92);
  box-sizing: border-box;
}

.stat-card::after {
  content: '';
  position: absolute;
  right: 22rpx;
  top: 24rpx;
  width: 42rpx;
  height: 42rpx;
  border-radius: 16rpx;
  background: linear-gradient(145deg, #e8f5ff, #b9dcff);
  box-shadow: inset 0 3rpx 6rpx rgba(255,255,255,0.76), 0 8rpx 16rpx rgba(47,128,255,0.12);
}

.stat-card.warning::after {
  background: linear-gradient(145deg, #ffe7eb, #ffb8c4);
}

.stat-value {
  position: relative;
  z-index: 1;
  display: block;
  font-size: 52rpx;
  line-height: 1.1;
  font-weight: 900;
  color: #2f80ff;
  text-shadow: 0 7rpx 14rpx rgba(47,128,255,0.12);
}

.stat-card.warning .stat-value {
  color: #ec4e58;
  text-shadow: 0 7rpx 14rpx rgba(236,78,88,0.10);
}

.stat-label {
  position: relative;
  z-index: 1;
  display: block;
  margin-top: 9rpx;
  font-size: 24rpx;
  color: #61708a;
}

.section {
  position: relative;
  margin-bottom: 24rpx;
  padding: 26rpx 28rpx;
  overflow: hidden;
  border-radius: 32rpx;
  background:
    radial-gradient(circle at 92% 0%, rgba(79,213,232,0.10), transparent 32%),
    linear-gradient(145deg, rgba(255,255,255,0.99), rgba(242,246,252,0.95));
  border: 1rpx solid rgba(255,255,255,0.94);
  box-shadow: 14rpx 16rpx 34rpx rgba(154,170,196,0.20), -9rpx -9rpx 22rpx rgba(255,255,255,0.84), inset 0 2rpx 0 rgba(255,255,255,0.92);
  box-sizing: border-box;
}

.section-head {
  display: flex;
  justify-content: space-between;
  align-items: center;
  gap: 20rpx;
  margin-bottom: 10rpx;
}

.section-title {
  display: block;
  font-size: 31rpx;
  line-height: 1.3;
  font-weight: 850;
  color: #1f2a3d;
}

.refresh {
  flex-shrink: 0;
  padding: 9rpx 18rpx;
  border-radius: 999rpx;
  font-size: 24rpx;
  font-weight: 760;
  color: #2f80ff;
  background: linear-gradient(145deg, #ffffff, #eaf3ff);
  border: 1rpx solid rgba(255,255,255,0.86);
  box-shadow: 6rpx 8rpx 16rpx rgba(164,178,202,0.14), inset 0 2rpx 0 rgba(255,255,255,0.84);
}

.rank-row,
.simple-row,
.summary-line {
  display: flex;
  justify-content: space-between;
  align-items: center;
  gap: 24rpx;
  padding: 22rpx 0;
  border-bottom: 1rpx solid rgba(139,154,178,0.10);
}

.rank-row:last-child,
.simple-row:last-child,
.summary-line:last-child {
  border-bottom: 0;
}

.rank-info {
  flex: 1;
  min-width: 0;
}

.rank-name {
  display: block;
  font-size: 28rpx;
  line-height: 1.35;
  color: #1f2a3d;
  font-weight: 780;
  overflow: hidden;
  text-overflow: ellipsis;
  white-space: nowrap;
}

.rank-meta {
  display: block;
  margin-top: 7rpx;
  font-size: 22rpx;
  color: #8d9ab0;
}

.rank-rate,
.summary-value {
  flex-shrink: 0;
  min-width: 80rpx;
  padding: 8rpx 16rpx;
  border-radius: 999rpx;
  color: #2f80ff;
  background: #eaf3ff;
  font-size: 28rpx;
  font-weight: 850;
  text-align: center;
  box-shadow: inset 0 2rpx 0 rgba(255,255,255,0.72), 0 8rpx 16rpx rgba(47,128,255,0.08);
}

.summary-line text:first-child,
.simple-row text:first-child {
  flex: 1;
  font-size: 26rpx;
  color: #61708a;
  overflow: hidden;
  text-overflow: ellipsis;
  white-space: nowrap;
}

.simple-row text:last-child {
  flex-shrink: 0;
  font-size: 27rpx;
  font-weight: 780;
  color: #1f2a3d;
}

.danger {
  color: #ec4e58 !important;
  background: #fff0f1;
}

.empty {
  padding: 44rpx 0;
  text-align: center;
  color: #8d9ab0;
  font-size: 26rpx;
}
