.container { min-height: 100vh; background: #f5f7fa; padding: 24rpx; box-sizing: border-box; }
.page-header { padding: 8rpx 4rpx 24rpx; }
.title { display: block; font-size: 38rpx; font-weight: 800; color: #172033; }
.subtitle { display: block; margin-top: 8rpx; font-size: 24rpx; color: #7b8794; }
.stats-grid { display: grid; grid-template-columns: 1fr 1fr; gap: 18rpx; margin-bottom: 24rpx; }
.stat-card { background: #fff; border-radius: 16rpx; padding: 28rpx; box-shadow: 0 6rpx 18rpx rgba(12, 32, 64, 0.06); }
.stat-card.warning .stat-value { color: #d94841; }
.stat-value { display: block; font-size: 46rpx; font-weight: 800; color: #0066cc; }
.stat-label { display: block; margin-top: 6rpx; font-size: 24rpx; color: #7b8794; }
.section { background: #fff; border-radius: 16rpx; padding: 24rpx; margin-bottom: 22rpx; box-shadow: 0 6rpx 18rpx rgba(12, 32, 64, 0.05); }
.section-head { display: flex; justify-content: space-between; align-items: center; margin-bottom: 8rpx; }
.section-title { font-size: 30rpx; font-weight: 700; color: #172033; }
.refresh { font-size: 24rpx; color: #0066cc; }
.rank-row, .simple-row, .summary-line { display: flex; justify-content: space-between; align-items: center; padding: 22rpx 0; border-bottom: 1rpx solid #eef1f5; }
.rank-row:last-child, .simple-row:last-child { border-bottom: 0; }
.rank-info { flex: 1; min-width: 0; }
.rank-name { display: block; font-size: 28rpx; color: #1f2a3d; font-weight: 600; }
.rank-meta { display: block; margin-top: 6rpx; font-size: 22rpx; color: #8a94a6; }
.rank-rate, .summary-value { color: #0066cc; font-size: 30rpx; font-weight: 800; margin-left: 20rpx; }
.danger { color: #d94841; }
.empty { text-align: center; color: #99a3b3; font-size: 26rpx; padding: 36rpx 0; }
