.credit-header {
  background: linear-gradient(135deg, #0066CC, #1890FF);
  padding: 40rpx 32rpx;
  display: flex;
  flex-direction: column;
  align-items: center;
}

.credit-score-label {
  font-size: 26rpx;
  color: rgba(255, 255, 255, 0.8);
  margin-bottom: 8rpx;
}

.credit-score-value {
  font-size: 80rpx;
  font-weight: bold;
  color: #FFFFFF;
  margin-bottom: 24rpx;
}

.credit-bar-bg {
  width: 100%;
  height: 16rpx;
  background-color: rgba(255, 255, 255, 0.2);
  border-radius: 8rpx;
  overflow: hidden;
  margin-bottom: 16rpx;
}

.credit-bar-fill {
  height: 100%;
  border-radius: 8rpx;
}

.credit-levels {
  display: flex;
  flex-direction: row;
  justify-content: space-between;
  width: 100%;
}

.level-text {
  font-size: 22rpx;
  color: rgba(255, 255, 255, 0.7);
}

.level-red {
  color: #FFA39E;
}

.level-yellow {
  color: #FFD666;
}

.level-green {
  color: #95F09B;
}

.record-list {
  padding: 0;
}

.record-item {
  display: flex;
  flex-direction: row;
  justify-content: space-between;
  align-items: center;
  padding: 24rpx 32rpx;
  background-color: #FFFFFF;
  border-bottom: 1rpx solid #F5F5F5;
}

.record-left {
  display: flex;
  flex-direction: column;
  flex: 1;
}

.record-title {
  font-size: 28rpx;
  color: #333333;
  margin-bottom: 8rpx;
  font-weight: 600;
}

.record-reason {
  font-size: 24rpx;
  color: #666666;
  margin-bottom: 6rpx;
  line-height: 1.4;
}

.record-time {
  font-size: 24rpx;
  color: #999999;
}

.record-right {
  display: flex;
  flex-direction: column;
  align-items: flex-end;
  flex-shrink: 0;
  margin-left: 24rpx;
}

.record-change {
  font-size: 32rpx;
  font-weight: bold;
}

.record-score {
  margin-top: 6rpx;
  font-size: 22rpx;
  color: #999999;
}

.change-positive {
  color: #52C41A;
}

.change-negative {
  color: #FF4D4F;
}

.loading-state {
  display: flex;
  justify-content: center;
  padding: 120rpx 0;
}

.loading-text {
  font-size: 28rpx;
  color: #999999;
}

.stats-header {
  display: grid;
  grid-template-columns: repeat(2, 1fr);
  gap: 18rpx;
  padding: 24rpx;
}

.stats-card {
  min-height: 140rpx;
  border-radius: 18rpx;
  background: #FFFFFF;
  box-shadow: 0 6rpx 18rpx rgba(0, 0, 0, 0.06);
  display: flex;
  flex-direction: column;
  align-items: center;
  justify-content: center;
}

.stats-num {
  font-size: 48rpx;
  font-weight: 800;
  color: #0066CC;
}

.stats-label {
  margin-top: 8rpx;
  font-size: 24rpx;
  color: #666666;
}

.stats-warning .stats-num {
  color: #FA8C16;
}

.status-pill {
  flex-shrink: 0;
  padding: 8rpx 16rpx;
  border-radius: 999rpx;
  background: #EEF5FF;
  color: #0066CC;
  font-size: 22rpx;
}

.empty-state {
  padding: 120rpx 32rpx;
  display: flex;
  flex-direction: column;
  align-items: center;
}

.empty-icon {
  font-size: 48rpx;
  color: #C8CDD6;
}

.empty-text {
  margin-top: 12rpx;
  font-size: 26rpx;
  color: #999999;
}
