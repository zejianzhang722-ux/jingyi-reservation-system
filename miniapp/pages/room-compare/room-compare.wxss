.container {
  min-height: 100vh;
  padding-bottom: calc(48rpx + env(safe-area-inset-bottom));
  background:
    radial-gradient(circle at 90% 4%, rgba(79,213,232,0.16), transparent 30%),
    radial-gradient(circle at 2% 24%, rgba(47,128,255,0.10), transparent 28%),
    linear-gradient(180deg, #f8fbff 0%, #f0f3f8 48%, #edf1f7 100%);
}

.selected-rooms {
  display: flex;
  flex-direction: row;
  flex-wrap: wrap;
  padding: 24rpx;
  gap: 14rpx;
  background: rgba(248,251,255,0.86);
  border-bottom: 1rpx solid rgba(255,255,255,0.72);
  box-shadow: 0 14rpx 32rpx rgba(99,117,150,0.08);
  backdrop-filter: blur(18px);
  -webkit-backdrop-filter: blur(18px);
}

.selected-room {
  display: flex;
  flex-direction: row;
  align-items: center;
  gap: 8rpx;
  padding: 12rpx 20rpx;
  border-radius: 999rpx;
  background: linear-gradient(145deg, #ffffff, #eaf3ff);
  border: 1rpx solid rgba(255,255,255,0.88);
  box-shadow: 7rpx 9rpx 18rpx rgba(154,170,196,0.14), inset 0 2rpx 0 rgba(255,255,255,0.84);
}

.selected-room-name {
  font-size: 26rpx;
  font-weight: 760;
  color: #2f80ff;
}

.selected-room-remove {
  font-size: 24rpx;
  color: #8d9ab0;
  padding: 4rpx;
}

.add-room-btn {
  display: flex;
  align-items: center;
  justify-content: center;
  padding: 12rpx 24rpx;
  border: 2rpx dashed rgba(47,128,255,0.24);
  border-radius: 999rpx;
  background: rgba(255,255,255,0.46);
}

.add-room-text {
  font-size: 26rpx;
  color: #2f80ff;
  font-weight: 760;
}

.compare-table {
  margin: 24rpx;
  overflow: hidden;
  border-radius: 34rpx;
  background:
    radial-gradient(circle at 92% 0%, rgba(79,213,232,0.10), transparent 32%),
    linear-gradient(145deg, rgba(255,255,255,0.99), rgba(242,246,252,0.95));
  border: 1rpx solid rgba(255,255,255,0.94);
  box-shadow: 16rpx 18rpx 38rpx rgba(154,170,196,0.22), -10rpx -10rpx 24rpx rgba(255,255,255,0.86), inset 0 2rpx 0 rgba(255,255,255,0.92);
}

.compare-row {
  display: flex;
  flex-direction: row;
  border-bottom: 1rpx solid rgba(139,154,178,0.10);
}

.compare-row:last-child {
  border-bottom: none;
}

.compare-header {
  background: linear-gradient(145deg, rgba(255,255,255,0.60), rgba(232,242,253,0.60));
}

.compare-label {
  flex-shrink: 0;
  width: 160rpx;
  padding: 22rpx 16rpx;
  font-size: 25rpx;
  color: #8d9ab0;
  border-right: 1rpx solid rgba(139,154,178,0.10);
  box-sizing: border-box;
}

.compare-header .compare-label {
  font-weight: 850;
  color: #1f2a3d;
}

.compare-value {
  flex: 1;
  min-width: 150rpx;
  padding: 22rpx 16rpx;
  font-size: 25rpx;
  color: #1f2a3d;
  text-align: center;
  border-right: 1rpx solid rgba(139,154,178,0.10);
  box-sizing: border-box;
}

.compare-value:last-child {
  border-right: none;
}

.compare-header .compare-value {
  font-weight: 850;
  color: #2f80ff;
}

.picker-mask {
  position: fixed;
  inset: 0;
  background: rgba(31,42,61,0.42);
  backdrop-filter: blur(6px);
  -webkit-backdrop-filter: blur(6px);
  z-index: 100;
}

.picker-panel {
  position: fixed;
  left: 22rpx;
  right: 22rpx;
  bottom: calc(22rpx + env(safe-area-inset-bottom));
  z-index: 101;
  max-height: 64vh;
  overflow: hidden;
  border-radius: 34rpx;
  background: linear-gradient(145deg, rgba(255,255,255,0.98), rgba(239,245,252,0.96));
  border: 1rpx solid rgba(255,255,255,0.92);
  box-shadow: 0 30rpx 70rpx rgba(31,42,61,0.30), inset 0 2rpx 0 rgba(255,255,255,0.92);
  transform: translateY(calc(100% + 80rpx));
  transition: transform 0.28s cubic-bezier(.22,.74,.25,1);
}

.picker-show {
  transform: translateY(0);
}

.picker-header {
  display: flex;
  flex-direction: row;
  justify-content: space-between;
  align-items: center;
  padding: 28rpx 32rpx 24rpx;
  border-bottom: 1rpx solid rgba(139,154,178,0.10);
}

.picker-title {
  font-size: 32rpx;
  font-weight: 860;
  color: #1f2a3d;
}

.picker-close {
  width: 48rpx;
  height: 48rpx;
  display: flex;
  align-items: center;
  justify-content: center;
  border-radius: 16rpx;
  font-size: 28rpx;
  color: #8d9ab0;
  background: linear-gradient(145deg, #ffffff, #edf4fc);
  box-shadow: 6rpx 8rpx 16rpx rgba(164,178,202,0.14), inset 0 2rpx 0 rgba(255,255,255,0.84);
}

.picker-list {
  max-height: 50vh;
}

.picker-item {
  display: flex;
  flex-direction: row;
  align-items: center;
  padding: 24rpx 32rpx;
  border-bottom: 1rpx solid rgba(139,154,178,0.10);
}

.picker-item-icon {
  width: 54rpx;
  height: 54rpx;
  margin-right: 16rpx;
  border-radius: 18rpx;
  background: linear-gradient(145deg, #e8f5ff, #b9dcff);
  box-shadow: 7rpx 9rpx 16rpx rgba(164,178,202,0.16), inset 0 3rpx 6rpx rgba(255,255,255,0.72);
  position: relative;
  flex-shrink: 0;
}

.picker-item-icon::after {
  content: '';
  position: absolute;
  left: 15rpx;
  top: 15rpx;
  width: 22rpx;
  height: 22rpx;
  border: 4rpx solid #2f80ff;
  border-top-width: 8rpx;
  border-radius: 5rpx;
}

.empty-icon {
  width: 106rpx;
  height: 106rpx;
  margin: 160rpx auto 24rpx;
  border-radius: 34rpx;
  background: linear-gradient(145deg, #ffffff, #e8f0fb);
  box-shadow: 12rpx 14rpx 26rpx rgba(164,178,202,0.22), -10rpx -10rpx 20rpx rgba(255,255,255,0.90), inset 0 2rpx 0 rgba(255,255,255,0.86);
  position: relative;
}

.empty-icon::before,
.empty-icon::after {
  content: '';
  position: absolute;
  background: #2f80ff;
}

.empty-icon::before {
  left: 49rpx;
  top: 28rpx;
  width: 8rpx;
  height: 50rpx;
  border-radius: 999rpx;
}

.empty-icon::after {
  left: 28rpx;
  top: 49rpx;
  width: 50rpx;
  height: 8rpx;
  border-radius: 999rpx;
}

.picker-item-name {
  flex: 1;
  font-size: 28rpx;
  color: #1f2a3d;
  font-weight: 760;
}

.picker-item-number {
  font-size: 24rpx;
  color: #8d9ab0;
}
