.container {
  min-height: 100vh;
  padding: 24rpx 24rpx calc(120rpx + env(safe-area-inset-bottom));
  box-sizing: border-box;
  background:
    radial-gradient(circle at 90% 4%, rgba(79,213,232,0.16), transparent 30%),
    radial-gradient(circle at 2% 24%, rgba(47,128,255,0.10), transparent 28%),
    linear-gradient(180deg, #f8fbff 0%, #f0f3f8 48%, #edf1f7 100%);
}

.header {
  display: flex;
  justify-content: space-between;
  align-items: center;
  gap: 20rpx;
  padding: 10rpx 0 24rpx;
}

.title {
  flex: 1;
  font-size: 40rpx;
  line-height: 1.22;
  font-weight: 880;
  color: #1f2a3d;
  letter-spacing: 0.6rpx;
}

.add-btn {
  flex-shrink: 0;
  padding: 15rpx 24rpx;
  border-radius: 999rpx;
  color: #fff;
  font-size: 25rpx;
  font-weight: 800;
  background: linear-gradient(135deg, #2f80ff, #39c6df);
  box-shadow: 0 14rpx 26rpx rgba(47,128,255,0.24), inset 0 2rpx 0 rgba(255,255,255,0.34);
}

.announcement-item {
  position: relative;
  margin-bottom: 18rpx;
  padding: 26rpx 28rpx;
  overflow: hidden;
  border-radius: 32rpx;
  background:
    radial-gradient(circle at 92% 0%, rgba(79,213,232,0.12), transparent 32%),
    linear-gradient(145deg, rgba(255,255,255,0.99), rgba(242,246,252,0.95));
  border: 1rpx solid rgba(255,255,255,0.94);
  box-shadow: 14rpx 16rpx 34rpx rgba(154,170,196,0.22), -10rpx -10rpx 24rpx rgba(255,255,255,0.86), inset 0 2rpx 0 rgba(255,255,255,0.92);
  box-sizing: border-box;
}

.announcement-item::before {
  content: '';
  position: absolute;
  left: 0;
  top: 28rpx;
  bottom: 28rpx;
  width: 7rpx;
  border-radius: 0 8rpx 8rpx 0;
  background: linear-gradient(180deg, #2f80ff, #39c6df);
  box-shadow: 4rpx 0 14rpx rgba(47,128,255,0.20);
}

.item-header {
  display: flex;
  justify-content: space-between;
  align-items: center;
  gap: 18rpx;
  margin-bottom: 14rpx;
}

.item-title {
  flex: 1;
  min-width: 0;
  font-size: 30rpx;
  line-height: 1.35;
  font-weight: 850;
  color: #1f2a3d;
  overflow: hidden;
  text-overflow: ellipsis;
  white-space: nowrap;
}

.item-type {
  flex-shrink: 0;
  font-size: 22rpx;
  padding: 7rpx 15rpx;
  border-radius: 999rpx;
  font-weight: 760;
  box-shadow: inset 0 2rpx 0 rgba(255,255,255,0.72), 0 8rpx 16rpx rgba(117,132,161,0.10);
}

.type-normal {
  background: #eaf3ff;
  color: #2f80ff;
}

.type-urgent {
  background: #fff0f1;
  color: #ec4e58;
}

.type-maintenance {
  background: #fff6e8;
  color: #f59b28;
}

.item-content {
  display: block;
  margin-bottom: 16rpx;
  padding: 18rpx 20rpx;
  border-radius: 22rpx;
  font-size: 26rpx;
  color: #61708a;
  line-height: 1.7;
  background: rgba(255,255,255,0.52);
  box-shadow: inset 4rpx 4rpx 10rpx rgba(164,178,202,0.10), inset -4rpx -4rpx 10rpx rgba(255,255,255,0.78);
}

.item-footer {
  display: flex;
  justify-content: space-between;
  align-items: center;
  gap: 18rpx;
}

.item-time {
  flex: 1;
  font-size: 22rpx;
  color: #9aa6b8;
}

.item-actions {
  display: flex;
  gap: 16rpx;
}

.btn-delete {
  font-size: 24rpx;
  font-weight: 760;
  color: #ec4e58;
  padding: 9rpx 18rpx;
  border-radius: 999rpx;
  background: #fff0f1;
}

.empty {
  margin-top: 80rpx;
  padding: 110rpx 0;
  text-align: center;
  color: #8d9ab0;
  font-size: 28rpx;
  border-radius: 32rpx;
  background: linear-gradient(145deg, rgba(255,255,255,0.96), rgba(242,246,252,0.90));
  border: 1rpx solid rgba(255,255,255,0.88);
  box-shadow: 12rpx 14rpx 28rpx rgba(164,178,202,0.18), -8rpx -8rpx 18rpx rgba(255,255,255,0.80);
}

.form-mask {
  position: fixed;
  inset: 0;
  background: rgba(31,42,61,0.42);
  backdrop-filter: blur(6px);
  -webkit-backdrop-filter: blur(6px);
  z-index: 100;
}

.form-panel {
  position: fixed;
  left: 22rpx;
  right: 22rpx;
  bottom: calc(22rpx + env(safe-area-inset-bottom));
  z-index: 101;
  transform: translateY(calc(100% + 80rpx));
  transition: transform 0.28s cubic-bezier(.22,.74,.25,1);
  overflow: hidden;
  border-radius: 34rpx;
  background: linear-gradient(145deg, rgba(255,255,255,0.98), rgba(239,245,252,0.96));
  border: 1rpx solid rgba(255,255,255,0.92);
  box-shadow: 0 30rpx 70rpx rgba(31,42,61,0.30), inset 0 2rpx 0 rgba(255,255,255,0.92);
}

.form-show {
  transform: translateY(0);
}

.form-header {
  display: flex;
  justify-content: space-between;
  align-items: center;
  padding: 28rpx 32rpx 24rpx;
  border-bottom: 1rpx solid rgba(139,154,178,0.10);
}

.form-title {
  font-size: 32rpx;
  font-weight: 860;
  color: #1f2a3d;
}

.form-close {
  width: 48rpx;
  height: 48rpx;
  display: flex;
  align-items: center;
  justify-content: center;
  border-radius: 16rpx;
  font-size: 28rpx;
  color: #8d9ab0;
  background: linear-gradient(145deg, #ffffff, #edf4fc);
  box-shadow: 6rpx 8rpx 16rpx rgba(164,178,202,0.14), inset 0 2rpx 0 rgba(255,255,255,0.84);
}

.form-body {
  padding: 24rpx 32rpx;
  max-height: 60vh;
  overflow-y: auto;
}

.form-row {
  display: flex;
  align-items: center;
  gap: 18rpx;
  margin-bottom: 20rpx;
}

.form-row-textarea {
  align-items: flex-start;
}

.form-label {
  flex-shrink: 0;
  width: 96rpx;
  font-size: 27rpx;
  color: #61708a;
  font-weight: 660;
}

.form-input,
.form-picker,
.form-textarea {
  flex: 1;
  padding: 16rpx 18rpx;
  border-radius: 20rpx;
  font-size: 27rpx;
  color: #1f2a3d;
  background: linear-gradient(145deg, rgba(255,255,255,0.92), rgba(239,244,251,0.86));
  box-shadow: inset 5rpx 5rpx 12rpx rgba(164,178,202,0.16), inset -5rpx -5rpx 12rpx rgba(255,255,255,0.86);
  box-sizing: border-box;
}

.form-textarea {
  height: 210rpx;
  width: auto;
  line-height: 1.55;
}

.form-footer {
  display: flex;
  gap: 18rpx;
  padding: 24rpx 32rpx 30rpx;
  border-top: 1rpx solid rgba(139,154,178,0.10);
}

.form-btn {
  flex: 1;
  text-align: center;
  padding: 20rpx;
  border-radius: 999rpx;
  font-size: 29rpx;
  font-weight: 800;
}

.btn-cancel {
  background: linear-gradient(145deg, #ffffff, #edf4fc);
  color: #61708a;
}

.btn-submit {
  background: linear-gradient(135deg, #2f80ff, #39c6df);
  color: #ffffff;
  box-shadow: 0 14rpx 28rpx rgba(47,128,255,0.24), inset 0 2rpx 0 rgba(255,255,255,0.34);
}
