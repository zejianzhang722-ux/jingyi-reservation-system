.container{min-height:100vh;padding:24rpx 24rpx calc(120rpx + env(safe-area-inset-bottom));box-sizing:border-box;background:radial-gradient(circle at 90% 4%,rgba(79,213,232,.16),transparent 30%),radial-gradient(circle at 2% 24%,rgba(47,128,255,.10),transparent 28%),linear-gradient(180deg,#f8fbff 0%,#f0f3f8 48%,#edf1f7 100%)}
.header{display:flex;justify-content:space-between;align-items:center;gap:20rpx;padding:10rpx 0 24rpx}.title{flex:1;font-size:40rpx;line-height:1.22;font-weight:880;color:#1f2a3d;letter-spacing:.6rpx}.add-btn{flex-shrink:0;padding:15rpx 24rpx;border-radius:999rpx;color:#fff;font-size:25rpx;font-weight:800;background:linear-gradient(135deg,#2f80ff,#39c6df);box-shadow:0 14rpx 26rpx rgba(47,128,255,.24),inset 0 2rpx 0 rgba(255,255,255,.34)}
.announcement-item{position:relative;margin-bottom:18rpx;padding:26rpx 28rpx;overflow:hidden;border-radius:32rpx;background:radial-gradient(circle at 92% 0%,rgba(79,213,232,.12),transparent 32%),linear-gradient(145deg,rgba(255,255,255,.99),rgba(242,246,252,.95));border:1rpx solid rgba(255,255,255,.94);box-shadow:14rpx 16rpx 34rpx rgba(154,170,196,.22),-10rpx -10rpx 24rpx rgba(255,255,255,.86),inset 0 2rpx 0 rgba(255,255,255,.92);box-sizing:border-box}.announcement-item:before{content:'';position:absolute;left:0;top:28rpx;bottom:28rpx;width:7rpx;border-radius:0 8rpx 8rpx 0;background:linear-gradient(180deg,#2f80ff,#39c6df)}.item-header{display:flex;justify-content:space-between;align-items:center;gap:18rpx;margin-bottom:14rpx}.item-title{flex:1;min-width:0;font-size:30rpx;line-height:1.35;font-weight:850;color:#1f2a3d;overflow:hidden;text-overflow:ellipsis;white-space:nowrap}.item-type{flex-shrink:0;font-size:22rpx;padding:7rpx 15rpx;border-radius:999rpx;font-weight:760}.type-normal,.type-notice{background:#eaf3ff;color:#2f80ff}.type-urgent{background:#fff0f1;color:#ec4e58}.type-maintenance{background:#fff6e8;color:#f59b28}.item-content{display:block;margin-bottom:16rpx;padding:18rpx 20rpx;border-radius:22rpx;font-size:26rpx;color:#61708a;line-height:1.7;background:rgba(255,255,255,.52);box-shadow:inset 4rpx 4rpx 10rpx rgba(164,178,202,.10),inset -4rpx -4rpx 10rpx rgba(255,255,255,.78)}.item-footer{display:flex;justify-content:space-between;align-items:center;gap:18rpx}.item-time{flex:1;font-size:22rpx;color:#9aa6b8}.item-actions{display:flex;gap:10rpx;flex-wrap:wrap;justify-content:flex-end}.btn-delete,.btn-edit,.btn-top{font-size:23rpx;font-weight:760;padding:9rpx 16rpx;border-radius:999rpx}.btn-delete{color:#ec4e58;background:#fff0f1}.btn-edit{color:#2f80ff;background:#eaf3ff}.btn-top{color:#f59b28;background:#fff6e8}.empty{margin-top:80rpx;padding:110rpx 0;text-align:center;color:#8d9ab0;font-size:28rpx;border-radius:32rpx;background:linear-gradient(145deg,rgba(255,255,255,.96),rgba(242,246,252,.90));box-shadow:12rpx 14rpx 28rpx rgba(164,178,202,.18)}
.form-mask{position:fixed;left:0;right:0;top:0;bottom:0;background:rgba(31,42,61,.42);backdrop-filter:blur(6px);-webkit-backdrop-filter:blur(6px);z-index:100}.form-panel{position:fixed;left:22rpx;right:22rpx;bottom:calc(22rpx + env(safe-area-inset-bottom));z-index:101;transform:translateY(calc(100% + 80rpx));transition:transform .28s cubic-bezier(.22,.74,.25,1);overflow:hidden;border-radius:34rpx;background:linear-gradient(145deg,rgba(255,255,255,.98),rgba(239,245,252,.96));border:1rpx solid rgba(255,255,255,.92);box-shadow:0 30rpx 70rpx rgba(31,42,61,.30),inset 0 2rpx 0 rgba(255,255,255,.92)}.form-show{transform:translateY(0)}.form-header{display:flex;justify-content:space-between;align-items:center;padding:28rpx 32rpx 24rpx;border-bottom:1rpx solid rgba(139,154,178,.10)}.form-title{font-size:32rpx;font-weight:860;color:#1f2a3d}.form-close{width:48rpx;height:48rpx;display:flex;align-items:center;justify-content:center;border-radius:16rpx;font-size:28rpx;color:#8d9ab0;background:linear-gradient(145deg,#fff,#edf4fc)}.form-body{padding:24rpx 32rpx;max-height:60vh;overflow-y:auto}.form-row{display:flex;align-items:center;gap:18rpx;margin-bottom:20rpx}.form-row-textarea{align-items:flex-start}.form-label{flex-shrink:0;width:96rpx;font-size:27rpx;color:#61708a;font-weight:660}.form-input,.form-picker,.form-textarea{flex:1;padding:16rpx 18rpx;border-radius:20rpx;font-size:27rpx;color:#1f2a3d;background:linear-gradient(145deg,rgba(255,255,255,.92),rgba(239,244,251,.86));box-shadow:inset 5rpx 5rpx 12rpx rgba(164,178,202,.16),inset -5rpx -5rpx 12rpx rgba(255,255,255,.86);box-sizing:border-box}.form-picker{display:block;text-align:right}.form-textarea{height:210rpx;width:auto;line-height:1.55}.form-footer{display:flex;gap:18rpx;padding:24rpx 32rpx 30rpx;border-top:1rpx solid rgba(139,154,178,.10)}.form-btn{flex:1;text-align:center;padding:20rpx;border-radius:999rpx;font-size:29rpx;font-weight:800}.btn-cancel{background:linear-gradient(145deg,#fff,#edf4fc);color:#61708a}.btn-submit{background:linear-gradient(135deg,#2f80ff,#39c6df);color:#fff;box-shadow:0 14rpx 28rpx rgba(47,128,255,.24),inset 0 2rpx 0 rgba(255,255,255,.34)}
