.container { padding: 20rpx; background: #f5f6fa; min-height: 100vh; }
.header { display: flex; justify-content: space-between; align-items: center; margin-bottom: 24rpx; }
.title { font-size: 36rpx; font-weight: bold; color: #333; }
.add-btn { background: #0066CC; color: #fff; padding: 12rpx 24rpx; border-radius: 8rpx; font-size: 26rpx; }
.announcement-list { }
.announcement-item { background: #fff; border-radius: 12rpx; padding: 24rpx; margin-bottom: 16rpx; box-shadow: 0 2rpx 8rpx rgba(0,0,0,0.06); }
.item-header { display: flex; justify-content: space-between; align-items: center; margin-bottom: 12rpx; }
.item-title { font-size: 30rpx; font-weight: bold; color: #333; flex: 1; }
.item-type { font-size: 22rpx; padding: 4rpx 12rpx; border-radius: 4rpx; }
.type-normal { background: #e6f7ff; color: #1890ff; }
.type-urgent { background: #fff1f0; color: #ff4d4f; }
.type-maintenance { background: #fff7e6; color: #fa8c16; }
.item-content { font-size: 26rpx; color: #666; line-height: 1.6; margin-bottom: 12rpx; }
.item-footer { display: flex; justify-content: space-between; align-items: center; }
.item-time { font-size: 22rpx; color: #999; }
.item-actions { display: flex; gap: 16rpx; }
.btn-delete { font-size: 24rpx; color: #ff4d4f; padding: 4rpx 16rpx; border: 1rpx solid #ff4d4f; border-radius: 4rpx; }
.empty { text-align: center; padding: 100rpx 0; color: #999; font-size: 28rpx; }
.form-mask { position: fixed; top: 0; left: 0; right: 0; bottom: 0; background: rgba(0,0,0,0.5); z-index: 100; }
.form-panel { position: fixed; left: 0; right: 0; bottom: 0; background: #fff; border-radius: 24rpx 24rpx 0 0; z-index: 101; transform: translateY(100%); transition: transform 0.3s; padding-bottom: env(safe-area-inset-bottom); }
.form-show { transform: translateY(0); }
.form-header { display: flex; justify-content: space-between; align-items: center; padding: 24rpx 32rpx; border-bottom: 1rpx solid #eee; }
.form-title { font-size: 32rpx; font-weight: bold; color: #333; }
.form-close { font-size: 36rpx; color: #999; padding: 8rpx; }
.form-body { padding: 24rpx 32rpx; max-height: 60vh; overflow-y: auto; }
.form-row { display: flex; align-items: center; margin-bottom: 20rpx; }
.form-row-textarea { align-items: flex-start; }
.form-label { font-size: 28rpx; color: #333; width: 100rpx; flex-shrink: 0; }
.form-input { flex: 1; font-size: 28rpx; padding: 12rpx; border: 1rpx solid #ddd; border-radius: 8rpx; }
.form-picker { flex: 1; font-size: 28rpx; padding: 12rpx; border: 1rpx solid #ddd; border-radius: 8rpx; color: #333; }
.form-textarea { flex: 1; font-size: 28rpx; padding: 12rpx; border: 1rpx solid #ddd; border-radius: 8rpx; height: 200rpx; width: auto; }
.form-footer { display: flex; gap: 20rpx; padding: 24rpx 32rpx; border-top: 1rpx solid #eee; }
.form-btn { flex: 1; text-align: center; padding: 20rpx; border-radius: 8rpx; font-size: 30rpx; }
.btn-cancel { background: #f5f5f5; color: #666; }
.btn-submit { background: #0066CC; color: #fff; }
