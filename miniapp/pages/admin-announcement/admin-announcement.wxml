<view class="container">
  <view class="header">
    <text class="title">公告管理</text>
    <view class="add-btn" bindtap="onAdd">+ 发布公告</view>
  </view>
  <view class="announcement-list" wx:if="{{list.length > 0}}">
    <view class="announcement-item" wx:for="{{list}}" wx:key="id">
      <view class="item-header">
        <text class="item-title">{{item.title}}</text>
        <text class="item-type type-{{item.type}}">{{typeMap[item.type] || '通知'}}</text>
      </view>
      <text class="item-content">{{item.content}}</text>
      <view class="item-footer">
        <text class="item-time">{{item.created_at || item.createdAt}}</text>
        <view class="item-actions">
          <view class="btn-delete" data-id="{{item.id}}" bindtap="onDelete">删除</view>
        </view>
      </view>
    </view>
  </view>
  <view class="empty" wx:else>
    <text>暂无公告</text>
  </view>
  <view class="form-mask" wx:if="{{showForm}}" bindtap="onCancelForm"></view>
  <view class="form-panel {{showForm ? 'form-show' : ''}}">
    <view class="form-header">
      <text class="form-title">发布公告</text>
      <text class="form-close" bindtap="onCancelForm">✕</text>
    </view>
    <view class="form-body">
      <view class="form-row">
        <text class="form-label">标题</text>
        <input class="form-input" placeholder="请输入公告标题" value="{{form.title}}" bindinput="onTitleInput" />
      </view>
      <view class="form-row">
        <text class="form-label">类型</text>
        <picker mode="selector" range="{{['普通通知','紧急通知','维护通知']}}" value="{{form.type === 'urgent' ? 1 : form.type === 'maintenance' ? 2 : 0}}" bindchange="onTypeChange">
          <text class="form-picker">{{typeMap[form.type] || '普通通知'}}</text>
        </picker>
      </view>
      <view class="form-row form-row-textarea">
        <text class="form-label">内容</text>
        <textarea class="form-textarea" placeholder="请输入公告内容" value="{{form.content}}" bindinput="onContentInput" maxlength="500" />
      </view>
    </view>
    <view class="form-footer">
      <view class="form-btn btn-cancel" bindtap="onCancelForm">取消</view>
      <view class="form-btn btn-submit" bindtap="onSubmit">发布</view>
    </view>
  </view>
</view>
