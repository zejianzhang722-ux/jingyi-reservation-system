.container {
  min-height: 100vh;
  padding: 24rpx 0 calc(48rpx + env(safe-area-inset-bottom));
  background:
    radial-gradient(circle at 90% 2%, rgba(79,213,232,0.16), transparent 30%),
    radial-gradient(circle at 0% 24%, rgba(47,128,255,0.10), transparent 28%),
    linear-gradient(180deg, #f8fbff 0%, #f0f3f8 48%, #edf1f7 100%);
}

.detail-card {
  position: relative;
  margin: 0 24rpx 24rpx;
  padding: 32rpx;
  overflow: hidden;
  border-radius: 36rpx;
  background:
    radial-gradient(circle at 86% 2%, rgba(79,213,232,0.14), transparent 32%),
    linear-gradient(145deg, rgba(255,255,255,0.99), rgba(241,246,253,0.96));
  border: 1rpx solid rgba(255,255,255,0.94);
  box-shadow: 18rpx 20rpx 42rpx rgba(154,170,196,0.26), -10rpx -10rpx 24rpx rgba(255,255,255,0.88), inset 0 2rpx 0 rgba(255,255,255,0.92);
  animation: roomRise 380ms cubic-bezier(.22,.74,.25,1) both;
  box-sizing: border-box;
}

.detail-card::before {
  content: '';
  position: absolute;
  right: -72rpx;
  top: -78rpx;
  width: 228rpx;
  height: 228rpx;
  border-radius: 50%;
  background: radial-gradient(circle, rgba(79,213,232,0.26), rgba(79,213,232,0));
}

.detail-header {
  position: relative;
  display: flex;
  flex-direction: row;
  align-items: center;
  gap: 22rpx;
  margin-bottom: 28rpx;
  padding-bottom: 26rpx;
  border-bottom: 1rpx solid rgba(139,154,178,0.10);
}

.detail-icon {
  flex-shrink: 0;
  width: 86rpx;
  height: 86rpx;
  display: flex;
  align-items: center;
  justify-content: center;
  border-radius: 28rpx;
  background: linear-gradient(145deg, #e8f5ff, #b9dcff);
  border: 1rpx solid rgba(255,255,255,0.86);
  box-shadow: 10rpx 12rpx 24rpx rgba(164,178,202,0.20), -8rpx -8rpx 18rpx rgba(255,255,255,0.88), inset 0 4rpx 8rpx rgba(255,255,255,0.72);
}

.detail-icon-shared { background: linear-gradient(145deg, #f2ebff, #d5c2ff); }
.detail-icon-media { background: linear-gradient(145deg, #ffe8f3, #ffc5df); }
.detail-icon-competition { background: linear-gradient(145deg, #fff4df, #ffdba0); }
.detail-icon-roadshow { background: linear-gradient(145deg, #e1fbfb, #a9ecec); }
.detail-icon-dance { background: linear-gradient(145deg, #ffe7eb, #ffb8c4); }
.detail-icon-reading { background: linear-gradient(145deg, #e5fff5, #bcefd9); }
.detail-icon-multi { background: linear-gradient(145deg, #e7ebff, #c8d3ff); }
.detail-icon-academic { background: linear-gradient(145deg, #fff6d9, #ffe6a0); }
.detail-icon-career { background: linear-gradient(145deg, #f2ffd8, #d6f49a); }
.detail-icon-party { background: linear-gradient(145deg, #ffe7e7, #ffc2c2); }
.detail-icon-psychology { background: linear-gradient(145deg, #fff0f6, #ffd1e5); }

.detail-symbol {
  width: 44rpx;
  height: 44rpx;
  position: relative;
  filter: drop-shadow(0 6rpx 6rpx rgba(45,70,110,0.14));
}

.detail-symbol::before,
.detail-symbol::after {
  content: '';
  position: absolute;
  box-sizing: border-box;
}

.detail-symbol-study::before, .detail-symbol-room::before { width: 31rpx; height: 35rpx; left: 6rpx; top: 4rpx; border: 5rpx solid #2f80ff; border-radius: 6rpx; }
.detail-symbol-study::after, .detail-symbol-room::after { width: 23rpx; height: 5rpx; left: 10rpx; top: 17rpx; background: #2f80ff; box-shadow: 0 9rpx 0 #2f80ff; border-radius: 5rpx; }
.detail-symbol-shared::before { width: 16rpx; height: 16rpx; left: 3rpx; top: 6rpx; background: #7654d6; border-radius: 50%; box-shadow: 21rpx 0 0 #7654d6; }
.detail-symbol-shared::after { width: 38rpx; height: 15rpx; left: 3rpx; bottom: 4rpx; background: #7654d6; border-radius: 18rpx 18rpx 8rpx 8rpx; }
.detail-symbol-media::before { width: 35rpx; height: 25rpx; left: 4rpx; top: 10rpx; background: #d63384; border-radius: 8rpx; }
.detail-symbol-media::after { width: 0; height: 0; left: 18rpx; top: 17rpx; border-top: 6rpx solid transparent; border-bottom: 6rpx solid transparent; border-left: 10rpx solid #fff; }
.detail-symbol-competition::before, .detail-symbol-roadshow::before { width: 35rpx; height: 26rpx; left: 4rpx; top: 6rpx; border: 5rpx solid #c77a00; border-radius: 6rpx 6rpx 16rpx 16rpx; }
.detail-symbol-competition::after, .detail-symbol-roadshow::after { width: 21rpx; height: 6rpx; left: 11rpx; bottom: 4rpx; background: #c77a00; border-radius: 6rpx; }
.detail-symbol-dance::before { width: 24rpx; height: 24rpx; left: 10rpx; top: 3rpx; border: 5rpx solid #c33d5b; border-radius: 50%; }
.detail-symbol-dance::after { width: 33rpx; height: 5rpx; left: 5rpx; bottom: 8rpx; background: #c33d5b; transform: rotate(-22deg); border-radius: 5rpx; }
.detail-symbol-reading::before { width: 32rpx; height: 28rpx; left: 6rpx; top: 8rpx; border-left: 5rpx solid #2f8a3b; border-right: 5rpx solid #2f8a3b; border-bottom: 5rpx solid #2f8a3b; border-radius: 6rpx; }
.detail-symbol-reading::after { width: 5rpx; height: 28rpx; left: 20rpx; top: 8rpx; background: #2f8a3b; }
.detail-symbol-multi::before, .detail-symbol-academic::before { width: 31rpx; height: 26rpx; left: 6rpx; top: 9rpx; border: 5rpx solid #2f54eb; border-radius: 8rpx; }
.detail-symbol-multi::after, .detail-symbol-academic::after { width: 18rpx; height: 5rpx; left: 13rpx; top: 20rpx; background: #2f54eb; box-shadow: 0 8rpx 0 #2f54eb; border-radius: 5rpx; }
.detail-symbol-career::before { width: 33rpx; height: 24rpx; left: 5rpx; top: 13rpx; border: 5rpx solid #6f9d00; border-radius: 6rpx; }
.detail-symbol-career::after { width: 14rpx; height: 6rpx; left: 15rpx; top: 9rpx; border: 4rpx solid #6f9d00; border-bottom: 0; border-radius: 8rpx 8rpx 0 0; }
.detail-symbol-party::before { width: 5rpx; height: 35rpx; left: 10rpx; top: 5rpx; background: #d64545; border-radius: 5rpx; }
.detail-symbol-party::after { width: 25rpx; height: 18rpx; left: 15rpx; top: 6rpx; background: #d64545; border-radius: 0 8rpx 8rpx 0; }
.detail-symbol-psychology::before { width: 24rpx; height: 24rpx; left: 10rpx; top: 9rpx; background: #d63384; transform: rotate(45deg); border-radius: 6rpx; }
.detail-symbol-psychology::after { width: 18rpx; height: 18rpx; left: 6rpx; top: 7rpx; background: #d63384; border-radius: 50%; box-shadow: 14rpx 0 0 #d63384; }

.detail-title {
  flex: 1;
  display: flex;
  flex-direction: column;
  min-width: 0;
}

.detail-name {
  font-size: 38rpx;
  font-weight: 880;
  color: #1f2a3d;
  line-height: 1.24;
  letter-spacing: 0.6rpx;
}

.detail-number {
  margin-top: 8rpx;
  font-size: 25rpx;
  color: #61708a;
}

.detail-status {
  flex-shrink: 0;
  padding: 8rpx 18rpx;
  border-radius: 999rpx;
  font-size: 22rpx;
  font-weight: 780;
  border: 1rpx solid rgba(255,255,255,0.72);
  box-shadow: inset 0 2rpx 0 rgba(255,255,255,0.72), 0 8rpx 16rpx rgba(117,132,161,0.12);
}

.status-open {
  color: #25a96a;
  background: #e9fbf3;
}

.status-closed {
  color: #ec4e58;
  background: #fff0f1;
}

.detail-info {
  margin-bottom: 24rpx;
  padding: 8rpx 22rpx;
  border-radius: 26rpx;
  background: rgba(255,255,255,0.46);
  box-shadow: inset 5rpx 5rpx 12rpx rgba(164,178,202,0.10), inset -5rpx -5rpx 12rpx rgba(255,255,255,0.82);
}

.info-row {
  display: flex;
  flex-direction: row;
  justify-content: space-between;
  align-items: flex-start;
  gap: 24rpx;
  padding: 17rpx 0;
  border-bottom: 1rpx solid rgba(139,154,178,0.08);
}

.info-row:last-child {
  border-bottom: none;
}

.info-label {
  flex-shrink: 0;
  font-size: 26rpx;
  line-height: 1.45;
  color: #8d9ab0;
}

.info-value {
  flex: 1;
  font-size: 26rpx;
  line-height: 1.45;
  color: #1f2a3d;
  font-weight: 720;
  text-align: right;
  word-break: break-all;
}

.detail-section {
  margin-top: 26rpx;
  padding-top: 26rpx;
  border-top: 1rpx solid rgba(139,154,178,0.10);
}

.section-label {
  display: block;
  margin-bottom: 18rpx;
  font-size: 29rpx;
  font-weight: 850;
  color: #1f2a3d;
}

.device-list {
  display: flex;
  flex-direction: row;
  flex-wrap: wrap;
  gap: 14rpx;
}

.device-tag {
  padding: 10rpx 19rpx;
  border-radius: 999rpx;
  font-size: 24rpx;
  color: #2f80ff;
  background: linear-gradient(145deg, #ffffff, #eaf3ff);
  border: 1rpx solid rgba(255,255,255,0.82);
  box-shadow: 6rpx 8rpx 16rpx rgba(164,178,202,0.14), inset 0 2rpx 0 rgba(255,255,255,0.84);
}

.rules-text {
  display: block;
  font-size: 26rpx;
  color: #61708a;
  line-height: 1.8;
}

.detail-actions {
  display: flex;
  flex-direction: column;
  gap: 18rpx;
  padding: 0 24rpx 40rpx;
}

.action-btn {
  display: flex;
  align-items: center;
  justify-content: center;
  min-height: 86rpx;
  padding: 0 28rpx;
  border-radius: 999rpx;
  font-size: 29rpx;
  font-weight: 800;
  text-align: center;
  box-sizing: border-box;
  border: 1rpx solid rgba(255,255,255,0.82);
  transition: transform 160ms ease, opacity 160ms ease;
}

.action-btn:active {
  transform: translateY(3rpx) scale(0.98);
  opacity: 0.92;
}

.btn-primary {
  color: #ffffff;
  background: linear-gradient(135deg, #2f80ff 0%, #39c6df 100%);
  box-shadow: 0 16rpx 30rpx rgba(47,128,255,0.26), inset 0 2rpx 0 rgba(255,255,255,0.36);
}

.btn-outline {
  color: #2f80ff;
  background: linear-gradient(145deg, #ffffff, #edf4fc);
  box-shadow: 10rpx 12rpx 24rpx rgba(164,178,202,0.18), -8rpx -8rpx 18rpx rgba(255,255,255,0.88), inset 0 2rpx 0 rgba(255,255,255,0.86);
}

.empty-state,
.loading-state {
  display: flex;
  flex-direction: column;
  align-items: center;
  justify-content: center;
  padding: 150rpx 0;
  animation: roomRise 360ms cubic-bezier(.22,.74,.25,1) both;
}

.empty-icon-svg {
  position: relative;
  width: 132rpx;
  height: 132rpx;
  margin-bottom: 26rpx;
  border-radius: 42rpx;
  background: linear-gradient(145deg, #ffffff, #e8f0fb);
  box-shadow: 12rpx 14rpx 26rpx rgba(164,178,202,0.22), -10rpx -10rpx 20rpx rgba(255,255,255,0.90), inset 0 2rpx 0 rgba(255,255,255,0.86);
}

.empty-icon-svg::before {
  content: '';
  position: absolute;
  left: 35rpx;
  top: 35rpx;
  width: 62rpx;
  height: 62rpx;
  border-radius: 20rpx;
  background: linear-gradient(135deg, #2f80ff, #39c6df);
  box-shadow: 0 12rpx 22rpx rgba(47,128,255,0.22);
}

.empty-text,
.loading-text {
  font-size: 27rpx;
  color: #8d9ab0;
}

.loading-spinner {
  width: 54rpx;
  height: 54rpx;
  border: 5rpx solid rgba(47,128,255,0.14);
  border-top-color: #2f80ff;
  border-radius: 50%;
  animation: spin 0.82s linear infinite;
  margin-bottom: 18rpx;
}

@keyframes spin {
  from { transform: rotate(0deg); }
  to { transform: rotate(360deg); }
}

@keyframes roomRise {
  from { opacity: 0; transform: translateY(24rpx) scale(0.985); }
  to { opacity: 1; transform: translateY(0) scale(1); }
}
