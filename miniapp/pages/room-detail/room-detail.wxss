.detail-card {
  background-color: var(--bg-card);
  margin: 24rpx;
  border-radius: var(--radius-lg);
  padding: 32rpx;
  box-shadow: var(--shadow);
  border: 1rpx solid var(--border-color);
}

.detail-header {
  display: flex;
  flex-direction: row;
  align-items: center;
  gap: 20rpx;
  margin-bottom: 24rpx;
  padding-bottom: 24rpx;
  border-bottom: 1rpx solid var(--border-color);
}

.detail-icon {
  width: 76rpx;
  height: 76rpx;
  border-radius: 22rpx;
  background: linear-gradient(145deg, #E8F4FF, #CDE7FF);
  display: flex;
  align-items: center;
  justify-content: center;
  flex-shrink: 0;
  box-shadow: inset 0 2rpx 6rpx rgba(255,255,255,0.65), 0 10rpx 20rpx rgba(0,0,0,0.08);
}

.detail-icon-shared { background: linear-gradient(145deg, #F1EAFF, #DDD0FF); }
.detail-icon-media { background: linear-gradient(145deg, #FFE8F3, #FFD0E4); }
.detail-icon-competition { background: linear-gradient(145deg, #FFF3D8, #FFE1A8); }
.detail-icon-roadshow { background: linear-gradient(145deg, #E0FAFA, #BDF0F0); }
.detail-icon-dance { background: linear-gradient(145deg, #FFE4E8, #FFC5CD); }
.detail-icon-reading { background: linear-gradient(145deg, #EAF9E8, #CEF1C8); }
.detail-icon-multi { background: linear-gradient(145deg, #E7EBFF, #CCD5FF); }
.detail-icon-academic { background: linear-gradient(145deg, #FFF6D9, #FFE7A6); }
.detail-icon-career { background: linear-gradient(145deg, #F2FFD8, #DDF5A5); }
.detail-icon-party { background: linear-gradient(145deg, #FFE7E7, #FFC9C9); }
.detail-icon-psychology { background: linear-gradient(145deg, #FFF0F6, #FFD6E7); }

.detail-symbol {
  width: 42rpx;
  height: 42rpx;
  position: relative;
}

.detail-symbol::before,
.detail-symbol::after {
  content: '';
  position: absolute;
  box-sizing: border-box;
}

.detail-symbol-study::before, .detail-symbol-room::before { width: 30rpx; height: 34rpx; left: 6rpx; top: 4rpx; border: 5rpx solid #0066cc; border-radius: 5rpx; }
.detail-symbol-study::after, .detail-symbol-room::after { width: 22rpx; height: 5rpx; left: 10rpx; top: 16rpx; background: #0066cc; box-shadow: 0 9rpx 0 #0066cc; }
.detail-symbol-shared::before { width: 16rpx; height: 16rpx; left: 3rpx; top: 6rpx; background: #6f4fd4; border-radius: 50%; box-shadow: 20rpx 0 0 #6f4fd4; }
.detail-symbol-shared::after { width: 36rpx; height: 15rpx; left: 3rpx; bottom: 3rpx; background: #6f4fd4; border-radius: 18rpx 18rpx 8rpx 8rpx; }
.detail-symbol-media::before { width: 34rpx; height: 24rpx; left: 4rpx; top: 10rpx; background: #d63384; border-radius: 8rpx; }
.detail-symbol-media::after { width: 0; height: 0; left: 17rpx; top: 16rpx; border-top: 6rpx solid transparent; border-bottom: 6rpx solid transparent; border-left: 10rpx solid #fff; }
.detail-symbol-competition::before, .detail-symbol-roadshow::before { width: 34rpx; height: 26rpx; left: 4rpx; top: 6rpx; border: 5rpx solid #c77a00; border-radius: 5rpx 5rpx 16rpx 16rpx; }
.detail-symbol-competition::after, .detail-symbol-roadshow::after { width: 20rpx; height: 6rpx; left: 11rpx; bottom: 3rpx; background: #c77a00; border-radius: 6rpx; }
.detail-symbol-dance::before { width: 24rpx; height: 24rpx; left: 9rpx; top: 2rpx; border: 5rpx solid #c33d5b; border-radius: 50%; }
.detail-symbol-dance::after { width: 32rpx; height: 5rpx; left: 5rpx; bottom: 7rpx; background: #c33d5b; transform: rotate(-22deg); border-radius: 5rpx; }
.detail-symbol-reading::before { width: 32rpx; height: 28rpx; left: 5rpx; top: 8rpx; border-left: 5rpx solid #2f8a3b; border-right: 5rpx solid #2f8a3b; border-bottom: 5rpx solid #2f8a3b; border-radius: 5rpx; }
.detail-symbol-reading::after { width: 5rpx; height: 28rpx; left: 19rpx; top: 8rpx; background: #2f8a3b; }
.detail-symbol-multi::before, .detail-symbol-academic::before { width: 30rpx; height: 26rpx; left: 6rpx; top: 8rpx; border: 5rpx solid #2f54eb; border-radius: 8rpx; }
.detail-symbol-multi::after, .detail-symbol-academic::after { width: 18rpx; height: 5rpx; left: 12rpx; top: 19rpx; background: #2f54eb; box-shadow: 0 8rpx 0 #2f54eb; }
.detail-symbol-career::before { width: 32rpx; height: 24rpx; left: 5rpx; top: 12rpx; border: 5rpx solid #6f9d00; border-radius: 6rpx; }
.detail-symbol-career::after { width: 14rpx; height: 6rpx; left: 14rpx; top: 8rpx; border: 4rpx solid #6f9d00; border-bottom: 0; border-radius: 8rpx 8rpx 0 0; }
.detail-symbol-party::before { width: 5rpx; height: 34rpx; left: 10rpx; top: 4rpx; background: #d64545; }
.detail-symbol-party::after { width: 24rpx; height: 18rpx; left: 15rpx; top: 5rpx; background: #d64545; border-radius: 0 8rpx 8rpx 0; }
.detail-symbol-psychology::before { width: 24rpx; height: 24rpx; left: 9rpx; top: 8rpx; background: #d63384; transform: rotate(45deg); border-radius: 6rpx; }
.detail-symbol-psychology::after { width: 18rpx; height: 18rpx; left: 5rpx; top: 6rpx; background: #d63384; border-radius: 50%; box-shadow: 14rpx 0 0 #d63384; }

.detail-title {
  flex: 1;
  display: flex;
  flex-direction: column;
  min-width: 0;
}

.detail-name {
  font-size: 36rpx;
  font-weight: 800;
  color: var(--text-primary);
  line-height: 1.3;
}

.detail-number {
  font-size: 24rpx;
  color: var(--text-secondary);
  margin-top: 6rpx;
}

.detail-status {
  padding: 8rpx 18rpx;
  border-radius: 999rpx;
  font-size: 22rpx;
  flex-shrink: 0;
}

.status-open {
  color: var(--success);
  background: var(--success-light);
}

.status-closed {
  color: var(--danger);
  background: var(--danger-light);
}

.detail-info {
  margin-bottom: 24rpx;
}

.info-row {
  display: flex;
  flex-direction: row;
  justify-content: space-between;
  gap: 24rpx;
  padding: 16rpx 0;
  border-bottom: 1rpx solid #F7F8FA;
}

.info-label {
  font-size: 26rpx;
  color: var(--text-secondary);
  flex-shrink: 0;
}

.info-value {
  font-size: 26rpx;
  color: var(--text-primary);
  font-weight: 600;
  text-align: right;
}

.detail-section {
  margin-top: 24rpx;
  padding-top: 24rpx;
  border-top: 1rpx solid var(--border-color);
}

.section-label {
  font-size: 28rpx;
  font-weight: 800;
  color: var(--text-primary);
  margin-bottom: 16rpx;
  display: block;
}

.device-list {
  display: flex;
  flex-direction: row;
  flex-wrap: wrap;
  gap: 12rpx;
}

.device-tag {
  font-size: 24rpx;
  color: var(--primary);
  background-color: var(--primary-light);
  padding: 8rpx 18rpx;
  border-radius: var(--radius-sm);
}

.rules-text {
  font-size: 26rpx;
  color: var(--text-secondary);
  line-height: 1.8;
}

.detail-actions {
  display: flex;
  flex-direction: column;
  gap: 16rpx;
  padding: 0 24rpx 40rpx;
}

.action-btn {
  text-align: center;
  padding: 24rpx;
  border-radius: var(--radius-md);
  font-size: 30rpx;
}
