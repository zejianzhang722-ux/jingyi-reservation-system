.container{min-height:100vh;padding:24rpx 24rpx calc(120rpx + env(safe-area-inset-bottom));box-sizing:border-box;background:radial-gradient(circle at 90% 4%,rgba(79,213,232,.16),transparent 30%),radial-gradient(circle at 2% 24%,rgba(47,128,255,.10),transparent 28%),linear-gradient(180deg,#f8fbff 0%,#f0f3f8 48%,#edf1f7 100%)}
.header{padding:10rpx 4rpx 22rpx}.title{display:block;font-size:40rpx;line-height:1.22;font-weight:880;color:#1f2a3d}.subtitle{display:block;margin-top:9rpx;color:#61708a;font-size:24rpx;line-height:1.5}.filter-tabs{width:100%;white-space:nowrap;margin-bottom:20rpx;padding-bottom:8rpx}.tab{display:inline-flex;align-items:center;justify-content:center;min-width:112rpx;margin-right:14rpx;padding:14rpx 24rpx;border-radius:999rpx;font-size:24rpx;font-weight:760;color:#8d9ab0;background:linear-gradient(145deg,rgba(255,255,255,.96),rgba(236,242,250,.88));border:1rpx solid rgba(255,255,255,.88);box-shadow:8rpx 10rpx 20rpx rgba(154,170,196,.16),-6rpx -6rpx 16rpx rgba(255,255,255,.84);box-sizing:border-box}.tab.active{color:#fff;background:linear-gradient(135deg,#2f80ff,#39c6df);box-shadow:0 14rpx 26rpx rgba(47,128,255,.23),inset 0 2rpx 0 rgba(255,255,255,.34)}
.poster-item{position:relative;margin-bottom:18rpx;padding:24rpx;overflow:hidden;border-radius:32rpx;background:radial-gradient(circle at 92% 0%,rgba(79,213,232,.12),transparent 32%),linear-gradient(145deg,rgba(255,255,255,.99),rgba(242,246,252,.95));border:1rpx solid rgba(255,255,255,.94);box-shadow:14rpx 16rpx 34rpx rgba(154,170,196,.22),-10rpx -10rpx 24rpx rgba(255,255,255,.86),inset 0 2rpx 0 rgba(255,255,255,.92);box-sizing:border-box}.poster-item:before{content:'';position:absolute;left:0;top:28rpx;bottom:28rpx;width:7rpx;border-radius:0 8rpx 8rpx 0;background:linear-gradient(180deg,#2f80ff,#39c6df)}.poster-main{display:flex;gap:20rpx}.poster-cover{flex-shrink:0;width:150rpx;height:200rpx;overflow:hidden;border-radius:22rpx;background:#edf4fc;box-shadow:inset 0 2rpx 0 rgba(255,255,255,.86),8rpx 10rpx 18rpx rgba(154,170,196,.18)}.poster-cover image{width:100%;height:100%}.poster-info{flex:1;min-width:0}.poster-title-row{display:flex;align-items:flex-start;gap:12rpx}.poster-title{flex:1;font-size:30rpx;line-height:1.35;font-weight:850;color:#1f2a3d;overflow:hidden;text-overflow:ellipsis;white-space:nowrap}.status-tag{flex-shrink:0;padding:7rpx 15rpx;border-radius:999rpx;font-size:22rpx;font-weight:760}.status-pending{color:#f59b28;background:#fff6e8}.status-approved{color:#22a86e;background:#e9fbf3}.status-rejected,.status-violation{color:#ec4e58;background:#fff0f1}.status-cleaned{color:#61708a;background:#edf2f8}.poster-desc{display:block;margin:10rpx 0 12rpx;font-size:25rpx;line-height:1.55;color:#61708a;display:-webkit-box;-webkit-line-clamp:2;-webkit-box-orient:vertical;overflow:hidden}.meta-grid{display:flex;flex-direction:column;gap:5rpx}.meta-grid text{font-size:22rpx;line-height:1.45;color:#8d9ab0}.reject-reason{margin-top:12rpx;padding:12rpx 15rpx;border-radius:16rpx;background:#fff0f1;color:#ec4e58;font-size:23rpx;line-height:1.45}.actions{display:flex;justify-content:flex-end;gap:12rpx;flex-wrap:wrap;margin-top:18rpx}.btn{padding:11rpx 20rpx;border-radius:999rpx;font-size:24rpx;font-weight:780}.btn-approve{color:#fff;background:linear-gradient(135deg,#2f80ff,#39c6df);box-shadow:0 10rpx 20rpx rgba(47,128,255,.20)}.btn-reject,.btn-violation{color:#ec4e58;background:#fff0f1}.btn-clean{color:#22a86e;background:#e9fbf3}.empty,.loading{margin-top:80rpx;padding:110rpx 0;text-align:center;color:#8d9ab0;font-size:28rpx;border-radius:32rpx;background:linear-gradient(145deg,rgba(255,255,255,.96),rgba(242,246,252,.90));box-shadow:12rpx 14rpx 28rpx rgba(164,178,202,.18)}
