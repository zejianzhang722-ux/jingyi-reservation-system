.container {
  min-height: 100vh;
  padding-bottom: calc(140rpx + env(safe-area-inset-bottom));
  background:
    radial-gradient(circle at 90% 2%, rgba(79, 213, 232, 0.16), transparent 28%),
    radial-gradient(circle at 2% 20%, rgba(47, 128, 255, 0.10), transparent 30%),
    linear-gradient(180deg, #f7faff 0%, #f0f3f8 46%, #edf1f7 100%);
}

.tabs-scroll {
  position: sticky;
  top: 0;
  z-index: 6;
  width: 100%;
  white-space: nowrap;
  padding: 18rpx 0 16rpx;
  background: rgba(247, 250, 255, 0.88);
  border-bottom: 1rpx solid rgba(255, 255, 255, 0.75);
  box-shadow: 0 14rpx 32rpx rgba(99, 117, 150, 0.08);
  backdrop-filter: blur(18px);
  -webkit-backdrop-filter: blur(18px);
}

.tabs {
  display: flex;
  flex-direction: row;
  gap: 14rpx;
  padding: 0 24rpx;
}

.tab-item {
  position: relative;
  flex-shrink: 0;
  display: flex;
  flex-direction: column;
  align-items: center;
  justify-content: center;
  min-width: 116rpx;
  height: 66rpx;
  padding: 0 22rpx;
  border-radius: 999rpx;
  background: linear-gradient(145deg, rgba(255,255,255,0.92), rgba(235,241,249,0.82));
  border: 1rpx solid rgba(255,255,255,0.88);
  box-shadow: 8rpx 10rpx 22rpx rgba(164, 178, 202, 0.18), -8rpx -8rpx 18rpx rgba(255,255,255,0.88);
  box-sizing: border-box;
  transition: transform 160ms ease, box-shadow 160ms ease;
}

.tab-item:active {
  transform: scale(0.97);
  box-shadow: inset 6rpx 6rpx 14rpx rgba(163, 176, 199, 0.18), inset -6rpx -6rpx 14rpx rgba(255,255,255,0.82);
}

.tab-active {
  background: linear-gradient(135deg, #2f80ff 0%, #39c6df 100%);
  box-shadow: 0 16rpx 30rpx rgba(47,128,255,0.24), inset 0 2rpx 0 rgba(255,255,255,0.32);
}

.tab-name {
  font-size: 25rpx;
  font-weight: 780;
  color: #8b97aa !important;
}

.tab-active .tab-name {
  color: #ffffff !important;
}

.tab-indicator {
  position: absolute;
  left: 50%;
  bottom: 8rpx;
  width: 28rpx;
  height: 5rpx;
  margin-left: -14rpx;
  border-radius: 8rpx;
  background: rgba(255,255,255,0.80) !important;
  box-shadow: 0 0 10rpx rgba(255,255,255,0.55);
}

.reservation-list {
  padding: 20rpx 0 6rpx;
}

.reservation-item {
  position: relative;
  display: flex;
  flex-direction: row;
  margin: 18rpx 24rpx;
  overflow: hidden;
  border-radius: 30rpx;
  background:
    radial-gradient(circle at 90% 0%, rgba(79, 213, 232, 0.13), transparent 30%),
    linear-gradient(145deg, rgba(255,255,255,0.98), rgba(242,246,252,0.95));
  border: 1rpx solid rgba(255,255,255,0.94);
  box-shadow: 14rpx 16rpx 34rpx rgba(164, 178, 202, 0.22), -10rpx -10rpx 24rpx rgba(255,255,255,0.86), inset 0 2rpx 0 rgba(255,255,255,0.92);
  transition: transform 180ms ease, box-shadow 180ms ease;
}

.reservation-item:active {
  transform: translateY(3rpx) scale(0.985);
  box-shadow: 8rpx 10rpx 20rpx rgba(164, 178, 202, 0.18), inset 0 2rpx 0 rgba(255,255,255,0.88);
}

.reservation-status-bar {
  width: 10rpx;
  flex-shrink: 0;
  border-radius: 10rpx;
  margin: 22rpx 0 22rpx 18rpx;
  box-shadow: 0 0 18rpx rgba(47,128,255,0.18);
}

.status-pending { background: linear-gradient(180deg, #ffcf72, #f5a93a); }
.status-counselor_pending { background: linear-gradient(180deg, #ffcf72, #f5a93a); }
.status-approved { background: linear-gradient(180deg, #4bb2ff, #2f80ff); }
.status-checked_in { background: linear-gradient(180deg, #5ee0a4, #39bf78); }
.status-completed { background: linear-gradient(180deg, #cfd8e6, #9aa6b8); }
.status-cancelled { background: linear-gradient(180deg, #d8dde7, #b2bac9); }
.status-noshow { background: linear-gradient(180deg, #ff7f86, #ff5f68); }

.reservation-content {
  flex: 1;
  padding: 26rpx 26rpx 24rpx 20rpx;
}

.reservation-header {
  display: flex;
  flex-direction: row;
  justify-content: space-between;
  align-items: center;
  gap: 18rpx;
  margin-bottom: 14rpx;
}

.reservation-room {
  flex: 1;
  font-size: 31rpx;
  line-height: 1.25;
  font-weight: 820;
  color: #1f2a3d;
  letter-spacing: 0.5rpx;
}

.reservation-status-tag {
  flex-shrink: 0;
  min-width: 86rpx;
  padding: 7rpx 17rpx;
  border-radius: 999rpx;
  font-size: 22rpx;
  line-height: 1.2;
  font-weight: 750;
  text-align: center;
  border: 1rpx solid rgba(255,255,255,0.72);
  box-shadow: inset 0 2rpx 0 rgba(255,255,255,0.72), 0 8rpx 16rpx rgba(117,132,161,0.12);
}

.status-tag-pending,
.status-tag-counselor_pending { background: #fff3dc; color: #d88a1c; }
.status-tag-approved { background: #e8f3ff; color: #2f80ff; }
.status-tag-checked_in { background: #e8fbf2; color: #25a96a; }
.status-tag-completed { background: #eef2f7; color: #79879c; }
.status-tag-cancelled { background: #f0f2f6; color: #a2acbb; }
.status-tag-noshow { background: #fff0f1; color: #ec4e58; }

.reservation-info {
  display: flex;
  flex-direction: column;
  gap: 8rpx;
}

.reservation-date {
  display: inline-flex;
  font-size: 26rpx;
  line-height: 1.45;
  font-weight: 620;
  color: #61708a;
}

.reservation-purpose {
  font-size: 24rpx;
  line-height: 1.55;
  color: #9aa6b8;
}

.reservation-actions {
  display: flex;
  flex-direction: row;
  gap: 16rpx;
  margin-top: 20rpx;
}

.action-btn {
  min-width: 126rpx;
  padding: 13rpx 26rpx;
  border-radius: 999rpx;
  font-size: 24rpx;
  font-weight: 760;
  text-align: center;
  box-sizing: border-box;
  transition: transform 160ms ease, opacity 160ms ease;
}

.action-btn:active {
  transform: scale(0.96);
  opacity: 0.88;
}

.action-cancel {
  color: #ec4e58;
  background: linear-gradient(145deg, #fff5f6, #ffe8ea);
  border: 1rpx solid rgba(255, 151, 158, 0.28);
  box-shadow: 0 8rpx 16rpx rgba(255,95,104,0.10), inset 0 2rpx 0 rgba(255,255,255,0.72);
}

.action-checkin {
  color: #ffffff;
  background: linear-gradient(135deg, #2f80ff, #39c6df);
  box-shadow: 0 10rpx 22rpx rgba(47,128,255,0.24), inset 0 2rpx 0 rgba(255,255,255,0.36);
}

.empty-state,
.loading-state {
  display: flex;
  flex-direction: column;
  align-items: center;
  justify-content: center;
  padding: 150rpx 0;
  animation: uiRise 360ms cubic-bezier(.22,.74,.25,1) both;
}

.empty-icon-svg {
  position: relative;
  width: 132rpx;
  height: 132rpx;
  margin-bottom: 26rpx;
  border-radius: 42rpx;
  background: linear-gradient(145deg, #ffffff, #e8f0fb);
  box-shadow: 12rpx 14rpx 26rpx rgba(164,178,202,0.22), -10rpx -10rpx 20rpx rgba(255,255,255,0.90), inset 0 2rpx 0 rgba(255,255,255,0.86);
}

.empty-icon-svg::before {
  content: '';
  position: absolute;
  left: 34rpx;
  top: 34rpx;
  width: 64rpx;
  height: 64rpx;
  border-radius: 18rpx;
  background: linear-gradient(135deg, #2f80ff, #39c6df);
  opacity: 0.82;
  box-shadow: 0 12rpx 22rpx rgba(47,128,255,0.22);
}

.empty-text,
.loading-text {
  font-size: 27rpx;
  color: #8d9ab0;
}

.loading-spinner {
  width: 54rpx;
  height: 54rpx;
  border: 5rpx solid rgba(47,128,255,0.14);
  border-top-color: #2f80ff;
  border-radius: 50%;
  animation: spin 0.82s linear infinite;
  margin-bottom: 18rpx;
}

@keyframes spin {
  from { transform: rotate(0deg); }
  to { transform: rotate(360deg); }
}

@keyframes uiRise {
  from { opacity: 0; transform: translateY(22rpx) scale(0.985); }
  to { opacity: 1; transform: translateY(0) scale(1); }
}
