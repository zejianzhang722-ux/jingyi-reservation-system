.tabs-scroll {
  width: 100%;
  white-space: nowrap;
  background-color: var(--bg-card);
  border-bottom: 1rpx solid var(--border-color);
}

.tabs {
  display: flex;
  flex-direction: row;
  padding: 0 8rpx;
}

.tab-item {
  display: flex;
  flex-direction: column;
  align-items: center;
  padding: 20rpx 20rpx;
  position: relative;
  flex-shrink: 0;
}

.tab-name {
  font-size: 26rpx;
  font-weight: 600;
}

.tab-indicator {
  width: 32rpx;
  height: 6rpx;
  border-radius: 3rpx;
  margin-top: 8rpx;
}

.reservation-list {
  padding: 8rpx 0;
}

.reservation-item {
  display: flex;
  flex-direction: row;
  background-color: var(--bg-card);
  border-radius: 16rpx;
  overflow: hidden;
  margin: 12rpx 24rpx;
  box-shadow: var(--shadow);
  border-left: 4rpx solid var(--accent);
}

.reservation-item:active {
  opacity: 0.9;
}

.reservation-status-bar {
  width: 8rpx;
  flex-shrink: 0;
}

.status-pending { background-color: var(--warning); }
.status-counselor_pending { background-color: var(--warning); }
.status-approved { background-color: var(--primary); }
.status-checked_in { background-color: var(--success); }
.status-completed { background-color: var(--text-hint); }
.status-cancelled { background-color: var(--disabled); }
.status-noshow { background-color: var(--danger); }

.reservation-content {
  flex: 1;
  padding: 24rpx;
}

.reservation-header {
  display: flex;
  flex-direction: row;
  justify-content: space-between;
  align-items: center;
  margin-bottom: 12rpx;
}

.reservation-room {
  font-size: 30rpx;
  font-weight: 700;
  color: var(--text-primary);
}

.reservation-status-tag {
  font-size: 22rpx;
  padding: 4rpx 16rpx;
  border-radius: 20rpx;
}

.status-tag-pending { background-color: var(--warning-light); color: var(--warning); }
.status-tag-counselor_pending { background-color: var(--warning-light); color: var(--warning); }
.status-tag-approved { background-color: var(--primary-light); color: var(--primary); }
.status-tag-checked_in { background-color: var(--success-light); color: var(--success); }
.status-tag-completed { background-color: #F5F5F5; color: var(--text-hint); }
.status-tag-cancelled { background-color: #F5F5F5; color: #BBBBBB; }
.status-tag-noshow { background-color: var(--danger-light); color: var(--danger); }

.reservation-info {
  display: flex;
  flex-direction: column;
  gap: 4rpx;
}

.reservation-date {
  font-size: 26rpx;
  color: var(--text-secondary);
}

.reservation-purpose {
  font-size: 24rpx;
  color: var(--text-hint);
}

.reservation-actions {
  display: flex;
  flex-direction: row;
  gap: 16rpx;
  margin-top: 16rpx;
}

.action-btn {
  font-size: 24rpx;
  padding: 8rpx 24rpx;
  border-radius: 8rpx;
  text-align: center;
}

.action-cancel {
  background-color: var(--danger-light);
  color: var(--danger);
  border: 1rpx solid #FFCCC7;
}

.action-checkin {
  background-color: var(--primary);
  color: #FFFFFF;
}

.empty-state {
  display: flex;
  flex-direction: column;
  align-items: center;
  justify-content: center;
  padding: 120rpx 0;
  animation: fadeIn 0.3s ease-out both;
}

.empty-icon-svg {
  width: 120rpx;
  height: 120rpx;
  background: var(--border-color);
  border-radius: 50%;
  margin-bottom: 24rpx;
}

.empty-text {
  font-size: 28rpx;
  color: var(--text-hint);
}

.loading-state {
  display: flex;
  flex-direction: column;
  align-items: center;
  justify-content: center;
  padding: 120rpx 0;
  animation: fadeIn 0.3s ease-out both;
}

.loading-spinner {
  width: 48rpx;
  height: 48rpx;
  border: 4rpx solid #E8E8E8;
  border-top-color: var(--primary);
  border-radius: 50%;
  animation: spin 0.8s linear infinite;
  margin-bottom: 16rpx;
}

.loading-text {
  font-size: 26rpx;
  color: var(--text-hint);
}
