.container { padding: 20rpx; background: #f5f6fa; min-height: 100vh; }
.header { margin-bottom: 20rpx; }
.title { font-size: 36rpx; font-weight: bold; color: #333; }
.subtitle { display: block; margin-top: 8rpx; color: #8a94a6; font-size: 24rpx; }
.filter-tabs { display: flex; margin-bottom: 20rpx; white-space: nowrap; padding-bottom: 8rpx; }
.tab { padding: 10rpx 24rpx; border-radius: 20rpx; font-size: 24rpx; background: #fff; color: #666; border: 1rpx solid #ddd; flex-shrink: 0; }
.tab + .tab { margin-left: 12rpx; }
.tab.active { background: #0066CC; color: #fff; border-color: #0066CC; }
.room-list { }
.room-item { background: #fff; border-radius: 12rpx; padding: 24rpx; margin-bottom: 16rpx; box-shadow: 0 2rpx 8rpx rgba(0,0,0,0.06); display: flex; justify-content: space-between; align-items: center; }
.room-info { flex: 1; }
.room-header { display: flex; align-items: center; gap: 12rpx; margin-bottom: 8rpx; }
.room-name { font-size: 30rpx; font-weight: bold; color: #333; }
.room-status { font-size: 22rpx; padding: 4rpx 12rpx; border-radius: 4rpx; }
.status-open { background: #f6ffed; color: #52c41a; }
.status-closed { background: #fff1f0; color: #ff4d4f; }
.status-maintenance { background: #fff7e6; color: #fa8c16; }
.room-detail { }
.detail-text { display: block; font-size: 24rpx; color: #999; margin-top: 4rpx; }
.room-actions { flex-shrink: 0; margin-left: 20rpx; }
.btn-toggle { padding: 12rpx 24rpx; border-radius: 8rpx; font-size: 24rpx; background: #0066CC; color: #fff; }
.empty { text-align: center; padding: 100rpx 0; color: #999; font-size: 28rpx; }
