.container{min-height:100vh;padding:24rpx 24rpx calc(120rpx + env(safe-area-inset-bottom));box-sizing:border-box;background:radial-gradient(circle at 90% 4%,rgba(79,213,232,.16),transparent 30%),radial-gradient(circle at 2% 24%,rgba(47,128,255,.10),transparent 28%),linear-gradient(180deg,#f8fbff 0%,#f0f3f8 48%,#edf1f7 100%)}
.header{padding:10rpx 4rpx 22rpx}.header-top{display:flex;align-items:flex-start;justify-content:space-between;gap:18rpx}.title{display:block;font-size:40rpx;line-height:1.22;font-weight:880;color:#1f2a3d;letter-spacing:.6rpx}.subtitle{display:block;margin-top:9rpx;color:#61708a;font-size:24rpx;line-height:1.5}.add-btn{flex-shrink:0;padding:14rpx 23rpx;border-radius:999rpx;font-size:25rpx;font-weight:800;color:#fff;background:linear-gradient(135deg,#2f80ff,#39c6df);box-shadow:0 14rpx 26rpx rgba(47,128,255,.24),inset 0 2rpx 0 rgba(255,255,255,.34)}
.filter-tabs{width:100%;white-space:nowrap;margin-bottom:20rpx;padding-bottom:8rpx}.tab{display:inline-flex;align-items:center;justify-content:center;min-width:112rpx;margin-right:14rpx;padding:14rpx 24rpx;border-radius:999rpx;font-size:24rpx;font-weight:760;color:#8d9ab0;background:linear-gradient(145deg,rgba(255,255,255,.96),rgba(236,242,250,.88));border:1rpx solid rgba(255,255,255,.88);box-shadow:8rpx 10rpx 20rpx rgba(154,170,196,.16),-6rpx -6rpx 16rpx rgba(255,255,255,.84);box-sizing:border-box}.tab.active{color:#fff;background:linear-gradient(135deg,#2f80ff,#39c6df);box-shadow:0 14rpx 26rpx rgba(47,128,255,.23),inset 0 2rpx 0 rgba(255,255,255,.34)}
.room-item{position:relative;display:flex;justify-content:space-between;align-items:center;gap:18rpx;margin-bottom:18rpx;padding:26rpx 28rpx;overflow:hidden;border-radius:32rpx;background:radial-gradient(circle at 92% 0%,rgba(79,213,232,.12),transparent 32%),linear-gradient(145deg,rgba(255,255,255,.99),rgba(242,246,252,.95));border:1rpx solid rgba(255,255,255,.94);box-shadow:14rpx 16rpx 34rpx rgba(154,170,196,.22),-10rpx -10rpx 24rpx rgba(255,255,255,.86),inset 0 2rpx 0 rgba(255,255,255,.92);box-sizing:border-box}.room-item:before{content:'';position:absolute;left:0;top:28rpx;bottom:28rpx;width:7rpx;border-radius:0 8rpx 8rpx 0;background:linear-gradient(180deg,#2f80ff,#39c6df)}.room-info{flex:1;min-width:0}.room-header{display:flex;align-items:center;gap:14rpx;margin-bottom:12rpx}.room-name{flex:1;font-size:31rpx;line-height:1.35;font-weight:850;color:#1f2a3d;overflow:hidden;text-overflow:ellipsis;white-space:nowrap}.room-status{flex-shrink:0;font-size:22rpx;padding:7rpx 15rpx;border-radius:999rpx;font-weight:760}.status-open{background:#e9fbf3;color:#22a86e}.status-closed{background:#fff0f1;color:#ec4e58}.status-maintenance{background:#fff6e8;color:#f59b28}.room-detail{padding:12rpx 18rpx;border-radius:22rpx;background:rgba(255,255,255,.48);box-shadow:inset 4rpx 4rpx 10rpx rgba(164,178,202,.10),inset -4rpx -4rpx 10rpx rgba(255,255,255,.78)}.detail-text{display:block;margin-top:4rpx;font-size:24rpx;color:#61708a;line-height:1.55}.room-actions{flex-shrink:0;display:flex;flex-direction:column;gap:10rpx}.btn-toggle,.btn-edit{min-width:92rpx;padding:12rpx 22rpx;border-radius:999rpx;font-size:24rpx;font-weight:780;text-align:center}.btn-toggle{color:#fff;background:linear-gradient(135deg,#2f80ff,#39c6df);box-shadow:0 12rpx 24rpx rgba(47,128,255,.22),inset 0 2rpx 0 rgba(255,255,255,.34)}.btn-edit{color:#2f80ff;background:linear-gradient(145deg,#fff,#eaf3ff);box-shadow:6rpx 8rpx 16rpx rgba(164,178,202,.14),inset 0 2rpx 0 rgba(255,255,255,.84)}
.empty{margin-top:80rpx;padding:110rpx 0;text-align:center;color:#8d9ab0;font-size:28rpx;border-radius:32rpx;background:linear-gradient(145deg,rgba(255,255,255,.96),rgba(242,246,252,.90));border:1rpx solid rgba(255,255,255,.88);box-shadow:12rpx 14rpx 28rpx rgba(164,178,202,.18),-8rpx -8rpx 18rpx rgba(255,255,255,.80)}
.form-mask{position:fixed;left:0;right:0;top:0;bottom:0;z-index:100;background:rgba(31,42,61,.42);backdrop-filter:blur(6px);-webkit-backdrop-filter:blur(6px)}.form-panel{position:fixed;left:22rpx;right:22rpx;bottom:calc(22rpx + env(safe-area-inset-bottom));z-index:101;overflow:hidden;border-radius:34rpx;background:linear-gradient(145deg,rgba(255,255,255,.98),rgba(239,245,252,.96));border:1rpx solid rgba(255,255,255,.92);box-shadow:0 30rpx 70rpx rgba(31,42,61,.30),inset 0 2rpx 0 rgba(255,255,255,.92);transform:translateY(calc(100% + 80rpx));transition:transform .28s cubic-bezier(.22,.74,.25,1)}.form-show{transform:translateY(0)}.form-header{display:flex;justify-content:space-between;align-items:flex-start;gap:18rpx;padding:28rpx 32rpx 22rpx;border-bottom:1rpx solid rgba(139,154,178,.10)}.form-title{display:block;font-size:32rpx;font-weight:860;color:#1f2a3d}.form-subtitle{display:block;margin-top:8rpx;font-size:23rpx;color:#61708a}.form-close{flex-shrink:0;width:48rpx;height:48rpx;display:flex;align-items:center;justify-content:center;border-radius:16rpx;font-size:28rpx;color:#8d9ab0;background:linear-gradient(145deg,#fff,#edf4fc)}.form-body{max-height:60vh;padding:20rpx 32rpx;box-sizing:border-box}.form-row{display:flex;align-items:center;gap:18rpx;min-height:82rpx;border-bottom:1rpx solid rgba(139,154,178,.10)}.form-row.required .form-label:after{content:'*';color:#ec4e58;margin-left:4rpx}.form-row-textarea{align-items:flex-start;padding:16rpx 0}.form-label{flex-shrink:0;width:132rpx;font-size:26rpx;color:#61708a;font-weight:700}.form-input,.form-picker,.form-textarea{flex:1;padding:10rpx 18rpx;border-radius:18rpx;font-size:26rpx;color:#1f2a3d;background:linear-gradient(145deg,rgba(255,255,255,.92),rgba(239,244,251,.86));box-shadow:inset 5rpx 5rpx 12rpx rgba(164,178,202,.16),inset -5rpx -5rpx 12rpx rgba(255,255,255,.86);box-sizing:border-box}.form-input{min-height:62rpx;text-align:right}.form-picker{text-align:right;display:block}.form-textarea{width:auto;height:150rpx;line-height:1.55}.form-footer{display:flex;gap:18rpx;padding:22rpx 32rpx 30rpx;border-top:1rpx solid rgba(139,154,178,.10)}.form-btn{flex:1;text-align:center;padding:20rpx;border-radius:999rpx;font-size:29rpx;font-weight:800}.btn-cancel{background:linear-gradient(145deg,#fff,#edf4fc);color:#61708a}.btn-submit{background:linear-gradient(135deg,#2f80ff,#39c6df);color:#fff;box-shadow:0 14rpx 28rpx rgba(47,128,255,.24),inset 0 2rpx 0 rgba(255,255,255,.34)}.seat-warning{margin-top:22rpx;padding:18rpx 22rpx;border-radius:22rpx;font-size:24rpx;line-height:1.65;color:#f59b28;background:#fff6e8;box-shadow:inset 0 2rpx 0 rgba(255,255,255,.72)}
