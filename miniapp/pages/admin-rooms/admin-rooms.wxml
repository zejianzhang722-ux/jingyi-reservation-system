<view class="container">
  <view class="header">
    <view class="header-top">
      <view><text class="title">功能房管理</text><text class="subtitle">查看房间状态，维护开放规则、审核与人数容量</text></view>
      <view class="add-btn" bindtap="onAddRoom">新增功能房</view>
    </view>
  </view>

  <scroll-view class="filter-tabs" scroll-x="true" show-scrollbar="false">
    <view class="tab {{filterType === '' ? 'active' : ''}}" bindtap="onFilterType" data-type="">全部</view>
    <view class="tab {{filterType === 'study' ? 'active' : ''}}" bindtap="onFilterType" data-type="study">自习室</view>
    <view class="tab {{filterType === 'shared' ? 'active' : ''}}" bindtap="onFilterType" data-type="shared">共享空间</view>
    <view class="tab {{filterType === 'media' ? 'active' : ''}}" bindtap="onFilterType" data-type="media">影音室</view>
    <view class="tab {{filterType === 'competition' ? 'active' : ''}}" bindtap="onFilterType" data-type="competition">备赛间</view>
    <view class="tab {{filterType === 'roadshow' ? 'active' : ''}}" bindtap="onFilterType" data-type="roadshow">路演空间</view>
    <view class="tab {{filterType === 'reading' ? 'active' : ''}}" bindtap="onFilterType" data-type="reading">阅览室</view>
  </scroll-view>

  <view class="room-list" wx:if="{{list.length > 0}}">
    <view class="room-item" wx:for="{{list}}" wx:key="id">
      <view class="room-info" data-id="{{item.id}}" bindtap="onViewDetail">
        <view class="room-header"><text class="room-name">{{item.name}}</text><text class="room-status status-{{item.status}}">{{statusMap[item.status] || item.status}}</text></view>
        <view class="room-detail"><text class="detail-text">{{typeMap[item.type] || item.type}} | {{item.location || item.building_name || '-'}}</text><text class="detail-text">容量 {{item.capacity || '-'}} 人 | {{item.open_start_time || '-'}}-{{item.open_end_time || '-'}}</text></view>
      </view>
      <view class="room-actions"><view class="btn-edit" data-id="{{item.id}}" catchtap="onEditRoom">编辑</view><view class="btn-edit" data-id="{{item.id}}" catchtap="onOpenSeatForm">容量</view><view class="btn-toggle" data-id="{{item.id}}" data-status="{{item.status}}" catchtap="onToggleStatus">{{item.status === 'open' ? '关闭' : '开放'}}</view></view>
    </view>
  </view>
  <view class="empty" wx:else><text>暂无功能房数据</text></view>

  <view class="form-mask" wx:if="{{showForm}}" bindtap="onCancelForm"></view>
  <view class="form-mask" wx:if="{{showSeatForm}}" bindtap="onCancelSeatForm"></view>

  <view class="form-panel {{showForm ? 'form-show' : ''}}">
    <view class="form-header"><view><text class="form-title">{{formMode === 'edit' ? '编辑功能房' : '新增功能房'}}</text><text class="form-subtitle">维护楼栋楼层、人数容量、开放时间和审核规则</text></view><text class="form-close" bindtap="onCancelForm">✕</text></view>
    <scroll-view class="form-body" scroll-y="true">
      <view class="form-row required"><text class="form-label">名称</text><input class="form-input" placeholder="功能房名称" value="{{form.name}}" data-field="name" bindinput="onFormInput" /></view>
      <view class="form-row required"><text class="form-label">类型</text><picker mode="selector" range="{{typeOptions}}" range-key="label" bindchange="onTypeChange"><text class="form-picker">{{typeMap[form.type] || '自习室'}}</text></picker></view>
      <view class="form-row required"><text class="form-label">楼栋</text><picker mode="selector" range="{{buildingOptions}}" range-key="label" value="{{form.buildingId - 1}}" bindchange="onBuildingChange"><text class="form-picker">{{buildingOptions[form.buildingId - 1].label || '请选择楼栋'}}</text></picker></view>
      <view class="form-row required"><text class="form-label">楼层</text><picker mode="selector" range="{{floorOptions}}" range-key="label" value="{{form.floor - 1}}" bindchange="onFloorChange"><text class="form-picker">{{floorOptions[form.floor - 1].label || '请选择楼层'}}</text></picker></view>
      <view class="form-row"><text class="form-label">位置</text><input class="form-input" placeholder="如 敬一书院B座1楼" value="{{form.location}}" data-field="location" bindinput="onFormInput" /></view>
      <view class="form-row required"><text class="form-label">人数容量</text><input class="form-input" type="number" placeholder="可容纳人数" value="{{form.capacity}}" data-field="capacity" bindinput="onFormInput" /></view>
      <view class="form-row required"><text class="form-label">开放</text><input class="form-input" placeholder="08:00" value="{{form.openStartTime}}" data-field="openStartTime" bindinput="onFormInput" /></view>
      <view class="form-row required"><text class="form-label">关闭</text><input class="form-input" placeholder="22:00" value="{{form.openEndTime}}" data-field="openEndTime" bindinput="onFormInput" /></view>
      <view class="form-row required"><text class="form-label">最长</text><input class="form-input" type="number" placeholder="分钟" value="{{form.maxDuration}}" data-field="maxDuration" bindinput="onFormInput" /></view>
      <view class="form-row"><text class="form-label">状态</text><picker mode="selector" range="{{['开放中','已关闭','维护中']}}" value="{{form.status === 'closed' ? 1 : form.status === 'maintenance' ? 2 : 0}}" bindchange="onStatusChange"><text class="form-picker">{{statusMap[form.status] || '开放中'}}</text></picker></view>
      <view class="form-row"><text class="form-label">需审核</text><switch checked="{{form.needAudit}}" data-field="needAudit" bindchange="onSwitchChange" /></view>
      <view class="form-row"><text class="form-label">辅导员审</text><switch checked="{{form.needCounselorAudit}}" data-field="needCounselorAudit" bindchange="onSwitchChange" /></view>
      <view class="form-row form-row-textarea"><text class="form-label">设备</text><textarea class="form-textarea" placeholder="如 WiFi、电源、空调" value="{{form.facilities}}" data-field="facilities" bindinput="onFormInput" maxlength="300" /></view>
      <view class="form-row form-row-textarea"><text class="form-label">说明</text><textarea class="form-textarea" placeholder="使用说明或注意事项" value="{{form.description}}" data-field="description" bindinput="onFormInput" maxlength="500" /></view>
    </scroll-view>
    <view class="form-footer"><view class="form-btn btn-cancel" bindtap="onCancelForm">取消</view><view class="form-btn btn-submit" bindtap="onSubmitForm">{{submitting ? '保存中...' : '保存'}}</view></view>
  </view>

  <view class="form-panel {{showSeatForm ? 'form-show' : ''}}">
    <view class="form-header"><view><text class="form-title">维护人数容量</text><text class="form-subtitle">{{seatForm.roomName}}：只设置可容纳人数，不再填写起始号和每行数</text></view><text class="form-close" bindtap="onCancelSeatForm">✕</text></view>
    <view class="form-body">
      <view class="form-row required"><text class="form-label">人数容量</text><input class="form-input" type="number" placeholder="1-500" value="{{seatForm.count}}" data-field="count" bindinput="onSeatInput" /></view>
      <view class="seat-warning">保存后将按容量同步座位/容量数据。正式使用前请确认无正在进行的预约。</view>
    </view>
    <view class="form-footer"><view class="form-btn btn-cancel" bindtap="onCancelSeatForm">取消</view><view class="form-btn btn-submit" bindtap="onSubmitSeats">{{submittingSeats ? '同步中...' : '确认同步'}}</view></view>
  </view>
</view>