.container{min-height:100vh;padding-bottom:calc(128rpx + env(safe-area-inset-bottom));background:radial-gradient(circle at 90% 4%,rgba(79,213,232,.16),transparent 30%),radial-gradient(circle at 2% 24%,rgba(47,128,255,.10),transparent 28%),linear-gradient(180deg,#f8fbff 0%,#f0f3f8 48%,#edf1f7 100%)}
.form-card{position:relative;margin:24rpx;overflow:hidden;border-radius:34rpx;background:radial-gradient(circle at 92% 0%,rgba(79,213,232,.10),transparent 32%),linear-gradient(145deg,rgba(255,255,255,.99),rgba(242,246,252,.95));border:1rpx solid rgba(255,255,255,.94);box-shadow:16rpx 18rpx 38rpx rgba(154,170,196,.22),-10rpx -10rpx 24rpx rgba(255,255,255,.86),inset 0 2rpx 0 rgba(255,255,255,.92)}
.form-section{padding:28rpx;border-bottom:1rpx solid rgba(139,154,178,.10)}.form-section:last-of-type{border-bottom:none}.form-section-title{display:block;margin-bottom:18rpx;font-size:31rpx;line-height:1.3;font-weight:850;color:#1f2a3d}.form-item{display:flex;flex-direction:row;justify-content:space-between;align-items:center;min-height:88rpx;padding:16rpx 0;border-bottom:1rpx solid rgba(139,154,178,.10)}.form-item-vertical{display:flex;flex-direction:column;align-items:stretch;padding:16rpx 0}.form-label{flex-shrink:0;width:160rpx;font-size:27rpx;color:#61708a;font-weight:660}.form-item-vertical .form-label{width:auto;margin-bottom:12rpx}.form-input{flex:1;min-height:62rpx;padding:10rpx 18rpx;border-radius:18rpx;text-align:right;font-size:27rpx;color:#1f2a3d;background:linear-gradient(145deg,rgba(255,255,255,.92),rgba(239,244,251,.86));box-shadow:inset 5rpx 5rpx 12rpx rgba(164,178,202,.16),inset -5rpx -5rpx 12rpx rgba(255,255,255,.86);box-sizing:border-box}.form-textarea{width:100%;height:210rpx;padding:20rpx;border-radius:24rpx;font-size:27rpx;color:#1f2a3d;line-height:1.55;background:linear-gradient(145deg,rgba(255,255,255,.92),rgba(239,244,251,.86));box-shadow:inset 6rpx 6rpx 14rpx rgba(164,178,202,.16),inset -6rpx -6rpx 14rpx rgba(255,255,255,.86);box-sizing:border-box}.form-value{font-size:27rpx;color:#1f2a3d;font-weight:720}.placeholder{color:#9aa6b8}.image-upload{position:relative;width:100%;height:360rpx;overflow:hidden;display:flex;align-items:center;justify-content:center;border-radius:30rpx;background:linear-gradient(145deg,rgba(255,255,255,.92),rgba(239,244,251,.86));border:2rpx dashed rgba(47,128,255,.26);box-shadow:inset 8rpx 8rpx 18rpx rgba(164,178,202,.14),inset -8rpx -8rpx 18rpx rgba(255,255,255,.86)}.upload-preview{width:100%;height:100%}.upload-placeholder{display:flex;flex-direction:column;align-items:center;justify-content:center}.upload-icon{width:86rpx;height:86rpx;margin-bottom:14rpx;border-radius:28rpx;color:transparent;background:linear-gradient(145deg,#2f80ff,#39c6df);box-shadow:0 14rpx 26rpx rgba(47,128,255,.22),inset 0 4rpx 8rpx rgba(255,255,255,.30);position:relative}.upload-icon:before{content:'';position:absolute;left:23rpx;top:26rpx;width:40rpx;height:28rpx;border-radius:8rpx;background:rgba(255,255,255,.92)}.upload-text{font-size:26rpx;color:#8d9ab0;font-weight:700}.upload-tip{display:block;margin-top:16rpx;font-size:23rpx;line-height:1.55;color:#8d9ab0}.submit-btn{position:fixed;left:24rpx;right:24rpx;bottom:calc(24rpx + env(safe-area-inset-bottom));z-index:20;padding:25rpx 28rpx;text-align:center;border-radius:999rpx;font-size:32rpx;font-weight:850;color:#fff;background:linear-gradient(135deg,#2f80ff 0%,#39c6df 100%);border:1rpx solid rgba(255,255,255,.45);box-shadow:0 16rpx 32rpx rgba(47,128,255,.30),inset 0 2rpx 0 rgba(255,255,255,.36)}.btn-disabled{opacity:.62;background:linear-gradient(135deg,#a8b5c9,#c5cfdd)}
