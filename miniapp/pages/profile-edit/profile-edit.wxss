.container { padding: 20rpx 30rpx; background: #f5f7fa; min-height: 100vh; }
.form-section { background: #fff; border-radius: 16rpx; padding: 10rpx 30rpx; margin-bottom: 40rpx; }
.form-item { display: flex; align-items: center; padding: 28rpx 0; border-bottom: 1rpx solid #f0f0f0; }
.form-item:last-child { border-bottom: none; }
.form-label { width: 140rpx; font-size: 28rpx; color: #333; flex-shrink: 0; }
.form-input { flex: 1; font-size: 28rpx; color: #333; text-align: right; }
.save-btn { width: 100%; height: 88rpx; line-height: 88rpx; background: linear-gradient(135deg, #0077ff 0%, #00d4ff 100%); color: #fff; font-size: 32rpx; border-radius: 44rpx; border: none; margin-top: 40rpx; }
