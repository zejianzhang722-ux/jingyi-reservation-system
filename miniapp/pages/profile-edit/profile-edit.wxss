.container {
  min-height: 100vh;
  padding: 24rpx 24rpx calc(128rpx + env(safe-area-inset-bottom));
  box-sizing: border-box;
  background:
    radial-gradient(circle at 90% 4%, rgba(79,213,232,0.16), transparent 30%),
    radial-gradient(circle at 2% 24%, rgba(47,128,255,0.10), transparent 28%),
    linear-gradient(180deg, #f8fbff 0%, #f0f3f8 48%, #edf1f7 100%);
}

.form-section {
  position: relative;
  overflow: hidden;
  padding: 12rpx 28rpx;
  margin-bottom: 34rpx;
  border-radius: 34rpx;
  background:
    radial-gradient(circle at 92% 0%, rgba(79,213,232,0.12), transparent 32%),
    linear-gradient(145deg, rgba(255,255,255,0.99), rgba(242,246,252,0.95));
  border: 1rpx solid rgba(255,255,255,0.94);
  box-shadow: 16rpx 18rpx 38rpx rgba(154,170,196,0.22), -10rpx -10rpx 24rpx rgba(255,255,255,0.86), inset 0 2rpx 0 rgba(255,255,255,0.92);
  box-sizing: border-box;
  animation: profileEditRise 380ms cubic-bezier(.22,.74,.25,1) both;
}

.form-section::before {
  content: '';
  position: absolute;
  right: -58rpx;
  top: -66rpx;
  width: 200rpx;
  height: 200rpx;
  border-radius: 50%;
  background: radial-gradient(circle, rgba(79,213,232,0.23), rgba(79,213,232,0));
}

.form-item {
  position: relative;
  z-index: 1;
  display: flex;
  align-items: center;
  min-height: 94rpx;
  padding: 18rpx 0;
  border-bottom: 1rpx solid rgba(139,154,178,0.10);
  box-sizing: border-box;
}

.form-item:last-child {
  border-bottom: none;
}

.form-label {
  flex-shrink: 0;
  width: 150rpx;
  font-size: 27rpx;
  line-height: 1.45;
  color: #61708a;
  font-weight: 660;
}

.form-input {
  flex: 1;
  min-height: 62rpx;
  padding: 10rpx 18rpx;
  border-radius: 18rpx;
  text-align: right;
  font-size: 27rpx;
  color: #1f2a3d;
  background: linear-gradient(145deg, rgba(255,255,255,0.92), rgba(239,244,251,0.86));
  box-shadow: inset 5rpx 5rpx 12rpx rgba(164,178,202,0.16), inset -5rpx -5rpx 12rpx rgba(255,255,255,0.86);
  box-sizing: border-box;
}

.form-input[disabled] {
  color: #8d9ab0;
  background: linear-gradient(145deg, rgba(247,249,252,0.90), rgba(234,240,248,0.80));
}

.save-btn {
  position: fixed;
  left: 24rpx;
  right: 24rpx;
  bottom: calc(24rpx + env(safe-area-inset-bottom));
  width: auto;
  height: 88rpx;
  line-height: 88rpx;
  border: 1rpx solid rgba(255,255,255,0.45);
  border-radius: 999rpx;
  color: #fff;
  background: linear-gradient(135deg, #2f80ff 0%, #39c6df 100%);
  box-shadow: 0 16rpx 32rpx rgba(47,128,255,0.30), inset 0 2rpx 0 rgba(255,255,255,0.36);
  font-size: 31rpx;
  font-weight: 850;
  letter-spacing: 1rpx;
  transition: transform 160ms ease, opacity 160ms ease;
}

.save-btn:active {
  transform: translateY(3rpx) scale(0.98);
  opacity: 0.92;
}

.save-btn::after {
  border: 0;
}

@keyframes profileEditRise {
  from { opacity: 0; transform: translateY(24rpx) scale(0.985); }
  to { opacity: 1; transform: translateY(0) scale(1); }
}
