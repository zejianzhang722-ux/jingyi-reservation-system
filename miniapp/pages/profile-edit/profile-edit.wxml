<view class="container">
  <view class="form-section">
    <view class="form-item">
      <text class="form-label">姓名</text>
      <input class="form-input" value="{{form.name}}" bindinput="onNameInput" placeholder="请输入姓名" maxlength="50" />
    </view>
    <view class="form-item">
      <text class="form-label">学号</text>
      <input class="form-input" value="{{form.studentNo}}" disabled="true" />
    </view>
    <view class="form-item">
      <text class="form-label">一卡通号</text>
      <input class="form-input" value="{{form.cardNo}}" bindinput="onCardNoInput" placeholder="请输入6位一卡通号" type="number" maxlength="6" />
    </view>
    <view class="form-item">
      <text class="form-label">手机号</text>
      <input class="form-input" value="{{form.phone}}" bindinput="onPhoneInput" placeholder="请输入手机号" type="number" maxlength="11" />
    </view>
    <view class="form-item">
      <text class="form-label">邮箱</text>
      <input class="form-input" value="{{form.email}}" bindinput="onEmailInput" placeholder="可选，如 name@example.com" type="email" maxlength="100" />
    </view>
    <view class="form-item">
      <text class="form-label">书院</text>
      <input class="form-input" value="{{form.college}}" bindinput="onCollegeInput" placeholder="请输入书院" maxlength="50" />
    </view>
  </view>
  <button class="save-btn" bindtap="onSave" loading="{{saving}}" disabled="{{saving}}">{{saving ? '保存中...' : '保存修改'}}</button>
</view>
