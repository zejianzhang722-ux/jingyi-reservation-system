.container{min-height:100vh;padding:24rpx 24rpx calc(120rpx + env(safe-area-inset-bottom));box-sizing:border-box;background:radial-gradient(circle at 90% 4%,rgba(79,213,232,.16),transparent 30%),radial-gradient(circle at 2% 24%,rgba(47,128,255,.10),transparent 28%),linear-gradient(180deg,#f8fbff 0%,#f0f3f8 48%,#edf1f7 100%)}
.header{padding:10rpx 0 22rpx}.header-top{display:flex;align-items:center;justify-content:space-between;gap:18rpx;margin-bottom:18rpx}.title{flex:1;font-size:40rpx;line-height:1.22;font-weight:880;color:#1f2a3d;letter-spacing:.6rpx}.header-actions{display:flex;gap:10rpx;flex-shrink:0}.add-user-btn,.export-user-btn{flex-shrink:0;padding:14rpx 18rpx;border-radius:999rpx;font-size:24rpx;font-weight:800}.add-user-btn{color:#fff;background:linear-gradient(135deg,#2f80ff,#39c6df);box-shadow:0 14rpx 26rpx rgba(47,128,255,.24),inset 0 2rpx 0 rgba(255,255,255,.34)}.export-user-btn{color:#2f80ff;background:linear-gradient(145deg,#fff,#eaf3ff);box-shadow:8rpx 10rpx 20rpx rgba(164,178,202,.14),inset 0 2rpx 0 rgba(255,255,255,.84)}
.search-bar{position:relative;display:flex;align-items:center;min-height:82rpx;padding:0 24rpx;border-radius:999rpx;background:linear-gradient(145deg,rgba(255,255,255,.98),rgba(238,244,252,.92));border:1rpx solid rgba(255,255,255,.92);box-shadow:12rpx 14rpx 28rpx rgba(154,170,196,.20),-8rpx -8rpx 20rpx rgba(255,255,255,.88),inset 0 2rpx 0 rgba(255,255,255,.88);box-sizing:border-box}.search-bar:before{content:'';width:30rpx;height:30rpx;margin-right:14rpx;border:4rpx solid #2f80ff;border-radius:50%;box-sizing:border-box}.search-bar:after{content:'';position:absolute;left:49rpx;top:48rpx;width:16rpx;height:4rpx;border-radius:4rpx;background:#2f80ff;transform:rotate(45deg)}.search-input{flex:1;min-height:72rpx;font-size:27rpx;color:#1f2a3d}
.user-list{margin-top:12rpx}.user-item{position:relative;display:flex;align-items:center;gap:20rpx;margin-bottom:18rpx;padding:26rpx;overflow:hidden;border-radius:32rpx;background:radial-gradient(circle at 92% 0%,rgba(79,213,232,.12),transparent 32%),linear-gradient(145deg,rgba(255,255,255,.99),rgba(242,246,252,.95));border:1rpx solid rgba(255,255,255,.94);box-shadow:14rpx 16rpx 34rpx rgba(154,170,196,.22),-10rpx -10rpx 24rpx rgba(255,255,255,.86),inset 0 2rpx 0 rgba(255,255,255,.92);box-sizing:border-box}.user-item:before{content:'';position:absolute;left:0;top:28rpx;bottom:28rpx;width:7rpx;border-radius:0 8rpx 8rpx 0;background:linear-gradient(180deg,#2f80ff,#39c6df)}.user-avatar{flex-shrink:0;width:78rpx;height:78rpx;border-radius:28rpx;background:linear-gradient(145deg,#2f80ff,#39c6df);color:#fff;font-size:29rpx;font-weight:820;display:flex;align-items:center;justify-content:center;box-shadow:0 14rpx 26rpx rgba(47,128,255,.24),inset 0 4rpx 8rpx rgba(255,255,255,.30)}.user-info{flex:1;min-width:0}.user-name{display:block;font-size:30rpx;line-height:1.35;font-weight:820;color:#1f2a3d;overflow:hidden;text-overflow:ellipsis;white-space:nowrap}.user-detail{display:block;margin-top:6rpx;font-size:23rpx;color:#8d9ab0;overflow:hidden;text-overflow:ellipsis;white-space:nowrap}.user-credit{display:inline-flex;margin-top:8rpx;padding:6rpx 13rpx;border-radius:999rpx;font-size:22rpx;font-weight:760;color:#2f80ff;background:#eaf3ff}.user-actions{flex-shrink:0;display:flex;flex-direction:column;align-items:flex-end;gap:10rpx}.user-status{font-size:22rpx;padding:7rpx 15rpx;border-radius:999rpx;font-weight:760}.user-status.active{color:#22a86e;background:#e9fbf3}.user-status.banned{color:#ec4e58;background:#fff0f1}.action-btns{display:flex;gap:8rpx}.btn-credit,.btn-ban{min-width:66rpx;padding:8rpx 15rpx;border-radius:999rpx;font-size:22rpx;font-weight:760;text-align:center}.btn-credit{background:linear-gradient(145deg,#fff,#eaf3ff);color:#2f80ff}.btn-ban{background:#fff0f1;color:#ec4e58}.btn-unban{background:#e9fbf3;color:#22a86e}.empty{margin-top:80rpx;padding:110rpx 0;text-align:center;color:#8d9ab0;font-size:28rpx;border-radius:32rpx;background:linear-gradient(145deg,rgba(255,255,255,.96),rgba(242,246,252,.90));box-shadow:12rpx 14rpx 28rpx rgba(164,178,202,.18)}
.form-mask{position:fixed;left:0;right:0;top:0;bottom:0;z-index:100;background:rgba(31,42,61,.42);backdrop-filter:blur(6px);-webkit-backdrop-filter:blur(6px)}.form-panel{position:fixed;left:22rpx;right:22rpx;bottom:calc(22rpx + env(safe-area-inset-bottom));z-index:101;overflow:hidden;border-radius:34rpx;background:linear-gradient(145deg,rgba(255,255,255,.98),rgba(239,245,252,.96));border:1rpx solid rgba(255,255,255,.92);box-shadow:0 30rpx 70rpx rgba(31,42,61,.30),inset 0 2rpx 0 rgba(255,255,255,.92);transform:translateY(calc(100% + 80rpx));transition:transform .28s cubic-bezier(.22,.74,.25,1)}.form-show{transform:translateY(0)}.form-header{display:flex;justify-content:space-between;align-items:flex-start;gap:18rpx;padding:28rpx 32rpx 22rpx;border-bottom:1rpx solid rgba(139,154,178,.10)}.form-title{display:block;font-size:32rpx;font-weight:860;color:#1f2a3d}.form-subtitle{display:block;margin-top:8rpx;font-size:23rpx;color:#61708a;line-height:1.5}.form-close{flex-shrink:0;width:48rpx;height:48rpx;display:flex;align-items:center;justify-content:center;border-radius:16rpx;font-size:28rpx;color:#8d9ab0;background:linear-gradient(145deg,#fff,#edf4fc)}.form-body{max-height:58vh;padding:20rpx 32rpx;box-sizing:border-box}.form-row{display:flex;align-items:center;gap:18rpx;min-height:82rpx;border-bottom:1rpx solid rgba(139,154,178,.10)}.form-row.required .form-label:after{content:'*';color:#ec4e58;margin-left:4rpx}.form-label{flex-shrink:0;width:132rpx;font-size:26rpx;color:#61708a;font-weight:700}.form-input{flex:1;min-height:62rpx;padding:10rpx 18rpx;border-radius:18rpx;text-align:right;font-size:26rpx;color:#1f2a3d;background:linear-gradient(145deg,rgba(255,255,255,.92),rgba(239,244,251,.86));box-shadow:inset 5rpx 5rpx 12rpx rgba(164,178,202,.16),inset -5rpx -5rpx 12rpx rgba(255,255,255,.86);box-sizing:border-box}.form-footer{display:flex;gap:18rpx;padding:22rpx 32rpx 30rpx;border-top:1rpx solid rgba(139,154,178,.10)}.form-btn{flex:1;text-align:center;padding:20rpx;border-radius:999rpx;font-size:29rpx;font-weight:800}.btn-cancel{background:linear-gradient(145deg,#fff,#edf4fc);color:#61708a}.btn-submit{background:linear-gradient(135deg,#2f80ff,#39c6df);color:#fff;box-shadow:0 14rpx 28rpx rgba(47,128,255,.24),inset 0 2rpx 0 rgba(255,255,255,.34)}.import-textarea{width:100%;height:330rpx;padding:20rpx;border-radius:22rpx;font-size:25rpx;line-height:1.55;color:#1f2a3d;background:linear-gradient(145deg,rgba(255,255,255,.92),rgba(239,244,251,.86));box-shadow:inset 5rpx 5rpx 12rpx rgba(164,178,202,.16),inset -5rpx -5rpx 12rpx rgba(255,255,255,.86);box-sizing:border-box}.import-helper{display:inline-flex;margin-top:16rpx;padding:10rpx 18rpx;border-radius:999rpx;font-size:24rpx;font-weight:760;color:#2f80ff;background:#eaf3ff}.import-result{margin-top:18rpx;padding:16rpx 18rpx;border-radius:18rpx;font-size:23rpx;line-height:1.55;color:#61708a;white-space:pre-wrap;background:rgba(255,255,255,.62)}
