.container { padding: 20rpx 30rpx 150rpx; background: #f5f7fa; min-height: 100vh; box-sizing: border-box; }
.admin-header { display: flex; justify-content: space-between; align-items: center; padding: 30rpx 0; }
.admin-title { font-size: 40rpx; font-weight: 700; color: #1a1a2e; }
.admin-role { font-size: 24rpx; color: #fff; background: linear-gradient(135deg, #0077ff, #00d4ff); padding: 6rpx 20rpx; border-radius: 20rpx; }
.stats-grid { display: grid; grid-template-columns: 1fr 1fr; gap: 20rpx; margin-bottom: 40rpx; }
.stat-card { background: #fff; border-radius: 16rpx; padding: 30rpx; text-align: center; box-shadow: 0 2rpx 12rpx rgba(0,0,0,0.04); }
.stat-value { display: block; font-size: 48rpx; font-weight: 700; color: #0077ff; }
.stat-label { display: block; font-size: 24rpx; color: #999; margin-top: 8rpx; }
.section-title { font-size: 30rpx; font-weight: 600; color: #333; margin-bottom: 20rpx; }
.pending-list { background: #fff; border-radius: 16rpx; overflow: hidden; }
.pending-item { display: flex; justify-content: space-between; align-items: center; padding: 24rpx 30rpx; border-bottom: 1rpx solid #f0f0f0; }
.pending-item:last-child { border-bottom: none; }
.pending-info { flex: 1; }
.pending-name { display: block; font-size: 28rpx; font-weight: 500; color: #333; }
.pending-room { display: block; font-size: 24rpx; color: #666; margin-top: 4rpx; }
.pending-time { display: block; font-size: 22rpx; color: #999; margin-top: 4rpx; }
.pending-actions { display: flex; gap: 16rpx; flex-shrink: 0; }
.btn-approve { padding: 10rpx 24rpx; background: #52C41A; color: #fff; font-size: 24rpx; border-radius: 8rpx; }
.btn-reject { padding: 10rpx 24rpx; background: #FF4D4F; color: #fff; font-size: 24rpx; border-radius: 8rpx; }
.empty-tip { text-align: center; padding: 60rpx 0; color: #999; font-size: 28rpx; }
