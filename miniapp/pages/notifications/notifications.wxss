@import "../../styles/theme-3d.wxss";

.container {
  background:
    radial-gradient(circle at 90% 8%, rgba(79,213,232,.12), transparent 28%),
    linear-gradient(180deg, #f8fafd 0%, var(--canvas) 100%);
  padding-bottom: calc(132rpx + env(safe-area-inset-bottom));
}

.category-scroll {
  width: 100%;
  white-space: nowrap;
  padding: 16rpx 0 8rpx;
  background: rgba(248,250,253,.92);
  border-bottom: 1rpx solid rgba(255,255,255,.75);
  backdrop-filter: blur(20px);
  -webkit-backdrop-filter: blur(20px);
}

.categories {
  display: flex;
  flex-direction: row;
  padding: 0 18rpx;
  gap: 8rpx;
}

.category-item {
  flex-shrink: 0;
  position: relative;
  padding: 13rpx 19rpx;
  border-radius: 999rpx;
  transition: transform 180ms ease, background 180ms ease, box-shadow 180ms ease;
}

.category-item:active {
  transform: scale(.96);
}

.category-active {
  background: linear-gradient(145deg, #fff, #e7f2ff);
  box-shadow: 7rpx 9rpx 16rpx rgba(147,165,194,.20), -5rpx -5rpx 12rpx rgba(255,255,255,.92), inset 0 2rpx 0 rgba(255,255,255,.84);
}

.category-name {
  font-size: 25rpx;
  font-weight: 640;
  color: var(--ink-muted);
}

.category-active .category-name {
  color: var(--primary);
  font-weight: 760;
}

.category-active::after {
  content: '';
  position: absolute;
  left: 50%;
  bottom: -4rpx;
  width: 23rpx;
  height: 5rpx;
  margin-left: -11rpx;
  border-radius: 5rpx;
  background: linear-gradient(90deg, var(--primary), var(--cyan));
}

.notification-header {
  display: flex;
  justify-content: space-between;
  align-items: center;
  margin: 10rpx 24rpx 0;
  padding: 16rpx 4rpx 10rpx;
}

.unread-text {
  font-size: 24rpx;
  color: var(--ink-muted);
}

.mark-read-btn {
  font-size: 24rpx;
  font-weight: 700;
  color: var(--primary);
}

.notification-list {
  padding: 8rpx 24rpx 28rpx;
}

.notification-item {
  position: relative;
  display: flex;
  margin-bottom: 16rpx;
  padding: 22rpx;
  border-radius: 30rpx;
  background: linear-gradient(145deg, rgba(255,255,255,.98), rgba(246,248,252,.95));
  border: 1rpx solid rgba(255,255,255,.90);
  box-shadow: 12rpx 14rpx 26rpx rgba(154,168,192,.21), -9rpx -9rpx 20rpx rgba(255,255,255,.88), inset 0 2rpx 0 rgba(255,255,255,.88);
  transition: transform 180ms ease, box-shadow 180ms ease;
}

.notification-item:active {
  transform: translateY(3rpx) scale(.985);
  box-shadow: var(--shadow-pressed);
}

.notification-unread::before {
  content: '';
  position: absolute;
  left: 0;
  top: 24rpx;
  bottom: 24rpx;
  width: 6rpx;
  border-radius: 0 6rpx 6rpx 0;
  background: linear-gradient(180deg, var(--primary), var(--cyan));
  box-shadow: 4rpx 0 12rpx rgba(47,128,255,.20);
}

.notification-icon-wrap {
  position: relative;
  flex-shrink: 0;
  width: 72rpx;
  height: 72rpx;
  margin-right: 20rpx;
  display: flex;
  align-items: center;
  justify-content: center;
  border-radius: 24rpx;
  border: 1rpx solid rgba(255,255,255,.88);
  box-shadow: inset 0 3rpx 6rpx rgba(255,255,255,.82), 7rpx 9rpx 16rpx rgba(126,144,174,.18);
}

.notification-icon-type-audit { background: linear-gradient(145deg, #fff4df, #ffdba0); }
.notification-icon-type-reminder { background: linear-gradient(145deg, #e8f5ff, #b9dcff); }
.notification-icon-type-noshow_warning { background: linear-gradient(145deg, #ffe7eb, #ffb8c4); }
.notification-icon-type-credit { background: linear-gradient(145deg, #e5fff5, #bcefd9); }
.notification-icon-type-poster { background: linear-gradient(145deg, #f2ebff, #d5c2ff); }
.notification-icon-type-system { background: linear-gradient(145deg, #f5f8fc, #dfe8f4); }
.notification-icon-type-violation { background: linear-gradient(145deg, #ffe7eb, #ffb8c4); }

.notification-icon-svg {
  width: 31rpx;
  height: 31rpx;
  border-radius: 9rpx;
  box-shadow: inset 0 3rpx 4rpx rgba(255,255,255,.30), 0 6rpx 10rpx rgba(45,70,110,.15);
}

.notification-icon-type-audit .notification-icon-svg { background: linear-gradient(145deg, #f8a63c, #d88615); }
.notification-icon-type-reminder .notification-icon-svg { background: linear-gradient(145deg, #4da5ff, #1767e8); }
.notification-icon-type-noshow_warning .notification-icon-svg,
.notification-icon-type-violation .notification-icon-svg { background: linear-gradient(145deg, #ff7a83, #e94752); }
.notification-icon-type-credit .notification-icon-svg { background: linear-gradient(145deg, #63dfab, #22a86e); }
.notification-icon-type-poster .notification-icon-svg { background: linear-gradient(145deg, #a07bff, #7654d6); }
.notification-icon-type-system .notification-icon-svg { background: linear-gradient(145deg, #9aa6b8, #6a7688); }

.unread-dot {
  position: absolute;
  top: -4rpx;
  right: -4rpx;
  width: 16rpx;
  height: 16rpx;
  border-radius: 50%;
  background: linear-gradient(145deg, #f5b84b, #d48b12);
  border: 3rpx solid #fff;
  box-shadow: 0 0 10rpx rgba(245,184,75,.42);
}

.notification-content {
  flex: 1;
  min-width: 0;
}

.notification-title-row {
  display: flex;
  align-items: flex-start;
  justify-content: space-between;
  gap: 12rpx;
  margin-bottom: 8rpx;
}

.notification-title {
  flex: 1;
  overflow: hidden;
  text-overflow: ellipsis;
  white-space: nowrap;
  font-size: 29rpx;
  line-height: 1.35;
  font-weight: 780;
  color: var(--ink);
}

.notification-time {
  flex-shrink: 0;
  max-width: 205rpx;
  overflow: hidden;
  text-overflow: ellipsis;
  white-space: nowrap;
  font-size: 21rpx;
  color: var(--ink-muted);
}

.notification-body {
  font-size: 25rpx;
  line-height: 1.55;
  color: var(--ink-secondary);
  overflow: hidden;
  text-overflow: ellipsis;
  display: -webkit-box;
  -webkit-line-clamp: 2;
  -webkit-box-orient: vertical;
}

.empty-state,
.loading-state {
  padding: 120rpx 0;
}

.empty-icon-svg {
  width: 112rpx;
  height: 92rpx;
  margin-bottom: 24rpx;
  border-radius: 30rpx;
  background: linear-gradient(145deg, #fdfefe, #dce7f5);
  box-shadow: var(--shadow-soft);
}

.empty-text,
.loading-text {
  font-size: 27rpx;
  color: var(--ink-muted);
}
