.category-scroll {
  width: 100%;
  white-space: nowrap;
  background-color: var(--bg-card);
  border-bottom: 1rpx solid var(--border-color);
}

.categories {
  display: flex;
  flex-direction: row;
  padding: 0 8rpx;
}

.category-item {
  padding: 20rpx 16rpx;
  flex-shrink: 0;
  position: relative;
}

.category-active .category-name {
  color: var(--primary);
  font-weight: 700;
}

.category-active::after {
  content: '';
  position: absolute;
  bottom: 8rpx;
  left: 50%;
  transform: translateX(-50%);
  width: 32rpx;
  height: 6rpx;
  background: var(--accent);
  border-radius: 3rpx;
}

.category-name {
  font-size: 26rpx;
  color: var(--text-hint);
}

.notification-header {
  display: flex;
  flex-direction: row;
  justify-content: space-between;
  align-items: center;
  padding: 16rpx 24rpx;
  background-color: var(--bg-card);
}

.unread-text {
  font-size: 24rpx;
  color: var(--text-hint);
}

.mark-read-btn {
  font-size: 24rpx;
  color: var(--primary);
}

.notification-list {
  padding: 0;
}

.notification-item {
  display: flex;
  flex-direction: row;
  padding: 24rpx;
  background-color: var(--bg-card);
  border-bottom: 1rpx solid #F5F5F5;
  transition: background-color 0.2s ease;
}

.notification-item:active {
  background-color: var(--accent-light);
}

.notification-unread {
  background-color: #FAFCFF;
}

.notification-icon-wrap {
  position: relative;
  width: 72rpx;
  height: 72rpx;
  border-radius: 50%;
  margin-right: 20rpx;
  flex-shrink: 0;
  display: flex;
  align-items: center;
  justify-content: center;
  border: 2rpx solid rgba(196, 148, 58, 0.15);
}

.notification-icon-type-audit { background-color: var(--warning-light); }
.notification-icon-type-reminder { background-color: var(--primary-light); }
.notification-icon-type-noshow_warning { background-color: var(--danger-light); }
.notification-icon-type-credit { background-color: var(--success-light); }
.notification-icon-type-poster { background-color: #F9F0FF; }
.notification-icon-type-system { background-color: #F0F0F0; }
.notification-icon-type-violation { background-color: var(--danger-light); }

.notification-icon-svg {
  width: 32rpx;
  height: 32rpx;
  border-radius: 4rpx;
}

.notification-icon-type-audit .notification-icon-svg { background: var(--warning); }
.notification-icon-type-reminder .notification-icon-svg { background: var(--primary); }
.notification-icon-type-noshow_warning .notification-icon-svg { background: var(--danger); }
.notification-icon-type-credit .notification-icon-svg { background: var(--success); }
.notification-icon-type-poster .notification-icon-svg { background: #722ED1; }
.notification-icon-type-system .notification-icon-svg { background: var(--text-hint); }
.notification-icon-type-violation .notification-icon-svg { background: var(--danger); }

.unread-dot {
  position: absolute;
  top: 0;
  right: 0;
  width: 16rpx;
  height: 16rpx;
  border-radius: 50%;
  background-color: var(--accent);
  border: 2rpx solid #FFFFFF;
  box-shadow: 0 0 8rpx rgba(196, 148, 58, 0.4);
}

.notification-content {
  flex: 1;
  min-width: 0;
}

.notification-title-row {
  display: flex;
  flex-direction: row;
  justify-content: space-between;
  align-items: center;
  margin-bottom: 8rpx;
}

.notification-title {
  font-size: 28rpx;
  font-weight: 700;
  color: var(--text-primary);
  flex: 1;
  overflow: hidden;
  text-overflow: ellipsis;
  white-space: nowrap;
}

.notification-time {
  font-size: 22rpx;
  color: var(--text-hint);
  flex-shrink: 0;
  margin-left: 16rpx;
}

.notification-body {
  font-size: 26rpx;
  color: var(--text-secondary);
  line-height: 1.5;
  overflow: hidden;
  text-overflow: ellipsis;
  display: -webkit-box;
  -webkit-line-clamp: 2;
  -webkit-box-orient: vertical;
}

.empty-state {
  display: flex;
  flex-direction: column;
  align-items: center;
  justify-content: center;
  padding: 120rpx 0;
  animation: fadeIn 0.3s ease-out both;
}

.empty-icon-svg {
  width: 120rpx;
  height: 120rpx;
  background: var(--border-color);
  border-radius: 50%;
  margin-bottom: 24rpx;
}

.empty-text {
  font-size: 28rpx;
  color: var(--text-hint);
}

.loading-state {
  display: flex;
  flex-direction: column;
  align-items: center;
  justify-content: center;
  padding: 120rpx 0;
  animation: fadeIn 0.3s ease-out both;
}

.loading-spinner {
  width: 48rpx;
  height: 48rpx;
  border: 4rpx solid #E8E8E8;
  border-top-color: var(--primary);
  border-radius: 50%;
  animation: spin 0.8s linear infinite;
  margin-bottom: 16rpx;
}

.loading-text {
  font-size: 26rpx;
  color: var(--text-hint);
}
