.container {
  min-height: 100vh;
  padding: 22rpx 0 calc(128rpx + env(safe-area-inset-bottom));
  background:
    radial-gradient(circle at 88% 2%, rgba(79, 213, 232, 0.16), transparent 30%),
    radial-gradient(circle at 0% 26%, rgba(47, 128, 255, 0.10), transparent 28%),
    linear-gradient(180deg, #f8fbff 0%, #f0f3f8 48%, #edf1f7 100%);
}

.confirm-card {
  position: relative;
  margin: 0 24rpx 24rpx;
  overflow: hidden;
  border-radius: 34rpx;
  background:
    radial-gradient(circle at 88% 2%, rgba(79,213,232,0.13), transparent 30%),
    linear-gradient(145deg, rgba(255,255,255,0.98), rgba(242,246,252,0.95));
  border: 1rpx solid rgba(255,255,255,0.94);
  box-shadow: 16rpx 18rpx 38rpx rgba(164,178,202,0.24), -10rpx -10rpx 24rpx rgba(255,255,255,0.88), inset 0 2rpx 0 rgba(255,255,255,0.92);
  animation: confirmRise 380ms cubic-bezier(.22,.74,.25,1) both;
}

.confirm-card::before {
  content: '';
  position: absolute;
  right: -70rpx;
  top: -74rpx;
  width: 220rpx;
  height: 220rpx;
  border-radius: 50%;
  background: radial-gradient(circle, rgba(79,213,232,0.24), rgba(79,213,232,0));
}

.confirm-section {
  position: relative;
  padding: 28rpx;
  border-bottom: 1rpx solid rgba(139,154,178,0.10);
}

.confirm-section:last-of-type {
  border-bottom: none;
}

.confirm-section-title {
  display: block;
  margin-bottom: 20rpx;
  font-size: 31rpx;
  line-height: 1.25;
  font-weight: 850;
  color: #1f2a3d;
  letter-spacing: 0.6rpx;
}

.summary-section {
  padding-top: 32rpx;
  background:
    radial-gradient(circle at 86% 4%, rgba(79,213,232,0.18), transparent 34%),
    linear-gradient(145deg, rgba(255,255,255,0.98), rgba(232,242,253,0.86));
}

.summary-room {
  display: flex;
  flex-direction: column;
  gap: 9rpx;
}

.summary-name {
  font-size: 39rpx;
  line-height: 1.22;
  font-weight: 880;
  color: #2f80ff;
  text-shadow: 0 6rpx 12rpx rgba(47,128,255,0.12);
}

.summary-time {
  font-size: 26rpx;
  line-height: 1.45;
  color: #61708a;
}

.summary-grid {
  display: grid;
  grid-template-columns: repeat(2, 1fr);
  gap: 18rpx;
  margin-top: 24rpx;
}

.summary-item {
  min-height: 106rpx;
  padding: 20rpx;
  border-radius: 28rpx;
  background: linear-gradient(145deg, rgba(255,255,255,0.96), rgba(236,244,253,0.90));
  border: 1rpx solid rgba(255,255,255,0.88);
  box-shadow: 10rpx 12rpx 24rpx rgba(164,178,202,0.16), -8rpx -8rpx 18rpx rgba(255,255,255,0.82), inset 0 2rpx 0 rgba(255,255,255,0.86);
  box-sizing: border-box;
}

.summary-label {
  display: block;
  font-size: 22rpx;
  color: #8d9ab0;
}

.summary-value {
  display: block;
  margin-top: 8rpx;
  font-size: 29rpx;
  color: #1f2a3d;
  font-weight: 800;
}

.confirm-row,
.confirm-input-row,
.confirm-switch-row {
  display: flex;
  flex-direction: row;
  justify-content: space-between;
  align-items: center;
  min-height: 88rpx;
  border-top: 1rpx solid rgba(139,154,178,0.08);
}

.confirm-row:first-of-type,
.confirm-input-row:first-of-type,
.confirm-switch-row:first-of-type {
  border-top: none;
}

.confirm-label {
  flex-shrink: 0;
  width: 182rpx;
  font-size: 27rpx;
  line-height: 1.45;
  color: #61708a;
}

.required-star {
  color: #ff5f68;
  margin-right: 5rpx;
  font-weight: 800;
}

.confirm-value {
  flex: 1;
  font-size: 27rpx;
  line-height: 1.45;
  color: #1f2a3d;
  text-align: right;
  font-weight: 720;
  word-break: break-all;
}

.placeholder {
  color: #9aa6b8;
  font-weight: 500;
}

.confirm-input {
  flex: 1;
  min-height: 62rpx;
  padding: 10rpx 18rpx;
  border-radius: 18rpx;
  text-align: right;
  font-size: 27rpx;
  color: #1f2a3d;
  background: linear-gradient(145deg, rgba(255,255,255,0.92), rgba(239,244,251,0.86));
  box-shadow: inset 5rpx 5rpx 12rpx rgba(164,178,202,0.16), inset -5rpx -5rpx 12rpx rgba(255,255,255,0.86);
  box-sizing: border-box;
}

.confirm-agree {
  position: relative;
  display: flex;
  flex-direction: row;
  align-items: center;
  padding: 26rpx 28rpx 30rpx;
  border-top: 1rpx solid rgba(139,154,178,0.10);
  background: rgba(255,255,255,0.48);
}

.agree-check {
  display: flex;
  flex-direction: row;
  align-items: center;
  gap: 12rpx;
}

.checkbox {
  position: relative;
  width: 38rpx;
  height: 38rpx;
  border: 2rpx solid #cdd7e5;
  border-radius: 12rpx;
  background: #ffffff;
  box-shadow: inset 0 2rpx 0 rgba(255,255,255,0.86), 5rpx 6rpx 12rpx rgba(164,178,202,0.14);
}

.checkbox-checked {
  background: linear-gradient(135deg, #2f80ff, #39c6df);
  border-color: transparent;
  box-shadow: 0 8rpx 16rpx rgba(47,128,255,0.20), inset 0 2rpx 0 rgba(255,255,255,0.36);
}

.checkbox-checked::after {
  content: '';
  position: absolute;
  left: 9rpx;
  top: 10rpx;
  width: 17rpx;
  height: 9rpx;
  border-left: 4rpx solid #fff;
  border-bottom: 4rpx solid #fff;
  transform: rotate(-45deg);
}

.agree-text {
  font-size: 26rpx;
  color: #61708a;
}

.agree-link {
  margin-left: 5rpx;
  font-size: 26rpx;
  color: #2f80ff;
  font-weight: 800;
}

.submit-btn {
  position: fixed;
  left: 24rpx;
  right: 24rpx;
  bottom: calc(24rpx + env(safe-area-inset-bottom));
  z-index: 20;
  padding: 25rpx 28rpx;
  text-align: center;
  border-radius: 999rpx;
  font-size: 32rpx;
  font-weight: 850;
  letter-spacing: 1rpx;
  box-sizing: border-box;
  border: 1rpx solid rgba(255,255,255,0.45);
  transition: transform 160ms ease, opacity 160ms ease, box-shadow 160ms ease;
}

.submit-btn:active {
  transform: translateY(3rpx) scale(0.98);
  opacity: 0.92;
}

.btn-primary {
  color: #ffffff;
  background: linear-gradient(135deg, #2f80ff 0%, #39c6df 100%);
  box-shadow: 0 16rpx 32rpx rgba(47,128,255,0.30), inset 0 2rpx 0 rgba(255,255,255,0.36);
}

.btn-disabled {
  color: #ffffff;
  background: linear-gradient(135deg, #b4c3d7, #c6d2df);
  box-shadow: 0 10rpx 22rpx rgba(118,134,160,0.16), inset 0 2rpx 0 rgba(255,255,255,0.28);
}

@keyframes confirmRise {
  from { opacity: 0; transform: translateY(24rpx) scale(0.985); }
  to { opacity: 1; transform: translateY(0) scale(1); }
}
