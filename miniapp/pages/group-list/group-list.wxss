.container{min-height:100vh;padding:24rpx 24rpx calc(120rpx + env(safe-area-inset-bottom));box-sizing:border-box;background:radial-gradient(circle at 90% 4%,rgba(79,213,232,.16),transparent 30%),radial-gradient(circle at 2% 24%,rgba(47,128,255,.10),transparent 28%),linear-gradient(180deg,#f8fbff 0%,#f0f3f8 48%,#edf1f7 100%)}
.header{display:flex;align-items:flex-start;justify-content:space-between;gap:18rpx;padding:10rpx 4rpx 22rpx}.title{display:block;font-size:40rpx;line-height:1.22;font-weight:880;color:#1f2a3d}.subtitle{display:block;margin-top:9rpx;color:#61708a;font-size:24rpx;line-height:1.5}.create-btn{flex-shrink:0;padding:15rpx 26rpx;border-radius:999rpx;color:#fff;font-size:25rpx;font-weight:800;background:linear-gradient(135deg,#2f80ff,#39c6df);box-shadow:0 14rpx 26rpx rgba(47,128,255,.24),inset 0 2rpx 0 rgba(255,255,255,.34)}
.tabs{display:flex;gap:14rpx;margin-bottom:20rpx}.tab{flex:1;text-align:center;padding:15rpx 10rpx;border-radius:999rpx;font-size:25rpx;font-weight:760;color:#8d9ab0;background:linear-gradient(145deg,rgba(255,255,255,.96),rgba(236,242,250,.88));border:1rpx solid rgba(255,255,255,.88);box-shadow:8rpx 10rpx 20rpx rgba(154,170,196,.16),-6rpx -6rpx 16rpx rgba(255,255,255,.84);box-sizing:border-box}.tab.active{color:#fff;background:linear-gradient(135deg,#2f80ff,#39c6df);box-shadow:0 14rpx 26rpx rgba(47,128,255,.23),inset 0 2rpx 0 rgba(255,255,255,.34)}
.group-item{position:relative;margin-bottom:18rpx;padding:26rpx 28rpx;overflow:hidden;border-radius:32rpx;background:radial-gradient(circle at 92% 0%,rgba(79,213,232,.12),transparent 32%),linear-gradient(145deg,rgba(255,255,255,.99),rgba(242,246,252,.95));border:1rpx solid rgba(255,255,255,.94);box-shadow:14rpx 16rpx 34rpx rgba(154,170,196,.22),-10rpx -10rpx 24rpx rgba(255,255,255,.86),inset 0 2rpx 0 rgba(255,255,255,.92);box-sizing:border-box}.group-item:before{content:'';position:absolute;left:0;top:28rpx;bottom:28rpx;width:7rpx;border-radius:0 8rpx 8rpx 0;background:linear-gradient(180deg,#2f80ff,#39c6df)}.item-header{display:flex;justify-content:space-between;align-items:flex-start;gap:14rpx}.item-title-wrap{flex:1;min-width:0}.item-title{display:block;font-size:31rpx;line-height:1.35;font-weight:850;color:#1f2a3d;overflow:hidden;text-overflow:ellipsis;white-space:nowrap}.item-room{display:block;margin-top:6rpx;font-size:23rpx;color:#8d9ab0}.status-tag{flex-shrink:0;padding:7rpx 15rpx;border-radius:999rpx;font-size:22rpx;font-weight:760}.status-open{color:#22a86e;background:#e9fbf3}.status-full{color:#f59b28;background:#fff6e8}.status-submitted{color:#2f80ff;background:#eaf3ff}.status-cancelled,.status-closed{color:#ec4e58;background:#fff0f1}.meta-grid{display:grid;grid-template-columns:repeat(3,1fr);gap:10rpx;margin-top:18rpx}.meta-pill{min-width:0;padding:13rpx 10rpx;border-radius:20rpx;text-align:center;background:rgba(255,255,255,.56);box-shadow:inset 4rpx 4rpx 10rpx rgba(164,178,202,.10),inset -4rpx -4rpx 10rpx rgba(255,255,255,.78)}.meta-label{display:block;font-size:20rpx;color:#9aa6b8}.meta-value{display:block;margin-top:5rpx;font-size:22rpx;font-weight:760;color:#1f2a3d;overflow:hidden;text-overflow:ellipsis;white-space:nowrap}.member-row{display:flex;align-items:center;gap:18rpx;margin-top:18rpx}.member-copy{flex-shrink:0}.member-count{display:block;font-size:30rpx;font-weight:850;color:#2f80ff}.member-label{display:block;font-size:20rpx;color:#8d9ab0}.progress{flex:1;height:18rpx;overflow:hidden;border-radius:999rpx;background:#e4ebf5;box-shadow:inset 4rpx 4rpx 8rpx rgba(164,178,202,.20),inset -4rpx -4rpx 8rpx rgba(255,255,255,.86)}.progress-bar{height:100%;border-radius:999rpx;background:linear-gradient(90deg,#2f80ff,#39c6df)}.desc{display:block;margin-top:14rpx;padding:14rpx 16rpx;border-radius:18rpx;font-size:24rpx;line-height:1.55;color:#61708a;background:rgba(255,255,255,.54)}.item-footer{display:flex;justify-content:flex-end;align-items:center;gap:8rpx;margin-top:16rpx;color:#2f80ff;font-size:24rpx;font-weight:780}.arrow{width:11rpx;height:11rpx;border-top:3rpx solid currentColor;border-right:3rpx solid currentColor;transform:rotate(45deg)}
.empty,.loading{margin-top:80rpx;padding:96rpx 30rpx;text-align:center;color:#8d9ab0;border-radius:32rpx;background:linear-gradient(145deg,rgba(255,255,255,.96),rgba(242,246,252,.90));box-shadow:12rpx 14rpx 28rpx rgba(164,178,202,.18)}.empty-icon{width:86rpx;height:86rpx;margin:0 auto 20rpx;border-radius:30rpx;background:linear-gradient(145deg,#e8f5ff,#b9dcff);box-shadow:inset 0 4rpx 8rpx rgba(255,255,255,.76),8rpx 10rpx 18rpx rgba(126,144,174,.18)}.empty-title{display:block;font-size:30rpx;font-weight:820;color:#1f2a3d}.empty-hint{display:block;margin-top:10rpx;font-size:24rpx;line-height:1.6;color:#8d9ab0}.empty-btn{display:inline-flex;margin-top:24rpx;padding:15rpx 28rpx;border-radius:999rpx;color:#fff;font-size:26rpx;font-weight:800;background:linear-gradient(135deg,#2f80ff,#39c6df)}
