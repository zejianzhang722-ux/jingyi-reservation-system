.container {
  min-height: 100vh;
  padding: 24rpx 24rpx calc(140rpx + env(safe-area-inset-bottom));
  box-sizing: border-box;
  background:
    radial-gradient(circle at 90% 4%, rgba(79,213,232,0.15), transparent 30%),
    radial-gradient(circle at 2% 24%, rgba(47,128,255,0.10), transparent 28%),
    linear-gradient(180deg, #f8fbff 0%, #f0f3f8 48%, #edf1f7 100%);
}

.header {
  padding: 10rpx 0 22rpx;
}

.title {
  display: block;
  margin-bottom: 18rpx;
  font-size: 40rpx;
  line-height: 1.22;
  font-weight: 880;
  color: #1f2a3d;
  letter-spacing: 0.6rpx;
}

.search-bar {
  position: relative;
  display: flex;
  align-items: center;
  min-height: 82rpx;
  padding: 0 24rpx;
  border-radius: 999rpx;
  background: linear-gradient(145deg, rgba(255,255,255,0.98), rgba(238,244,252,0.92));
  border: 1rpx solid rgba(255,255,255,0.92);
  box-shadow: 12rpx 14rpx 28rpx rgba(154,170,196,0.20), -8rpx -8rpx 20rpx rgba(255,255,255,0.88), inset 0 2rpx 0 rgba(255,255,255,0.88);
  box-sizing: border-box;
}

.search-bar::before {
  content: '';
  width: 30rpx;
  height: 30rpx;
  margin-right: 14rpx;
  border: 4rpx solid #2f80ff;
  border-radius: 50%;
  box-sizing: border-box;
}

.search-bar::after {
  content: '';
  position: absolute;
  left: 49rpx;
  top: 48rpx;
  width: 16rpx;
  height: 4rpx;
  border-radius: 4rpx;
  background: #2f80ff;
  transform: rotate(45deg);
}

.search-input {
  flex: 1;
  min-height: 72rpx;
  font-size: 27rpx;
  color: #1f2a3d;
}

.filter-tabs {
  display: flex;
  gap: 14rpx;
  flex-wrap: wrap;
  margin-bottom: 22rpx;
}

.tab {
  padding: 13rpx 24rpx;
  font-size: 24rpx;
  line-height: 1.25;
  font-weight: 740;
  color: #8d9ab0;
  background: linear-gradient(145deg, rgba(255,255,255,0.95), rgba(236,242,250,0.86));
  border-radius: 999rpx;
  border: 1rpx solid rgba(255,255,255,0.86);
  box-shadow: 7rpx 9rpx 18rpx rgba(154,170,196,0.16), -6rpx -6rpx 14rpx rgba(255,255,255,0.84);
  transition: transform 160ms ease, box-shadow 160ms ease;
}

.tab:active {
  transform: scale(0.96);
  box-shadow: inset 5rpx 5rpx 12rpx rgba(164,178,202,0.18), inset -5rpx -5rpx 12rpx rgba(255,255,255,0.82);
}

.tab.active {
  color: #ffffff;
  background: linear-gradient(135deg, #2f80ff, #39c6df);
  box-shadow: 0 14rpx 26rpx rgba(47,128,255,0.23), inset 0 2rpx 0 rgba(255,255,255,0.34);
}

.reservation-list {
  margin-top: 10rpx;
}

.reservation-item {
  position: relative;
  margin-bottom: 18rpx;
  padding: 26rpx 28rpx;
  overflow: hidden;
  border-radius: 32rpx;
  background:
    radial-gradient(circle at 92% 0%, rgba(79,213,232,0.12), transparent 30%),
    linear-gradient(145deg, rgba(255,255,255,0.99), rgba(242,246,252,0.95));
  border: 1rpx solid rgba(255,255,255,0.94);
  box-shadow: 14rpx 16rpx 34rpx rgba(154,170,196,0.22), -10rpx -10rpx 24rpx rgba(255,255,255,0.86), inset 0 2rpx 0 rgba(255,255,255,0.92);
  transition: transform 160ms ease, box-shadow 160ms ease;
  box-sizing: border-box;
}

.reservation-item::before {
  content: '';
  position: absolute;
  left: 0;
  top: 26rpx;
  bottom: 26rpx;
  width: 7rpx;
  border-radius: 0 8rpx 8rpx 0;
  background: linear-gradient(180deg, #2f80ff, #39c6df);
  box-shadow: 4rpx 0 14rpx rgba(47,128,255,0.20);
}

.reservation-item:active {
  transform: translateY(3rpx) scale(0.985);
}

.item-top {
  display: flex;
  justify-content: space-between;
  align-items: center;
  gap: 18rpx;
  margin-bottom: 14rpx;
}

.item-user {
  flex: 1;
  font-size: 30rpx;
  line-height: 1.3;
  font-weight: 820;
  color: #1f2a3d;
}

.item-status {
  flex-shrink: 0;
  padding: 7rpx 17rpx;
  border-radius: 999rpx;
  font-size: 22rpx;
  font-weight: 760;
  border: 1rpx solid rgba(255,255,255,0.72);
  box-shadow: inset 0 2rpx 0 rgba(255,255,255,0.72), 0 8rpx 16rpx rgba(117,132,161,0.12);
}

.status-pending,
.status-counselor_pending { color: #d88a1c; background: #fff3dc; }
.status-approved { color: #25a96a; background: #e9fbf3; }
.status-rejected,
.status-noshow { color: #ec4e58; background: #fff0f1; }
.status-checked_in,
.status-using { color: #2f80ff; background: #e8f3ff; }
.status-completed { color: #77869b; background: #eef2f7; }
.status-cancelled { color: #a2acbb; background: #f0f2f6; }

.item-info {
  padding: 12rpx 18rpx;
  border-radius: 22rpx;
  background: rgba(255,255,255,0.48);
  box-shadow: inset 4rpx 4rpx 10rpx rgba(164,178,202,0.10), inset -4rpx -4rpx 10rpx rgba(255,255,255,0.78);
}

.info-row {
  display: block;
  font-size: 25rpx;
  color: #61708a;
  line-height: 1.78;
}

.item-actions {
  display: flex;
  gap: 16rpx;
  margin-top: 18rpx;
  justify-content: flex-end;
}

.btn-approve,
.btn-reject {
  min-width: 116rpx;
  padding: 13rpx 28rpx;
  color: #ffffff;
  font-size: 24rpx;
  font-weight: 760;
  text-align: center;
  border-radius: 999rpx;
  box-shadow: 0 9rpx 18rpx rgba(45,70,110,0.14), inset 0 2rpx 0 rgba(255,255,255,0.30);
  transition: transform 160ms ease, opacity 160ms ease;
}

.btn-approve:active,
.btn-reject:active {
  transform: scale(0.96);
  opacity: 0.90;
}

.btn-approve { background: linear-gradient(145deg, #63dfab, #22a86e); }
.btn-reject { background: linear-gradient(145deg, #ff7a83, #e94752); }

.empty {
  margin-top: 80rpx;
  padding: 110rpx 0;
  text-align: center;
  color: #8d9ab0;
  font-size: 28rpx;
  border-radius: 32rpx;
  background: linear-gradient(145deg, rgba(255,255,255,0.96), rgba(242,246,252,0.90));
  border: 1rpx solid rgba(255,255,255,0.88);
  box-shadow: 12rpx 14rpx 28rpx rgba(164,178,202,0.18), -8rpx -8rpx 18rpx rgba(255,255,255,0.80);
}

.load-more {
  margin: 24rpx auto 0;
  width: 260rpx;
  padding: 18rpx 0;
  text-align: center;
  color: #2f80ff;
  font-size: 26rpx;
  font-weight: 760;
  border-radius: 999rpx;
  background: linear-gradient(145deg, #ffffff, #edf4fc);
  box-shadow: 8rpx 10rpx 20rpx rgba(164,178,202,0.16), -6rpx -6rpx 16rpx rgba(255,255,255,0.86), inset 0 2rpx 0 rgba(255,255,255,0.84);
}
