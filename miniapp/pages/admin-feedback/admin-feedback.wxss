.container {
  min-height: 100vh;
  padding: 24rpx 24rpx calc(120rpx + env(safe-area-inset-bottom));
  box-sizing: border-box;
  background:
    radial-gradient(circle at 90% 4%, rgba(79,213,232,0.16), transparent 30%),
    radial-gradient(circle at 2% 24%, rgba(47,128,255,0.10), transparent 28%),
    linear-gradient(180deg, #f8fbff 0%, #f0f3f8 48%, #edf1f7 100%);
}

.header {
  padding: 10rpx 0 22rpx;
}

.title {
  display: block;
  margin-bottom: 18rpx;
  font-size: 40rpx;
  line-height: 1.22;
  font-weight: 880;
  color: #1f2a3d;
  letter-spacing: 0.6rpx;
}

.filter-tabs {
  display: flex;
  gap: 14rpx;
}

.tab {
  padding: 14rpx 26rpx;
  font-size: 24rpx;
  font-weight: 760;
  color: #8d9ab0;
  background: linear-gradient(145deg, rgba(255,255,255,0.96), rgba(236,242,250,0.88));
  border-radius: 999rpx;
  border: 1rpx solid rgba(255,255,255,0.88);
  box-shadow: 8rpx 10rpx 20rpx rgba(154,170,196,0.16), -6rpx -6rpx 16rpx rgba(255,255,255,0.84);
}

.tab.active {
  color: #ffffff;
  background: linear-gradient(135deg, #2f80ff, #39c6df);
  box-shadow: 0 14rpx 26rpx rgba(47,128,255,0.23), inset 0 2rpx 0 rgba(255,255,255,0.34);
}

.feedback-list {
  margin-top: 10rpx;
}

.feedback-item {
  position: relative;
  margin-bottom: 18rpx;
  padding: 26rpx 28rpx;
  overflow: hidden;
  border-radius: 32rpx;
  background:
    radial-gradient(circle at 92% 0%, rgba(79,213,232,0.12), transparent 32%),
    linear-gradient(145deg, rgba(255,255,255,0.99), rgba(242,246,252,0.95));
  border: 1rpx solid rgba(255,255,255,0.94);
  box-shadow: 14rpx 16rpx 34rpx rgba(154,170,196,0.22), -10rpx -10rpx 24rpx rgba(255,255,255,0.86), inset 0 2rpx 0 rgba(255,255,255,0.92);
  box-sizing: border-box;
}

.feedback-item::before {
  content: '';
  position: absolute;
  left: 0;
  top: 28rpx;
  bottom: 28rpx;
  width: 7rpx;
  border-radius: 0 8rpx 8rpx 0;
  background: linear-gradient(180deg, #2f80ff, #39c6df);
  box-shadow: 4rpx 0 14rpx rgba(47,128,255,0.20);
}

.item-header {
  display: flex;
  align-items: center;
  gap: 12rpx;
  margin-bottom: 14rpx;
}

.item-user {
  flex: 1;
  min-width: 0;
  font-size: 30rpx;
  line-height: 1.35;
  font-weight: 820;
  color: #1f2a3d;
  overflow: hidden;
  text-overflow: ellipsis;
  white-space: nowrap;
}

.item-type,
.item-status {
  flex-shrink: 0;
  font-size: 22rpx;
  padding: 7rpx 14rpx;
  border-radius: 999rpx;
  font-weight: 760;
  box-shadow: inset 0 2rpx 0 rgba(255,255,255,0.72), 0 8rpx 16rpx rgba(117,132,161,0.10);
}

.item-type {
  color: #2f80ff;
  background: #eaf3ff;
}

.item-status.pending {
  color: #f59b28;
  background: #fff6e8;
}

.item-status.resolved {
  color: #22a86e;
  background: #e9fbf3;
}

.item-content {
  display: block;
  margin-bottom: 16rpx;
  padding: 18rpx 20rpx;
  border-radius: 22rpx;
  font-size: 26rpx;
  color: #61708a;
  line-height: 1.7;
  background: rgba(255,255,255,0.52);
  box-shadow: inset 4rpx 4rpx 10rpx rgba(164,178,202,0.10), inset -4rpx -4rpx 10rpx rgba(255,255,255,0.78);
}

.item-reply {
  margin-bottom: 16rpx;
  padding: 18rpx 20rpx;
  border-radius: 22rpx;
  background: #eaf3ff;
}

.reply-label {
  font-size: 25rpx;
  font-weight: 780;
  color: #2f80ff;
}

.reply-content {
  font-size: 25rpx;
  color: #61708a;
  line-height: 1.7;
}

.item-footer {
  display: flex;
  justify-content: space-between;
  align-items: center;
  gap: 18rpx;
}

.item-time {
  flex: 1;
  font-size: 22rpx;
  color: #9aa6b8;
}

.item-actions {
  display: flex;
  gap: 12rpx;
}

.btn-reply,
.btn-resolve {
  padding: 10rpx 18rpx;
  border-radius: 999rpx;
  font-size: 24rpx;
  font-weight: 760;
  text-align: center;
}

.btn-reply {
  color: #2f80ff;
  background: #eaf3ff;
}

.btn-resolve {
  color: #22a86e;
  background: #e9fbf3;
}

.reply-form {
  margin-top: 18rpx;
  padding: 18rpx;
  border-radius: 26rpx;
  background: rgba(255,255,255,0.56);
  box-shadow: inset 5rpx 5rpx 12rpx rgba(164,178,202,0.10), inset -5rpx -5rpx 12rpx rgba(255,255,255,0.82);
}

.reply-input {
  width: 100%;
  height: 160rpx;
  padding: 18rpx;
  border-radius: 22rpx;
  font-size: 26rpx;
  line-height: 1.55;
  color: #1f2a3d;
  background: linear-gradient(145deg, rgba(255,255,255,0.92), rgba(239,244,251,0.86));
  box-shadow: inset 5rpx 5rpx 12rpx rgba(164,178,202,0.16), inset -5rpx -5rpx 12rpx rgba(255,255,255,0.86);
  box-sizing: border-box;
}

.reply-btns {
  display: flex;
  gap: 14rpx;
  margin-top: 16rpx;
}

.reply-btn {
  flex: 1;
  padding: 16rpx 0;
  border-radius: 999rpx;
  font-size: 25rpx;
  font-weight: 780;
  text-align: center;
}

.btn-cancel-reply {
  color: #61708a;
  background: linear-gradient(145deg, #ffffff, #edf4fc);
}

.btn-submit-reply {
  color: #ffffff;
  background: linear-gradient(135deg, #2f80ff, #39c6df);
  box-shadow: 0 12rpx 24rpx rgba(47,128,255,0.22), inset 0 2rpx 0 rgba(255,255,255,0.34);
}

.empty {
  margin-top: 80rpx;
  padding: 110rpx 0;
  text-align: center;
  color: #8d9ab0;
  font-size: 28rpx;
  border-radius: 32rpx;
  background: linear-gradient(145deg, rgba(255,255,255,0.96), rgba(242,246,252,0.90));
  border: 1rpx solid rgba(255,255,255,0.88);
  box-shadow: 12rpx 14rpx 28rpx rgba(164,178,202,0.18), -8rpx -8rpx 18rpx rgba(255,255,255,0.80);
}
