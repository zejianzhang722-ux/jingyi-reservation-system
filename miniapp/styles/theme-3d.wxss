page {
  --primary: #2f80ff;
  --primary-deep: #1767e8;
  --primary-soft: #eaf3ff;
  --cyan: #4fd5e8;
  --cyan-soft: #e3fbff;
  --mint: #4ccf9a;
  --gold: #f5b84b;
  --danger: #ff5f68;
  --warning: #f8a63c;
  --success: #39bf78;
  --ink: #1f2a3d;
  --ink-secondary: #61708a;
  --ink-muted: #9aa6b8;
  --canvas: #f1f3f7;
  --canvas-deep: #e9edf4;
  --surface: #fbfcfe;
  --surface-soft: #f6f8fb;
  --surface-glass: rgba(255, 255, 255, 0.78);
  --line: rgba(139, 154, 178, 0.14);
  --radius-sm: 16rpx;
  --radius-md: 24rpx;
  --radius-lg: 32rpx;
  --radius-xl: 44rpx;
  --shadow-soft: 14rpx 14rpx 30rpx rgba(174, 184, 202, 0.30), -12rpx -12rpx 28rpx rgba(255, 255, 255, 0.92);
  --shadow-float: 0 24rpx 48rpx rgba(70, 92, 130, 0.15), inset 0 2rpx 0 rgba(255, 255, 255, 0.88);
  --shadow-pressed: inset 8rpx 8rpx 18rpx rgba(174, 184, 202, 0.24), inset -8rpx -8rpx 18rpx rgba(255, 255, 255, 0.90);
  --shadow-blue: 0 18rpx 32rpx rgba(47, 128, 255, 0.28), inset 0 2rpx 0 rgba(255, 255, 255, 0.38);
  color: var(--ink);
  background: var(--canvas);
  font-family: -apple-system, BlinkMacSystemFont, "PingFang SC", "Microsoft YaHei", sans-serif;
}

@keyframes uiRise {
  from { opacity: 0; transform: translateY(24rpx) scale(0.985); }
  to { opacity: 1; transform: translateY(0) scale(1); }
}

@keyframes uiFloat {
  0%, 100% { transform: translate3d(0, 0, 0); }
  50% { transform: translate3d(0, -12rpx, 0); }
}

@keyframes uiGlow {
  0%, 100% { opacity: 0.50; transform: scale(0.96); }
  50% { opacity: 0.88; transform: scale(1.05); }
}

@keyframes uiPulse {
  0%, 100% { box-shadow: 0 0 0 0 rgba(79, 213, 232, 0.26); }
  50% { box-shadow: 0 0 0 16rpx rgba(79, 213, 232, 0); }
}

.ui-page {
  min-height: 100vh;
  background:
    radial-gradient(circle at 90% 5%, rgba(79, 213, 232, 0.13), transparent 30%),
    radial-gradient(circle at 2% 28%, rgba(47, 128, 255, 0.10), transparent 28%),
    linear-gradient(180deg, #f7f9fc 0%, var(--canvas) 42%, #eef1f6 100%);
}

.ui-card {
  background: linear-gradient(145deg, rgba(255,255,255,0.96), rgba(246,248,252,0.94));
  border: 1rpx solid rgba(255,255,255,0.90);
  border-radius: var(--radius-lg);
  box-shadow: var(--shadow-soft);
}

.ui-floating-card {
  background: var(--surface-glass);
  border: 1rpx solid rgba(255,255,255,0.82);
  border-radius: var(--radius-lg);
  box-shadow: var(--shadow-float);
  backdrop-filter: blur(24px);
  -webkit-backdrop-filter: blur(24px);
}

.ui-pressable {
  transition: transform 180ms ease, box-shadow 180ms ease, opacity 180ms ease;
}

.ui-pressable:active {
  transform: translateY(3rpx) scale(0.975);
  box-shadow: var(--shadow-pressed);
}

.ui-primary-button {
  color: #fff;
  background: linear-gradient(135deg, #2478ff 0%, #32bfe2 100%);
  border: 1rpx solid rgba(255,255,255,0.35);
  border-radius: 999rpx;
  box-shadow: var(--shadow-blue);
  transition: transform 180ms ease, filter 180ms ease, box-shadow 180ms ease;
}

.ui-primary-button:active {
  transform: scale(0.97);
  filter: brightness(0.96);
  box-shadow: 0 8rpx 18rpx rgba(47, 128, 255, 0.22), inset 0 3rpx 8rpx rgba(16, 74, 162, 0.16);
}

.ui-icon-tile {
  display: flex;
  align-items: center;
  justify-content: center;
  border-radius: 26rpx;
  background: linear-gradient(145deg, #ffffff, #eaf1fb);
  border: 1rpx solid rgba(255,255,255,0.88);
  box-shadow: 10rpx 10rpx 22rpx rgba(168,180,201,0.24), -8rpx -8rpx 18rpx rgba(255,255,255,0.96), inset 0 3rpx 4rpx rgba(255,255,255,0.75);
}

.ui-status-dot {
  width: 14rpx;
  height: 14rpx;
  border-radius: 50%;
  background: var(--success);
  box-shadow: 0 0 0 8rpx rgba(57,191,120,0.12), 0 4rpx 10rpx rgba(57,191,120,0.34);
}

.ui-section-title {
  font-size: 34rpx;
  line-height: 1.3;
  font-weight: 760;
  letter-spacing: 1rpx;
  color: var(--ink);
}

.ui-section-caption {
  margin-top: 6rpx;
  font-size: 22rpx;
  line-height: 1.55;
  color: var(--ink-muted);
}

.ui-rise {
  animation: uiRise 420ms cubic-bezier(.22,.74,.25,1) both;
}

.ui-float {
  animation: uiFloat 4.8s ease-in-out infinite;
}

.avatar-source-panel {
  position: fixed;
  inset: 0;
  z-index: 1200;
}

.avatar-source-mask {
  position: absolute;
  inset: 0;
  background: rgba(31, 42, 61, 0.42);
  backdrop-filter: blur(6px);
  -webkit-backdrop-filter: blur(6px);
}

.avatar-source-sheet {
  position: absolute;
  left: 22rpx;
  right: 22rpx;
  bottom: calc(22rpx + env(safe-area-inset-bottom));
  padding: 18rpx 22rpx 24rpx;
  border-radius: 34rpx;
  background: linear-gradient(145deg, rgba(255,255,255,0.98), rgba(239,245,252,0.96));
  border: 1rpx solid rgba(255,255,255,0.92);
  box-shadow: 0 30rpx 70rpx rgba(31,42,61,0.30), inset 0 2rpx 0 rgba(255,255,255,0.92);
}

.avatar-source-handle {
  width: 72rpx;
  height: 8rpx;
  margin: 0 auto 20rpx;
  border-radius: 8rpx;
  background: rgba(154,166,184,0.28);
}

.avatar-source-title {
  display: block;
  font-size: 34rpx;
  font-weight: 820;
  color: var(--ink);
  text-align: center;
}

.avatar-source-desc {
  display: block;
  margin: 9rpx 24rpx 22rpx;
  font-size: 23rpx;
  line-height: 1.55;
  color: var(--ink-muted);
  text-align: center;
}

.avatar-source-item {
  display: flex;
  align-items: center;
  min-height: 108rpx;
  margin: 16rpx 0;
  padding: 18rpx 20rpx;
  border-radius: 28rpx;
  background: linear-gradient(145deg, #ffffff, #edf3fa);
  border: 1rpx solid rgba(255,255,255,0.90);
  box-shadow: 10rpx 12rpx 24rpx rgba(154,168,192,0.18), -8rpx -8rpx 18rpx rgba(255,255,255,0.88), inset 0 2rpx 0 rgba(255,255,255,0.88);
  box-sizing: border-box;
}

button.avatar-source-item {
  width: 100%;
  margin-left: 0;
  margin-right: 0;
  text-align: left;
  line-height: normal;
}

button.avatar-source-item::after {
  border: 0;
}

.avatar-source-icon {
  position: relative;
  flex-shrink: 0;
  width: 70rpx;
  height: 70rpx;
  margin-right: 20rpx;
  border-radius: 24rpx;
  box-shadow: inset 0 4rpx 7rpx rgba(255,255,255,0.76), 7rpx 9rpx 16rpx rgba(126,144,174,0.18);
}

.avatar-source-icon-wechat {
  background: linear-gradient(145deg, #e7fff3, #b8efd5);
}

.avatar-source-icon-local {
  background: linear-gradient(145deg, #e8f5ff, #b9dcff);
}

.avatar-source-icon-wechat::before {
  content: '';
  position: absolute;
  width: 40rpx;
  height: 28rpx;
  left: 15rpx;
  top: 22rpx;
  border-radius: 22rpx;
  background: #25b864;
  box-shadow: 12rpx -8rpx 0 -4rpx rgba(37,184,100,0.72);
}

.avatar-source-icon-local::before {
  content: '';
  position: absolute;
  width: 38rpx;
  height: 30rpx;
  left: 16rpx;
  top: 20rpx;
  border-radius: 8rpx;
  background: linear-gradient(145deg, #4da5ff, #1767e8);
}

.avatar-source-copy {
  display: flex;
  flex-direction: column;
}

.avatar-source-name {
  font-size: 29rpx;
  font-weight: 760;
  color: var(--ink);
}

.avatar-source-hint {
  margin-top: 7rpx;
  font-size: 22rpx;
  color: var(--ink-muted);
}

.avatar-source-cancel {
  margin-top: 12rpx;
  padding: 22rpx 0;
  text-align: center;
  border-radius: 999rpx;
  color: var(--ink-secondary);
  font-size: 29rpx;
  font-weight: 700;
  background: linear-gradient(145deg, #ffffff, #edf2f8);
  box-shadow: inset 0 2rpx 0 rgba(255,255,255,0.86), 6rpx 8rpx 15rpx rgba(151,168,193,0.16);
}
