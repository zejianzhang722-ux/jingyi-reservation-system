NODE_ENV=production
MYSQL_USER=jingyi
MYSQL_PASSWORD=replace-with-secret
MYSQL_ROOT_PASSWORD=replace-with-secret
MYSQL_DATABASE=jingyi_reservation
REDIS_PASSWORD=replace-with-secret
JWT_SECRET=replace-with-at-least-32-random-characters
OPS_MONITOR_TOKEN=replace-with-at-least-32-random-characters
AUDIT_IP_HASH_SALT=replace-with-at-least-32-random-characters
BACKUP_ENCRYPTION_KEY=replace-with-32-byte-base64-key
BACKUP_DIR=/var/lib/jingyi/backups
BACKUP_SECONDARY_DIR=/var/lib/jingyi/backup-secondary
ALLOW_SINGLE_COPY_BACKUP=false
WECHAT_APPID=
WECHAT_APPSECRET=
ALLOW_WECHAT_DISABLED=true
BASE_URL=https://reservation.example.edu
ADMIN_ORIGIN=https://reservation.example.edu
CORS_ORIGINS=https://reservation.example.edu,https://servicewechat.com,https://mp.weixin.qq.com
ENABLE_AUTOMATED_BACKUPS=true
BACKUP_CRON=30 2 * * *
RETENTION_CRON=15 3 * * 0
BACKUP_RETENTION_DAYS=30
BACKUP_MIN_KEEP=7
DATA_RETENTION_APPLY=false
